<UserControl x:Class="Central.Module.Global.Admin.IconDefaultsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button x:Name="AddBtn" Content="Add" Click="Add_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button x:Name="DeleteBtn" Content="Delete" Click="Delete_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button x:Name="SaveBtn" Content="Save" Click="Save_Click" Padding="12,4" Margin="0,0,4,0" FontWeight="SemiBold" />
            <Button x:Name="RefreshBtn" Content="Refresh" Click="Refresh_Click" Padding="12,4" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11" />
        </StackPanel>

        <!-- Icon Defaults Grid -->
        <dxg:GridControl x:Name="DefaultsGrid" Grid.Row="1" AutoGenerateColumns="None"
                          SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="DefaultsView"
                               AllowEditing="True"
                               NavigationStyle="Cell"
                               ShowGroupPanel="True"
                               ShowAutoFilterRow="True"
                               AllowColumnFiltering="True"
                               ShowFilterPanelMode="ShowAlways"
                               ShowTotalSummary="True"
                               NewItemRowPosition="None"
                               CellValueChanged="DefaultsView_CellValueChanged" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Id" Header="ID" Width="50" ReadOnly="True" />
                <dxg:GridColumn FieldName="Context" Header="Context" Width="150">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="True">
                            <dxe:ComboBoxEditSettings.Items>
                                <dxe:ComboBoxEditItem Content="status.device" />
                                <dxe:ComboBoxEditItem Content="device_type" />
                                <dxe:ComboBoxEditItem Content="grid.devices" />
                                <dxe:ComboBoxEditItem Content="grid.switches" />
                                <dxe:ComboBoxEditItem Content="grid.servicedesk" />
                                <dxe:ComboBoxEditItem Content="ribbon" />
                                <dxe:ComboBoxEditItem Content="action" />
                            </dxe:ComboBoxEditSettings.Items>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="ElementKey" Header="Element Key" Width="180" />
                <dxg:GridColumn FieldName="IconName" Header="Icon Name" Width="200" />
                <dxg:GridColumn FieldName="IconId" Header="Icon ID" Width="70" />
                <dxg:GridColumn FieldName="Color" Header="Color" Width="120">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="14" Height="14" Margin="2,0,6,0"
                                         Fill="{Binding RowData.Row.Color, Converter={StaticResource StringToBrush}}" />
                                <TextBlock Text="{Binding RowData.Row.Color}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
            </dxg:GridControl.Columns>
        </dxg:GridControl>
    </Grid>
</UserControl>
