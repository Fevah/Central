<UserControl x:Class="Central.Module.Global.Admin.SyncConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Add Config" Click="AddConfig_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Save" Click="Save_Click" Padding="12,4" Margin="0,0,4,0" FontWeight="SemiBold" />
            <Button Content="Run Sync" Click="RunSync_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Test Connection" Click="TestConnection_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,4" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11" />
        </StackPanel>

        <!-- Sync Configs Grid -->
        <dxg:GridControl x:Name="ConfigsGrid" Grid.Row="1" AutoGenerateColumns="None"
                          SelectionMode="Row" CurrentItemChanged="ConfigsGrid_CurrentItemChanged">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="ConfigsView" AllowEditing="True" NavigationStyle="Cell"
                               ShowAutoFilterRow="True" CellValueChanged="ConfigsView_CellValueChanged" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Id" Header="ID" Width="50" ReadOnly="True" />
                <dxg:GridColumn FieldName="Name" Header="Name" Width="180" />
                <dxg:GridColumn FieldName="AgentType" Header="Agent" Width="120">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="True">
                            <dxe:ComboBoxEditSettings.Items>
                                <dxe:ComboBoxEditItem Content="manage_engine" />
                                <dxe:ComboBoxEditItem Content="entra_id_scim" />
                                <dxe:ComboBoxEditItem Content="csv_import" />
                                <dxe:ComboBoxEditItem Content="rest_api" />
                            </dxe:ComboBoxEditSettings.Items>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="IsEnabled" Header="Enabled" Width="65" />
                <dxg:GridColumn FieldName="Direction" Header="Direction" Width="100">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.Items>
                                <dxe:ComboBoxEditItem Content="pull" />
                                <dxe:ComboBoxEditItem Content="push" />
                                <dxe:ComboBoxEditItem Content="bidirectional" />
                            </dxe:ComboBoxEditSettings.Items>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="IntervalMinutes" Header="Interval (min)" Width="90" />
                <dxg:GridColumn FieldName="MaxConcurrent" Header="Max Concurrent" Width="100" />
                <dxg:GridColumn FieldName="LastSyncAt" Header="Last Sync" Width="140" ReadOnly="True" />
                <dxg:GridColumn FieldName="LastSyncStatus" Header="Status" Width="80" ReadOnly="True" />
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" />

        <!-- Sync Log for selected config -->
        <dxg:GridControl x:Name="LogGrid" Grid.Row="3" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False" NavigationStyle="Row" ShowTotalSummary="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="StartedAt" Header="Started" Width="140" SortIndex="0" SortOrder="Descending" />
                <dxg:GridColumn FieldName="Status" Header="Status" Width="80" />
                <dxg:GridColumn FieldName="EntityName" Header="Entity" Width="120" />
                <dxg:GridColumn FieldName="RecordsRead" Header="Read" Width="60" />
                <dxg:GridColumn FieldName="RecordsCreated" Header="Created" Width="65" />
                <dxg:GridColumn FieldName="RecordsUpdated" Header="Updated" Width="65" />
                <dxg:GridColumn FieldName="RecordsFailed" Header="Failed" Width="60" />
                <dxg:GridColumn FieldName="DurationMs" Header="Duration (ms)" Width="90" />
                <dxg:GridColumn FieldName="ErrorMessage" Header="Error" Width="300" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Status" DisplayFormat="{}Runs: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
