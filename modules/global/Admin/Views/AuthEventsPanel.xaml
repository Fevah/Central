<UserControl x:Class="Central.Module.Global.Admin.AuthEventsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,4" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11" />
        </StackPanel>

        <dxg:GridControl x:Name="EventsGrid" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False" NavigationStyle="Row"
                               ShowGroupPanel="True" ShowAutoFilterRow="True"
                               ShowFilterPanelMode="ShowAlways" ShowTotalSummary="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Timestamp" Header="Time" Width="150" SortIndex="0" SortOrder="Descending" />
                <dxg:GridColumn FieldName="EventType" Header="Event" Width="80" />
                <dxg:GridColumn FieldName="ProviderType" Header="Provider" Width="80" />
                <dxg:GridColumn FieldName="Username" Header="Username" Width="150" />
                <dxg:GridColumn FieldName="Success" Header="Success" Width="70" />
                <dxg:GridColumn FieldName="ErrorMessage" Header="Error" Width="300" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Username" DisplayFormat="{}Events: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
