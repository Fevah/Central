<UserControl x:Class="Central.Module.Global.Admin.SshLogsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid">

    <UserControl.Resources>
        <!-- SSH Log row style: red for failed, green tint for success -->
        <Style x:Key="SshLogRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Success}" Value="False">
                    <Setter Property="Background" Value="#3C1414" />
                    <Setter Property="Foreground" Value="#FF8888" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Row.Success}" Value="True">
                    <Setter Property="Background" Value="#143C14" />
                    <Setter Property="Foreground" Value="#88FF88" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button x:Name="RefreshSshLogsButton" Content="Refresh" Click="RefreshSshLogsButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button x:Name="PurgeSshLogsButton" Content="Purge (30+ days)" Click="PurgeSshLogsButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="SshLogCountText" VerticalAlignment="Center" Foreground="#AAA" />
        </StackPanel>

        <!-- Log Grid -->
        <dxg:GridControl x:Name="SshLogsGrid" Grid.Row="1"
                         ItemsSource="{Binding SshLogs}"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         CurrentItemChanged="SshLogsGrid_CurrentItemChanged">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="SshLogsView"
                               ShowGroupPanel="True"
                               AllowColumnFiltering="True"
                               ShowFilterPanelMode="ShowAlways"
                               NavigationStyle="Row"
                               AllowEditing="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               RowStyle="{StaticResource SshLogRowStyle}"
                               ShowTotalSummary="False" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="StatusIcon" Header="OK"  Width="40"  AllowSorting="True" AllowEditing="False" />
                <dxg:GridColumn FieldName="StartedAt"   Header="Time"      Width="150" SortOrder="Descending" />
                <dxg:GridColumn FieldName="Hostname"    Header="Switch"    Width="150" />
                <dxg:GridColumn FieldName="HostIp"      Header="IP"        Width="120" />
                <dxg:GridColumn FieldName="Username"    Header="User"      Width="80"  />
                <dxg:GridColumn FieldName="Port"        Header="Port"      Width="60"  />
                <dxg:GridColumn FieldName="Success"     Header="OK"        Width="50"  />
                <dxg:GridColumn FieldName="ConfigLines" Header="Lines"     Width="60"  />
                <dxg:GridColumn FieldName="Duration"    Header="Duration"  Width="80"  />
                <dxg:GridColumn FieldName="Error"       Header="Error"     Width="300" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Hostname" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>

        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="#333" />

        <!-- Log Detail (raw log entries + raw output) -->
        <TabControl Grid.Row="3" Background="#1E1E1E">
            <TabItem Header="Log Entries">
                <TextBox x:Name="SshLogEntriesText"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         Background="#1E1E1E" Foreground="#CCC"
                         TextWrapping="NoWrap" />
            </TabItem>
            <TabItem Header="Raw Output">
                <TextBox x:Name="SshLogRawText"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         Background="#1E1E1E" Foreground="#CCC"
                         TextWrapping="NoWrap" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
