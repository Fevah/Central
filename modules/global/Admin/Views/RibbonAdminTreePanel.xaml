<UserControl x:Class="Central.Module.Global.Admin.RibbonAdminTreePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:local="clr-namespace:Central.Module.Global.Admin">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToCollapsed" NullValue="Collapsed" NotNullValue="Visible"
            xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" NullValue="Visible" NotNullValue="Collapsed"
            xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="+ Page" Click="AddPage_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="+ Group" Click="AddGroup_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="+ Item" Click="AddItem_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="+ Separator" Click="AddSeparator_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="▲" Click="MoveUp_Click" Margin="0,0,2,0" Padding="8,2" ToolTip="Move Up" />
            <Button Content="▼" Click="MoveDown_Click" Margin="0,0,4,0" Padding="8,2" ToolTip="Move Down" />
            <Button Content="🖼 Set Default Icon" Click="SetDefaultIcon_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="Push All Defaults" Click="PushAllDefaults_Click" Padding="12,2"
                    FontWeight="SemiBold" ToolTip="Save all icons/labels as defaults for all users" />
        </StackPanel>

        <!-- Admin Tree -->
        <dxg:TreeListControl x:Name="AdminTree" Grid.Row="1"
                              AutoGenerateColumns="None"
                              EnableSmartColumnsGeneration="False">
            <dxg:TreeListControl.View>
                <dxg:TreeListView x:Name="AdminTreeView"
                                   KeyFieldName="Id" ParentFieldName="ParentId"
                                   AllowEditing="True" NavigationStyle="Cell"
                                   ShowIndicator="True" ShowNodeImages="False"
                                   AutoExpandAllNodes="True"
                                   RowDoubleClick="AdminTreeView_RowDoubleClick"
                                   AllowDragDrop="True" />
            </dxg:TreeListControl.View>
            <dxg:TreeListControl.Columns>
                <dxg:TreeListColumn FieldName="NodeIcon" Header="" Width="30" AllowEditing="False">
                    <dxg:TreeListColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image Width="16" Height="16" Source="{Binding RowData.Row.IconPreview}"
                                       Visibility="{Binding RowData.Row.IconPreview, Converter={StaticResource NullToCollapsed}}" />
                                <TextBlock Text="{Binding RowData.Row.NodeIcon}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding RowData.Row.IconPreview, Converter={StaticResource NullToVisible}}" />
                            </Grid>
                        </DataTemplate>
                    </dxg:TreeListColumn.CellTemplate>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="DisplayText" Header="Item" Width="180" AllowEditing="False" />
                <dxg:TreeListColumn FieldName="DefaultIcon" Header="Default Icon" Width="160">
                    <dxg:TreeListColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Width="16" Height="16" Margin="0,0,4,0"
                                       Source="{Binding RowData.Row.IconPreview}" />
                                <TextBlock Text="{Binding RowData.Row.DefaultIcon}" VerticalAlignment="Center"
                                           FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </dxg:TreeListColumn.CellTemplate>
                    <dxg:TreeListColumn.EditSettings>
                        <dxe:ButtonEditSettings AllowDefaultButton="False">
                            <dxe:ButtonEditSettings.Buttons>
                                <dxe:ButtonInfo GlyphKind="Search" Click="AdminIconPicker_Click" />
                            </dxe:ButtonEditSettings.Buttons>
                        </dxe:ButtonEditSettings>
                    </dxg:TreeListColumn.EditSettings>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="DefaultLabel" Header="Default Label" Width="140" />
                <dxg:TreeListColumn FieldName="DisplayStyle" Header="Style" Width="85">
                    <dxg:TreeListColumn.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{x:Static local:RibbonAdminTreePanel.DisplayStyles}" />
                    </dxg:TreeListColumn.EditSettings>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="LinkTarget" Header="Link To" Width="160">
                    <dxg:TreeListColumn.EditSettings>
                        <dxe:ButtonEditSettings AllowDefaultButton="True">
                            <dxe:ButtonEditSettings.Buttons>
                                <dxe:ButtonInfo GlyphKind="Search" Click="LinkPicker_Click" />
                            </dxe:ButtonEditSettings.Buttons>
                        </dxe:ButtonEditSettings>
                    </dxg:TreeListColumn.EditSettings>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="IsHidden" Header="Hidden" Width="55" />
                <dxg:TreeListColumn FieldName="NodeType" Header="Type" Width="65" AllowEditing="False" />
                <dxg:TreeListColumn FieldName="Permission" Header="Permission" Width="120" />
                <dxg:TreeListColumn FieldName="ItemType" Header="Item Type" Width="80">
                    <dxg:TreeListColumn.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{x:Static local:RibbonAdminTreePanel.ItemTypes}" />
                    </dxg:TreeListColumn.EditSettings>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="SortOrder" Header="Order" Width="50" />
            </dxg:TreeListControl.Columns>
        </dxg:TreeListControl>
    </Grid>
</UserControl>
