<UserControl x:Class="Central.Module.Global.Admin.JobsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Schedules header + buttons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
            <TextBlock Text="Job Schedules" FontWeight="SemiBold" FontSize="14"
                       Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button x:Name="EnableJobButton" Content="Enable" Padding="8,3" Margin="0,0,4,0"
                    Click="EnableJobButton_Click" />
            <Button x:Name="DisableJobButton" Content="Disable" Padding="8,3" Margin="0,0,4,0"
                    Click="DisableJobButton_Click" />
            <Button x:Name="RunJobButton" Content="Run Now" Padding="8,3" Margin="0,0,4,0"
                    Click="RunJobButton_Click" FontWeight="SemiBold" />
            <Button x:Name="RefreshJobsButton" Content="Refresh" Padding="8,3"
                    Click="RefreshJobsButton_Click" />
        </StackPanel>

        <!-- Schedules grid -->
        <dxg:GridControl x:Name="SchedulesGrid" Grid.Row="1"
                         AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="SchedulesView"
                               ShowGroupPanel="False"
                               NavigationStyle="Row"
                               AllowEditing="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               SearchPanelNullText="Search..." />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Name"            Header="Job"       Width="200" />
                <dxg:GridColumn FieldName="JobType"         Header="Type"      Width="120" />
                <dxg:GridColumn FieldName="IsEnabled"       Header="Enabled"   Width="70" />
                <dxg:GridColumn FieldName="IntervalMinutes" Header="Interval"  Width="80" />
                <dxg:GridColumn FieldName="LastRunAt"       Header="Last Run"  Width="160" />
                <dxg:GridColumn FieldName="NextRunAt"       Header="Next Run"  Width="160" />
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <!-- History header -->
        <TextBlock Grid.Row="2" Text="Job History (last 50)" FontWeight="SemiBold" FontSize="14"
                   Foreground="#E0E0E0" Margin="8,8,8,4" />

        <!-- History grid -->
        <dxg:GridControl x:Name="HistoryGrid" Grid.Row="3"
                         AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="HistoryView"
                               ShowGroupPanel="False"
                               NavigationStyle="Row"
                               AllowEditing="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               SearchPanelNullText="Search...">
                    <dxg:TableView.RowStyle>
                        <Style TargetType="dxg:RowControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Row.Status}" Value="Failed">
                                    <Setter Property="Foreground" Value="#EF4444" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Row.Status}" Value="Success">
                                    <Setter Property="Foreground" Value="#22C55E" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </dxg:TableView.RowStyle>
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="JobType"     Header="Type"      Width="120" />
                <dxg:GridColumn FieldName="StartedAt"   Header="Started"   Width="160" />
                <dxg:GridColumn FieldName="Status"      Header="Status"    Width="80" />
                <dxg:GridColumn FieldName="Summary"     Header="Result"    Width="250" />
                <dxg:GridColumn FieldName="Succeeded"   Header="OK"        Width="50" />
                <dxg:GridColumn FieldName="Failed"      Header="Fail"      Width="50" />
                <dxg:GridColumn FieldName="TriggeredBy" Header="Triggered By" Width="140" />
            </dxg:GridControl.Columns>
        </dxg:GridControl>
    </Grid>
</UserControl>
