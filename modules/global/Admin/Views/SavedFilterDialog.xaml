<dx:DXWindow x:Class="Central.Module.Global.Admin.SavedFilterDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             Title="Manage Saved Filters"
             Width="500" Height="400"
             WindowStartupLocation="CenterOwner"
             ShowInTaskbar="False">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Save current filter -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Filter name:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <dxe:TextEdit x:Name="FilterNameEdit" Width="250" NullText="Enter a name for this filter..." />
            <Button Content="Save Current" Click="SaveCurrent_Click" Padding="12,4" Margin="8,0,0,0" />
        </StackPanel>

        <!-- Saved filters list -->
        <dxg:GridControl x:Name="FiltersGrid" Grid.Row="1" AutoGenerateColumns="None" SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False" NavigationStyle="Row"
                               ShowGroupPanel="False" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="FilterName" Header="Filter Name" Width="200" />
                <dxg:GridColumn FieldName="IsDefault" Header="Default" Width="60" />
                <dxg:GridColumn FieldName="SortOrder" Header="Created" Width="140" />
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,8">
            <Button Content="Apply" Click="Apply_Click" Padding="16,4" Margin="0,0,4,0" FontWeight="SemiBold" />
            <Button Content="Set Default" Click="SetDefault_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Delete" Click="Delete_Click" Padding="12,4" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11" />
        </StackPanel>

        <!-- Close -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Click="Close_Click" Padding="16,4" IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:DXWindow>
