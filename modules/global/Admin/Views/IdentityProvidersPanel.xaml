<UserControl x:Class="Central.Module.Global.Admin.IdentityProvidersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Add Provider" Click="Add_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Delete" Click="Delete_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Save" Click="Save_Click" Padding="12,4" Margin="0,0,4,0" FontWeight="SemiBold" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,4" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11" />
        </StackPanel>

        <!-- Identity Providers Grid -->
        <dxg:GridControl x:Name="ProvidersGrid" Grid.Row="1" AutoGenerateColumns="None"
                          SelectionMode="Row" CurrentItemChanged="ProvidersGrid_CurrentItemChanged">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="ProvidersView" AllowEditing="True" NavigationStyle="Cell"
                               ShowAutoFilterRow="True" CellValueChanged="ProvidersView_CellValueChanged" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Id" Header="ID" Width="50" ReadOnly="True" />
                <dxg:GridColumn FieldName="ProviderType" Header="Type" Width="100">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.Items>
                                <dxe:ComboBoxEditItem Content="local" />
                                <dxe:ComboBoxEditItem Content="entra_id" />
                                <dxe:ComboBoxEditItem Content="okta" />
                                <dxe:ComboBoxEditItem Content="saml2" />
                            </dxe:ComboBoxEditSettings.Items>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Name" Header="Name" Width="200" />
                <dxg:GridColumn FieldName="IsEnabled" Header="Enabled" Width="70" />
                <dxg:GridColumn FieldName="IsDefault" Header="Default" Width="70" />
                <dxg:GridColumn FieldName="Priority" Header="Priority" Width="70" />
                <dxg:GridColumn FieldName="MetadataUrl" Header="Metadata URL" Width="250" />
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" />

        <!-- Domain Mappings + Config Editor -->
        <dxg:GridControl x:Name="DomainGrid" Grid.Row="3" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="True" NavigationStyle="Cell"
                               NewItemRowPosition="Top" ShowAutoFilterRow="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="EmailDomain" Header="Email Domain" Width="250" />
                <dxg:GridColumn FieldName="ProviderName" Header="Provider" Width="200" ReadOnly="True" />
            </dxg:GridControl.Columns>
        </dxg:GridControl>
    </Grid>
</UserControl>
