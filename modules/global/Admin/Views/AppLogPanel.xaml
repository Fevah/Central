<UserControl x:Class="Central.Module.Global.Admin.AppLogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button x:Name="RefreshAppLogButton" Content="Refresh" Click="RefreshAppLogButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button x:Name="DeleteAppLogButton" Content="Delete Selected" Click="DeleteAppLogButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button x:Name="ClearAppLogButton" Content="Clear All" Click="ClearAppLogButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="AppLogCountText" VerticalAlignment="Center" Foreground="#AAA" />
        </StackPanel>

        <!-- Log Grid -->
        <dxg:GridControl x:Name="AppLogGrid" Grid.Row="1"
                         ItemsSource="{Binding AppLogs}"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         CurrentItemChanged="AppLogGrid_CurrentItemChanged">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="AppLogView"
                               ShowGroupPanel="True"
                               AllowColumnFiltering="True"
                               ShowFilterPanelMode="ShowAlways"
                               NavigationStyle="Row"
                               AllowEditing="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               ShowTotalSummary="False" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="DisplayTime" Header="Time"    Width="150" SortIndex="0" SortOrder="Descending" />
                <dxg:GridColumn FieldName="Level"       Header="Level"   Width="70"  AllowGrouping="True" />
                <dxg:GridColumn FieldName="Tag"         Header="Tag"     Width="100" AllowGrouping="True" />
                <dxg:GridColumn FieldName="Source"      Header="Source"  Width="180" />
                <dxg:GridColumn FieldName="Message"     Header="Message" Width="400" />
                <dxg:GridColumn FieldName="Username"    Header="User"    Width="80" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Source" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>

        <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="#333" />

        <!-- Detail text -->
        <TextBox x:Name="AppLogDetailText" Grid.Row="3"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="11"
                 Background="#1E1E1E" Foreground="#CCC"
                 TextWrapping="Wrap" />
    </Grid>
</UserControl>
