<dx:DXDialogWindow x:Class="Central.Module.Global.Admin.GalleryItemsEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    Title="Gallery Items Editor"
    Width="560" Height="420"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap" FontSize="12">
            <Run FontWeight="SemiBold">Gallery tile list.</Run>
            <LineBreak />
            Each row becomes a tile in the gallery. Click the icon cell to pick
            a per-tile icon; leave blank to inherit the gallery's default icon.
        </TextBlock>

        <dxg:GridControl x:Name="TilesGrid" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False" AllowEditing="True"
                               NavigationStyle="Cell" NewItemRowPosition="Bottom" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Caption" Header="Caption" Width="200" />
                <dxg:GridColumn FieldName="IconName" Header="Icon" Width="200">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ButtonEditSettings AllowDefaultButton="True">
                            <dxe:ButtonEditSettings.Buttons>
                                <dxe:ButtonInfo GlyphKind="Search" Click="PickTileIcon_Click" />
                                <dxe:ButtonInfo GlyphKind="Cancel" Click="ClearTileIcon_Click" />
                            </dxe:ButtonEditSettings.Buttons>
                        </dxe:ButtonEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="IconPreview" Header="" Width="34" AllowEditing="False">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <Image Width="16" Height="16" Source="{Binding RowData.Row.IconPreview}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="▲ Move Up" Click="MoveUp_Click" Padding="8,4" Margin="0,0,4,0" />
            <Button Content="▼ Move Down" Click="MoveDown_Click" Padding="8,4" Margin="0,0,4,0" />
            <Button Content="🗑 Remove" Click="Remove_Click" Padding="8,4" Margin="0,0,12,0" />
            <Button Content="OK" Click="OK_Click" Padding="14,4" Margin="0,0,4,0" FontWeight="SemiBold" IsDefault="True" />
            <Button Content="Cancel" Click="Cancel_Click" Padding="14,4" IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:DXDialogWindow>
