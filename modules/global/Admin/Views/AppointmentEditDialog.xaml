<dx:DXWindow x:Class="Central.Module.Global.Admin.AppointmentEditDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Title="Appointment"
             Width="500" Height="520"
             WindowStartupLocation="CenterOwner"
             ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Subject -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Subject:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:TextEdit x:Name="SubjectEdit" Grid.Row="0" Grid.Column="1" Margin="0,4" />

        <!-- Start / End -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Start:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:DateEdit x:Name="StartEdit" Grid.Row="1" Grid.Column="1" Margin="0,4" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="End:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:DateEdit x:Name="EndEdit" Grid.Row="2" Grid.Column="1" Margin="0,4" />

        <!-- All Day -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="All Day:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:CheckEdit x:Name="AllDayCheck" Grid.Row="3" Grid.Column="1" Margin="0,4" />

        <!-- Location -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Location:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:TextEdit x:Name="LocationEdit" Grid.Row="4" Grid.Column="1" Margin="0,4" />

        <!-- Resource -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Resource:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:ComboBoxEdit x:Name="ResourceCombo" Grid.Row="5" Grid.Column="1" Margin="0,4"
                            NullText="(None)" IsTextEditable="False" />

        <!-- Status -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Status:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:ComboBoxEdit x:Name="StatusCombo" Grid.Row="6" Grid.Column="1" Margin="0,4" IsTextEditable="False">
            <dxe:ComboBoxEdit.Items>
                <dxe:ComboBoxEditItem Content="Free" Tag="0" />
                <dxe:ComboBoxEditItem Content="Tentative" Tag="1" />
                <dxe:ComboBoxEditItem Content="Busy" Tag="2" />
                <dxe:ComboBoxEditItem Content="Out of Office" Tag="3" />
            </dxe:ComboBoxEdit.Items>
        </dxe:ComboBoxEdit>

        <!-- Link to Task/Ticket -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Task ID:" VerticalAlignment="Center" Margin="0,4" />
        <dxe:SpinEdit x:Name="TaskIdEdit" Grid.Row="7" Grid.Column="1" Margin="0,4"
                       MinValue="0" IsFloatValue="False" NullText="(None)" />

        <!-- Description -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Description:" VerticalAlignment="Top" Margin="0,4" />
        <dxe:TextEdit x:Name="DescriptionEdit" Grid.Row="8" Grid.Column="1" Margin="0,4"
                       AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />

        <!-- OK/Cancel -->
        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save" Click="Save_Click" Padding="16,4" Margin="0,0,4,0" FontWeight="SemiBold" />
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,4" IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:DXWindow>
