<UserControl x:Class="Central.Module.Global.Admin.IntegrationsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Integrations list -->
        <dxg:GridControl x:Name="IntegrationsGrid" Grid.Row="0" AutoGenerateColumns="None"
                          CurrentItemChanged="IntegrationsGrid_CurrentItemChanged">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="IntegrationsView" AllowEditing="True" NavigationStyle="Cell"
                               ShowGroupPanel="False" ShowTotalSummary="False" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="StatusIcon" Header="" Width="30" AllowEditing="False" />
                <dxg:GridColumn FieldName="DisplayName" Header="Integration" Width="220" />
                <dxg:GridColumn FieldName="IntegrationType" Header="Auth Type" Width="80" AllowEditing="False" />
                <dxg:GridColumn FieldName="BaseUrl" Header="URL" Width="250" />
                <dxg:GridColumn FieldName="IsEnabled" Header="Enabled" Width="60" />
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" />

        <!-- Config panel for selected integration -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4">
            <Button Content="Test Connection" Click="TestConnection_Click" Padding="12,4" Margin="0,0,8,0" />
            <Button Content="Setup OAuth" Click="SetupOAuth_Click" Padding="12,4" Margin="0,0,8,0" />
            <Button Content="Enable/Disable" Click="ToggleEnabled_Click" Padding="12,4" Margin="0,0,8,0" />
            <Button Content="Save Config" Click="SaveConfig_Click" Padding="12,4" FontWeight="SemiBold" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Margin="12,0,0,0"
                       FontSize="11" Foreground="#9CA3AF" />
        </StackPanel>

        <!-- Credential + Config editor -->
        <dx:DXTabControl Grid.Row="3">
            <dx:DXTabItem Header="Credentials">
                <StackPanel Margin="8">
                    <TextBlock Text="OAuth2 Credentials (stored encrypted)" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="OAuth URL:" VerticalAlignment="Center" Margin="0,4" />
                        <dxe:TextEdit x:Name="OAuthUrlEdit" Grid.Row="0" Grid.Column="1" Margin="0,4" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Client ID:" VerticalAlignment="Center" Margin="0,4" />
                        <dxe:TextEdit x:Name="ClientIdEdit" Grid.Row="1" Grid.Column="1" Margin="0,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Client Secret:" VerticalAlignment="Center" Margin="0,4" />
                        <dxe:PasswordBoxEdit x:Name="ClientSecretEdit" Grid.Row="2" Grid.Column="1" Margin="0,4" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Auth Code:" VerticalAlignment="Center" Margin="0,4" />
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                            <dxe:TextEdit x:Name="AuthCodeEdit" Width="300" NullText="Paste grant code here..." />
                            <Button Content="Exchange" Click="ExchangeCode_Click" Margin="8,0,0,0" Padding="12,2" />
                        </StackPanel>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Refresh Token:" VerticalAlignment="Center" Margin="0,4" />
                        <dxe:TextEdit x:Name="RefreshTokenEdit" Grid.Row="4" Grid.Column="1" Margin="0,4"
                                       IsReadOnly="True" NullText="(exchange auth code to get this)" />
                    </Grid>
                </StackPanel>
            </dx:DXTabItem>
            <dx:DXTabItem Header="Log">
                <dxg:GridControl x:Name="LogGrid" AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" AllowEditing="False" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="CreatedAt" Header="Time" Width="140" />
                        <dxg:GridColumn FieldName="Action" Header="Action" Width="120" />
                        <dxg:GridColumn FieldName="Status" Header="Status" Width="70" />
                        <dxg:GridColumn FieldName="Message" Header="Message" Width="400" />
                        <dxg:GridColumn FieldName="DurationMs" Header="ms" Width="60" />
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </dx:DXTabItem>
            <dx:DXTabItem Header="Config JSON">
                <dxe:TextEdit x:Name="ConfigJsonEdit" AcceptsReturn="True" TextWrapping="Wrap"
                               VerticalContentAlignment="Top" Margin="4"
                               FontFamily="Cascadia Mono, Consolas" FontSize="12" />
            </dx:DXTabItem>
        </dx:DXTabControl>
    </Grid>
</UserControl>
