<UserControl x:Class="Central.Module.Global.Admin.AuditLogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <TextBlock Text="Entity:" VerticalAlignment="Center" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="EntityFilter" Width="140" NullText="All" EditValueChanged="Filter_Changed">
                <dxe:ComboBoxEdit.Items>
                    <dxe:ComboBoxEditItem Content="Device" />
                    <dxe:ComboBoxEditItem Content="Switch" />
                    <dxe:ComboBoxEditItem Content="User" />
                    <dxe:ComboBoxEditItem Content="Setting" />
                </dxe:ComboBoxEdit.Items>
            </dxe:ComboBoxEdit>
            <TextBlock Text="User:" VerticalAlignment="Center" Margin="8,0,4,0" />
            <dxe:TextEdit x:Name="UserFilter" Width="120" NullText="All" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,4" Margin="8,0,0,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11" Margin="16,0,0,0" />
        </StackPanel>

        <dxg:GridControl x:Name="AuditGrid" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False" NavigationStyle="Row"
                               ShowGroupPanel="True" ShowAutoFilterRow="True"
                               ShowFilterPanelMode="ShowAlways" ShowTotalSummary="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Timestamp" Header="Time" Width="150" SortIndex="0" SortOrder="Descending" />
                <dxg:GridColumn FieldName="Action" Header="Action" Width="100" />
                <dxg:GridColumn FieldName="EntityType" Header="Entity" Width="90" />
                <dxg:GridColumn FieldName="EntityId" Header="ID" Width="60" />
                <dxg:GridColumn FieldName="EntityName" Header="Name" Width="180" />
                <dxg:GridColumn FieldName="Username" Header="User" Width="120" />
                <dxg:GridColumn FieldName="Details" Header="Details" Width="250" />
                <dxg:GridColumn FieldName="BeforeJson" Header="Before" Width="200" />
                <dxg:GridColumn FieldName="AfterJson" Header="After" Width="200" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Action" DisplayFormat="{}Entries: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
