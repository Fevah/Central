<dxc:DXDialogWindow x:Class="Central.Module.Global.Platform.Dialogs.ResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
        Title="Reset Password" Width="400" Height="260"
        WindowStartupLocation="CenterOwner">

    <dxlc:LayoutControl Orientation="Vertical" Padding="12">

        <dxlc:LayoutItem Label="User">
            <dxe:TextEdit x:Name="UserLabel" IsReadOnly="True" />
        </dxlc:LayoutItem>

        <dxlc:LayoutItem Label="New Password">
            <dxe:PasswordBoxEdit x:Name="PasswordEdit" />
        </dxlc:LayoutItem>

        <dxlc:LayoutItem Label="Confirm Password">
            <dxe:PasswordBoxEdit x:Name="ConfirmEdit" />
        </dxlc:LayoutItem>

        <dxe:CheckEdit x:Name="ForceVerifyCheck" Content="Require email re-verification" Margin="0,8,0,0" />

        <TextBlock x:Name="ValidationMsg" Foreground="#EF4444" FontSize="12" />

    </dxlc:LayoutControl>
</dxc:DXDialogWindow>
