<UserControl x:Class="Central.Module.Global.Platform.SubscriptionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="SubscriptionsGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="SubscriptionsView"
                           ShowGroupPanel="True"
                           AllowColumnFiltering="True"
                           AllowEditing="False"
                           ShowAutoFilterRow="True" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="tenant_slug" Header="Tenant" Width="120" Fixed="Left" />
            <dxg:GridColumn FieldName="tenant_name" Header="Tenant Name" Width="160" />
            <dxg:GridColumn FieldName="tier" Header="Tier" Width="100" GroupIndex="0" />
            <dxg:GridColumn FieldName="plan_name" Header="Plan" Width="120" />
            <dxg:GridColumn FieldName="max_users" Header="Max Users" Width="90" />
            <dxg:GridColumn FieldName="max_devices" Header="Max Devices" Width="100" />
            <dxg:GridColumn FieldName="status" Header="Status" Width="90" />
            <dxg:GridColumn FieldName="started_at" Header="Started" Width="140" />
            <dxg:GridColumn FieldName="expires_at" Header="Expires" Width="140" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="tenant_slug" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
