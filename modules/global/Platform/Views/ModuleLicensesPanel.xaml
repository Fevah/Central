<UserControl x:Class="Central.Module.Global.Platform.ModuleLicensesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="LicensesGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="LicensesView"
                           ShowGroupPanel="True"
                           AllowColumnFiltering="True"
                           AllowEditing="False"
                           ShowAutoFilterRow="True" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="tenant_slug" Header="Tenant" Width="120" Fixed="Left" GroupIndex="0" />
            <dxg:GridColumn FieldName="tenant_name" Header="Tenant Name" Width="160" />
            <dxg:GridColumn FieldName="module_code" Header="Module" Width="120" />
            <dxg:GridColumn FieldName="module_name" Header="Module Name" Width="150" />
            <dxg:GridColumn FieldName="is_base" Header="Base" Width="60" />
            <dxg:GridColumn FieldName="granted_at" Header="Granted" Width="140" />
            <dxg:GridColumn FieldName="expires_at" Header="Expires" Width="140" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="module_code" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
