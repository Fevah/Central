<UserControl x:Class="Central.Module.Global.Dashboard.DashboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C0C0C0"/>
            <Setter Property="Margin" Value="8,12,8,6"/>
        </Style>
        <Style x:Key="CardPanel" TargetType="WrapPanel">
            <Setter Property="Margin" Value="4,0,4,8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <!-- Dashboard sections are built dynamically from
                 DashboardContributionRegistry at render time. Each enabled
                 feature module contributes one section; disabled modules
                 contribute nothing and their sections don't appear. -->
            <StackPanel x:Name="Sections"/>

            <!-- Recent Activity — sourced from NotificationService, not
                 module-specific, stays part of the dashboard shell. -->
            <TextBlock Text="Recent Activity" Style="{StaticResource SectionHeader}"/>
            <Border BorderBrush="#333" BorderThickness="1" CornerRadius="4" Margin="4,0,4,8" MaxHeight="300">
                <ListBox x:Name="ActivityList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                           Foreground="#707070" Width="40" FontSize="11"/>
                                <TextBlock Text="{Binding Icon}" Width="20" FontSize="11"/>
                                <TextBlock Text="{Binding Message}" Foreground="#D0D0D0" FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
