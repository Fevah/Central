<UserControl x:Class="Central.Module.GlobalAdmin.Views.TenantsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <UserControl.Resources>
        <Style x:Key="InactiveRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.is_active}" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <dxg:GridControl x:Name="TenantsGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="TenantsView"
                           ShowGroupPanel="False"
                           AllowColumnFiltering="True"
                           AllowEditing="False"
                           ShowAutoFilterRow="True"
                           RowStyle="{StaticResource InactiveRowStyle}" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="slug" Header="Slug" Width="120" Fixed="Left" />
            <dxg:GridColumn FieldName="display_name" Header="Display Name" Width="180" />
            <dxg:GridColumn FieldName="domain" Header="Domain" Width="150" />
            <dxg:GridColumn FieldName="tier" Header="Tier" Width="100" />
            <dxg:GridColumn FieldName="is_active" Header="Active" Width="70" />
            <dxg:GridColumn FieldName="plan_name" Header="Plan" Width="110" />
            <dxg:GridColumn FieldName="user_count" Header="Users" Width="70" />
            <dxg:GridColumn FieldName="created_at" Header="Created" Width="140" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="slug" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
