<UserControl x:Class="Central.Module.GlobalAdmin.Views.GlobalAdminAuditPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="AuditGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="AuditView"
                           ShowGroupPanel="False"
                           AllowEditing="False"
                           ShowAutoFilterRow="True"
                           AllowColumnFiltering="True"
                           BestFitMode="AllRows" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="ActionIcon" Header="" Width="30" AllowAutoFilter="False" />
            <dxg:GridColumn FieldName="CreatedAt" Header="Timestamp" Width="160" SortOrder="Descending" />
            <dxg:GridColumn FieldName="ActorEmail" Header="Actor" Width="180" />
            <dxg:GridColumn FieldName="Action" Header="Action" Width="160" />
            <dxg:GridColumn FieldName="EntityType" Header="Entity" Width="100" />
            <dxg:GridColumn FieldName="EntityId" Header="Entity ID" Width="140" />
            <dxg:GridColumn FieldName="Details" Header="Details" Width="300" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Action" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
