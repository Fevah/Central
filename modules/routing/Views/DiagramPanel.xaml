<UserControl x:Class="Central.Module.Routing.Views.DiagramPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxdiag="http://schemas.devexpress.com/winfx/2008/xaml/diagram">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Refresh" Click="RefreshButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Fit to View" Click="FitButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Tree Layout" Click="TreeLayoutButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Layered Layout" Click="SugiyamaButton_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="DiagramStatusText" VerticalAlignment="Center" Foreground="#AAA" Margin="8,0,0,0" />
        </StackPanel>
        <dxdiag:DiagramControl x:Name="NetworkDiagram" Grid.Row="1"
                                 Background="#1A1A2E"
                                 PageSize="5000,3000" />
    </Grid>
</UserControl>
