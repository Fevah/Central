<UserControl x:Class="Central.Module.Tasks.Views.TaskDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,0,1" />
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <StackPanel x:Name="DetailContent" Visibility="Collapsed">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock x:Name="TaskStatusIcon" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock x:Name="TaskTitle" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Meta row -->
            <WrapPanel Margin="0,0,0,12">
                <Border Background="#334155" CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                    <TextBlock x:Name="TaskType" FontSize="11" Foreground="#D1D5DB" />
                </Border>
                <Border x:Name="TaskPriorityBorder" CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                    <TextBlock x:Name="TaskPriority" FontSize="11" Foreground="White" FontWeight="SemiBold" />
                </Border>
                <Border Background="#334155" CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                    <TextBlock x:Name="TaskBuilding" FontSize="11" Foreground="#D1D5DB" />
                </Border>
            </WrapPanel>

            <!-- Properties -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                    <TextBlock Text="Assigned To" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="TaskAssigned" Style="{StaticResource ValueStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                    <TextBlock Text="Created By" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="TaskCreatedBy" Style="{StaticResource ValueStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,6">
                    <TextBlock Text="Due Date" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="TaskDueDate" Style="{StaticResource ValueStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,6">
                    <TextBlock Text="Hours" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="TaskHours" Style="{StaticResource ValueStyle}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,6">
                    <TextBlock Text="Tags" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="TaskTags" Style="{StaticResource ValueStyle}" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                    <TextBlock Text="Created" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="TaskCreatedAt" Style="{StaticResource ValueStyle}" />
                </StackPanel>
            </Grid>

            <!-- Description -->
            <TextBlock Text="DESCRIPTION" FontWeight="SemiBold" FontSize="11"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,4" />
            <TextBox x:Name="TaskDescription" IsReadOnly="True"
                     Background="Transparent" BorderThickness="0"
                     TextWrapping="Wrap" FontSize="12" Foreground="#D1D5DB"
                     MinHeight="60" Margin="0,0,0,12" />

            <!-- Comments -->
            <TextBlock Text="COMMENTS" FontWeight="SemiBold" FontSize="11"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,4" />
            <ItemsControl x:Name="CommentsList" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E293B" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" FontSize="11" Foreground="#93C5FD" />
                                    <TextBlock Text="{Binding CreatedAt, StringFormat=' · {0:MMM dd HH:mm}'}" FontSize="10" Foreground="#6B7280" />
                                </StackPanel>
                                <TextBlock Text="{Binding CommentText}" TextWrapping="Wrap" FontSize="12" Foreground="#D1D5DB" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add comment -->
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="NewCommentBox" Width="280" Height="26"
                         Background="#0F172A" Foreground="#F1F5F9" BorderThickness="1" BorderBrush="#334155" />
                <Button x:Name="AddCommentButton" Content="Add Comment" Padding="8,4" Margin="4,0,0,0"
                        Click="AddComment_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
