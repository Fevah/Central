<UserControl x:Class="Central.Module.Tasks.Views.SprintPlanPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Project:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="ProjectSelector" Width="180" Height="24" NullText="Select Project"
                               IsTextEditable="False" EditValueChanged="ProjectSelector_Changed"
                               DisplayMember="Name" ValueMember="Id" />
            <TextBlock Text="  " />
            <TextBlock Text="Sprint:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="SprintSelector" Width="180" Height="24" NullText="Select Sprint"
                               IsTextEditable="False" EditValueChanged="SprintSelector_Changed"
                               DisplayMember="DisplayName" ValueMember="Id" />
            <TextBlock Text="  " />
            <Button x:Name="NewSprintButton" Content="+ New Sprint" Padding="10,4" Margin="0,0,4,0"
                    Click="NewSprint_Click" FontWeight="SemiBold" />
            <Button x:Name="CloseSprintButton" Content="Close Sprint" Padding="10,4" Margin="0,0,4,0"
                    Click="CloseSprint_Click" />
        </StackPanel>

        <!-- Sprint Header / Capacity Bar -->
        <Border Grid.Row="1" Background="#1E293B" Margin="8,0,8,4" CornerRadius="4" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="SprintNameText" Text="No sprint selected" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
                    <TextBlock x:Name="SprintDatesText" Text="" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
                <!-- Capacity progress bar -->
                <Grid Grid.Column="1" Margin="20,0">
                    <ProgressBar x:Name="CapacityBar" Height="18" Minimum="0" Maximum="100" Value="0"
                                 Background="#374151" Foreground="#3B82F6" />
                    <TextBlock x:Name="CapacityText" Text="0 / 0 pts" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                </Grid>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock x:Name="ItemCountText" Text="0 items" Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center" />
                    <TextBlock x:Name="GoalText" Text="" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sprint Backlog Grid -->
        <dxg:GridControl x:Name="SprintGrid" Grid.Row="2" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="SprintView"
                                AllowEditing="True"
                                NavigationStyle="Cell"
                                ShowAutoFilterRow="True"
                                ShowTotalSummary="True"
                                ShowFilterPanelMode="ShowAlways"
                                UseEvenRowBackground="True"
                                SearchPanelNullText="Search sprint..."
                                MultiSelectMode="Row"
                                ValidateRow="SprintView_ValidateRow"
                                InvalidRowException="SprintView_InvalidRowException" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="SprintPriority" Header="#" Width="40" ReadOnly="True" SortOrder="Ascending" Fixed="Left" />
                <dxg:GridColumn FieldName="StatusIcon" Header="" Width="30" AllowEditing="False">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.StatusIcon}"
                                       Foreground="{Binding RowData.Row.StatusColor, Converter={StaticResource StringToBrush}}"
                                       FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Title" Header="Item" Width="260" Fixed="Left" />
                <dxg:GridColumn FieldName="TaskType" Header="Type" Width="70" ReadOnly="True" />
                <dxg:GridColumn FieldName="Status" Header="Status" Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>Open</sys:String>
                                    <sys:String>InProgress</sys:String>
                                    <sys:String>Review</sys:String>
                                    <sys:String>Done</sys:String>
                                    <sys:String>Blocked</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Points" Header="Points" Width="60">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="0" MaxValue="999" IsFloatValue="True" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="WorkRemaining" Header="Remaining" Width="75">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="0" MaxValue="9999" IsFloatValue="True" Mask="n1" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="AssignedToName" Header="Assigned" Width="110" ReadOnly="True" />
                <dxg:GridColumn FieldName="Priority" Header="Priority" Width="70" ReadOnly="True" />
                <dxg:GridColumn FieldName="Category" Header="Category" Width="90" ReadOnly="True" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Title" DisplayFormat="{}Items: {0}" />
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="Points" DisplayFormat="{}Points: {0:n1}" />
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="WorkRemaining" DisplayFormat="{}Remaining: {0:n1}h" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
