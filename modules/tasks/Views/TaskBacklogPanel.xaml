<UserControl x:Class="Central.Module.Tasks.Views.TaskBacklogPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Project:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="ProjectSelector" Width="180" Height="24" NullText="Select Project"
                               IsTextEditable="False" EditValueChanged="ProjectSelector_Changed"
                               DisplayMember="Name" ValueMember="Id" />
            <TextBlock Text="  " />
            <TextBlock Text="Commit to:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="SprintSelector" Width="160" Height="24" NullText="Select Sprint"
                               IsTextEditable="False" DisplayMember="Name" ValueMember="Id" />
            <Button x:Name="CommitButton" Content="Commit Selected" Padding="10,4" Margin="8,0,0,0"
                    Click="CommitToSprint_Click" FontWeight="SemiBold" />
            <Button x:Name="UncommitButton" Content="Uncommit" Padding="10,4" Margin="4,0,0,0"
                    Click="Uncommit_Click" />
            <TextBlock Text="  " />
            <dxe:ComboBoxEdit x:Name="CategoryFilter" Width="110" Height="24" NullText="All Categories"
                               IsTextEditable="False" EditValueChanged="Filter_Changed" />
            <TextBlock x:Name="BacklogCountText" VerticalAlignment="Center" Foreground="#9CA3AF"
                       FontSize="11" Margin="12,0,0,0" />
        </StackPanel>

        <!-- Backlog Tree (drag-sortable by backlog_priority) -->
        <dxg:TreeListControl x:Name="BacklogTree" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:TreeListControl.View>
                <dxg:TreeListView x:Name="BacklogTreeView"
                                   KeyFieldName="Id"
                                   ParentFieldName="ParentId"
                                   ShowColumnHeaders="True"
                                   ShowIndicator="False"
                                   AutoExpandAllNodes="True"
                                   AllowEditing="True"
                                   NavigationStyle="Cell"
                                   ShowAutoFilterRow="True"
                                   ShowTotalSummary="True"
                                   AllowDragDrop="True"
                                   UseEvenRowBackground="True"
                                   ShowFilterPanelMode="ShowAlways"
                                   SearchPanelNullText="Search backlog..."
                                   MultiSelectMode="Row"
                                   ValidateNode="BacklogTreeView_ValidateNode"
                                   InvalidNodeException="BacklogTreeView_InvalidNodeException"
 />
            </dxg:TreeListControl.View>
            <dxg:TreeListControl.Columns>
                <dxg:TreeListColumn FieldName="BacklogPriority" Header="#" Width="40" ReadOnly="True" SortOrder="Ascending" Fixed="Left" />
                <dxg:TreeListColumn FieldName="StatusIcon" Header="" Width="30" AllowEditing="False">
                    <dxg:TreeListColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.StatusIcon}"
                                       Foreground="{Binding RowData.Row.StatusColor, Converter={StaticResource StringToBrush}}"
                                       FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </dxg:TreeListColumn.CellTemplate>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="Title" Header="Item" Width="280" Fixed="Left" />
                <dxg:TreeListColumn FieldName="TaskType" Header="Type" Width="70" ReadOnly="True" />
                <dxg:TreeListColumn FieldName="Category" Header="Category" Width="90">
                    <dxg:TreeListColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>Feature</sys:String>
                                    <sys:String>Enhancement</sys:String>
                                    <sys:String>TechDebt</sys:String>
                                    <sys:String>Bug</sys:String>
                                    <sys:String>Ops</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:TreeListColumn.EditSettings>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="Points" Header="Points" Width="60">
                    <dxg:TreeListColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="0" MaxValue="999" IsFloatValue="True" />
                    </dxg:TreeListColumn.EditSettings>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="Priority" Header="Priority" Width="70" ReadOnly="True" />
                <dxg:TreeListColumn FieldName="Risk" Header="Risk" Width="60" ReadOnly="True" />
                <dxg:TreeListColumn FieldName="CommittedToName" Header="Sprint" Width="110" ReadOnly="True" />
                <dxg:TreeListColumn FieldName="AssignedToName" Header="Assigned" Width="110" ReadOnly="True" />
                <dxg:TreeListColumn FieldName="Tags" Header="Tags" Width="100" />
            </dxg:TreeListControl.Columns>
            <dxg:TreeListControl.TotalSummary>
                <dxg:TreeListSummaryItem SummaryType="Count" FieldName="Title" DisplayFormat="{}Items: {0}" />
                <dxg:TreeListSummaryItem SummaryType="Sum" FieldName="Points" DisplayFormat="{}Points: {0:n1}" />
            </dxg:TreeListControl.TotalSummary>
        </dxg:TreeListControl>
    </Grid>
</UserControl>
