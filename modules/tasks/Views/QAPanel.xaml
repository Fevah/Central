<UserControl x:Class="Central.Module.Tasks.Views.QAPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Project:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="ProjectSelector" Width="180" Height="24" NullText="All Projects"
                               IsTextEditable="False" EditValueChanged="ProjectSelector_Changed"
                               DisplayMember="Name" ValueMember="Id" />
            <TextBlock Text="  " />
            <Button x:Name="NewBugButton" Content="+ New Bug" Padding="10,4" Margin="0,0,4,0"
                    Click="NewBug_Click" FontWeight="SemiBold" />
            <Button x:Name="TriageButton" Content="Batch Triage" Padding="10,4" Margin="0,0,8,0"
                    Click="BatchTriage_Click" />
            <dxe:ComboBoxEdit x:Name="SeverityFilter" Width="100" Height="24" NullText="All Severity"
                               IsTextEditable="False" EditValueChanged="Filter_Changed" />
            <dxe:ComboBoxEdit x:Name="StatusFilter" Width="100" Height="24" NullText="All Status"
                               IsTextEditable="False" Margin="4,0,0,0" EditValueChanged="Filter_Changed" />
            <dxe:ComboBoxEdit x:Name="BugPriorityFilter" Width="100" Height="24" NullText="All Priority"
                               IsTextEditable="False" Margin="4,0,0,0" EditValueChanged="Filter_Changed" />
            <TextBlock x:Name="BugCountText" VerticalAlignment="Center" Foreground="#9CA3AF"
                       FontSize="11" Margin="12,0,0,0" />
        </StackPanel>

        <!-- Bug Grid -->
        <dxg:GridControl x:Name="BugGrid" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="BugView"
                                AllowEditing="True"
                                NavigationStyle="Cell"
                                ShowAutoFilterRow="True"
                                ShowTotalSummary="True"
                                ShowFilterPanelMode="ShowAlways"
                                AllowColumnFiltering="True"
                                UseEvenRowBackground="True"
                                SearchPanelNullText="Search bugs..."
                                MultiSelectMode="Row"
                                ValidateRow="BugView_ValidateRow"
                                InvalidRowException="BugView_InvalidRowException" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <!-- ID -->
                <dxg:GridColumn FieldName="Id" Header="ID" Width="50" ReadOnly="True" Fixed="Left" />
                <!-- Severity icon -->
                <dxg:GridColumn FieldName="Severity" Header="Severity" Width="90">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,4,0"
                                        Background="{Binding RowData.Row.SeverityColor, Converter={StaticResource StringToBrush}}" />
                                <TextBlock Text="{Binding RowData.Row.Severity}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>Blocker</sys:String>
                                    <sys:String>Critical</sys:String>
                                    <sys:String>Major</sys:String>
                                    <sys:String>Minor</sys:String>
                                    <sys:String>Cosmetic</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <!-- Bug Priority -->
                <dxg:GridColumn FieldName="BugPriority" Header="Priority" Width="80">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>Critical</sys:String>
                                    <sys:String>High</sys:String>
                                    <sys:String>Medium</sys:String>
                                    <sys:String>Low</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <!-- Title -->
                <dxg:GridColumn FieldName="Title" Header="Title" Width="280" Fixed="Left" />
                <!-- Status -->
                <dxg:GridColumn FieldName="Status" Header="Status" Width="100">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>New</sys:String>
                                    <sys:String>Triaged</sys:String>
                                    <sys:String>InProgress</sys:String>
                                    <sys:String>Resolved</sys:String>
                                    <sys:String>Verified</sys:String>
                                    <sys:String>Closed</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <!-- Assigned -->
                <dxg:GridColumn FieldName="AssignedToName" Header="Assigned" Width="110" ReadOnly="True" />
                <!-- Reporter -->
                <dxg:GridColumn FieldName="CreatedByName" Header="Reporter" Width="110" ReadOnly="True" />
                <!-- Sprint -->
                <dxg:GridColumn FieldName="CommittedToName" Header="Sprint" Width="100" ReadOnly="True" />
                <!-- Points -->
                <dxg:GridColumn FieldName="Points" Header="Points" Width="55">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="0" MaxValue="99" IsFloatValue="True" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <!-- Category -->
                <dxg:GridColumn FieldName="Category" Header="Category" Width="90" ReadOnly="True" />
                <!-- Risk -->
                <dxg:GridColumn FieldName="Risk" Header="Risk" Width="70">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>None</sys:String>
                                    <sys:String>Low</sys:String>
                                    <sys:String>Medium</sys:String>
                                    <sys:String>High</sys:String>
                                    <sys:String>Critical</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <!-- Due Date -->
                <dxg:GridColumn FieldName="DueDate" Header="Due" Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:DateEditSettings DisplayFormat="yyyy-MM-dd" Mask="yyyy-MM-dd" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <!-- Created -->
                <dxg:GridColumn FieldName="CreatedAt" Header="Created" Width="90" ReadOnly="True">
                    <dxg:GridColumn.EditSettings>
                        <dxe:DateEditSettings DisplayFormat="yyyy-MM-dd" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <!-- Building -->
                <dxg:GridColumn FieldName="Building" Header="Building" Width="80" />
                <!-- Tags -->
                <dxg:GridColumn FieldName="Tags" Header="Tags" Width="100" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Title" DisplayFormat="{}Bugs: {0}" />
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="Points" DisplayFormat="{}Points: {0:n1}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
