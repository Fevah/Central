<UserControl x:Class="Central.Module.Tasks.Views.MyTasksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Core.Converters;assembly=Central.Core">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="My Tasks" FontWeight="SemiBold" FontSize="14" Foreground="White" VerticalAlignment="Center" />
            <TextBlock Text="  " />
            <dxe:ComboBoxEdit x:Name="GroupBySelector" Width="120" Height="24" NullText="Group By"
                               IsTextEditable="False" EditValueChanged="GroupBy_Changed" />
            <dxe:ComboBoxEdit x:Name="StatusFilter" Width="100" Height="24" NullText="All Status"
                               IsTextEditable="False" Margin="4,0,0,0" EditValueChanged="Filter_Changed" />
            <TextBlock x:Name="MyTaskCountText" VerticalAlignment="Center" Foreground="#9CA3AF"
                       FontSize="11" Margin="12,0,0,0" />
        </StackPanel>
        <dxg:GridControl x:Name="MyTasksGrid" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="MyTasksView"
                                AllowEditing="True" NavigationStyle="Cell"
                                ShowAutoFilterRow="True" ShowTotalSummary="True"
                                ShowFilterPanelMode="ShowAlways" UseEvenRowBackground="True"
                                SearchPanelNullText="Search my tasks..."
                                ShowGroupPanel="True"
                                ValidateRow="MyTasksView_ValidateRow"
                                InvalidRowException="MyTasksView_InvalidRowException" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="StatusIcon" Header="" Width="30" AllowEditing="False">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.StatusIcon}"
                                       Foreground="{Binding RowData.Row.StatusColor, Converter={StaticResource StringToBrush}}"
                                       FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Title" Header="Task" Width="260" Fixed="Left" />
                <dxg:GridColumn FieldName="Status" Header="Status" Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>Open</sys:String><sys:String>InProgress</sys:String>
                                    <sys:String>Review</sys:String><sys:String>Done</sys:String><sys:String>Blocked</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Priority" Header="Priority" Width="70" ReadOnly="True" />
                <dxg:GridColumn FieldName="ProjectName" Header="Project" Width="120" ReadOnly="True" />
                <dxg:GridColumn FieldName="SprintName" Header="Sprint" Width="100" ReadOnly="True" />
                <dxg:GridColumn FieldName="WorkRemaining" Header="Remaining" Width="75">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="0" MaxValue="9999" IsFloatValue="True" Mask="n1" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Points" Header="Points" Width="55" ReadOnly="True" />
                <dxg:GridColumn FieldName="DueDateDisplay" Header="Due" Width="90" ReadOnly="True" />
                <dxg:GridColumn FieldName="TaskType" Header="Type" Width="70" ReadOnly="True" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Title" DisplayFormat="{}Tasks: {0}" />
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="Points" DisplayFormat="{}Points: {0:n1}" />
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="WorkRemaining" DisplayFormat="{}Remaining: {0:n1}h" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
