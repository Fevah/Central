<UserControl x:Class="Central.Module.Dashboard.Views.DashboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C0C0C0"/>
            <Setter Property="Margin" Value="8,12,8,6"/>
        </Style>
        <Style x:Key="CardPanel" TargetType="WrapPanel">
            <Setter Property="Margin" Value="4,0,4,8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8">
            <!-- Infrastructure Health -->
            <TextBlock Text="Infrastructure Health" Style="{StaticResource SectionHeader}"/>
            <WrapPanel x:Name="InfraCards" Style="{StaticResource CardPanel}"/>

            <!-- Network Devices -->
            <TextBlock Text="Network Devices" Style="{StaticResource SectionHeader}"/>
            <WrapPanel x:Name="DeviceCards" Style="{StaticResource CardPanel}"/>

            <!-- Tasks -->
            <TextBlock Text="Task Management" Style="{StaticResource SectionHeader}"/>
            <WrapPanel x:Name="TaskCards" Style="{StaticResource CardPanel}"/>

            <!-- Recent Activity -->
            <TextBlock Text="Recent Activity" Style="{StaticResource SectionHeader}"/>
            <Border BorderBrush="#333" BorderThickness="1" CornerRadius="4" Margin="4,0,4,8" MaxHeight="300">
                <ListBox x:Name="ActivityList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                           Foreground="#707070" Width="40" FontSize="11"/>
                                <TextBlock Text="{Binding Icon}" Width="20" FontSize="11"/>
                                <TextBlock Text="{Binding Message}" Foreground="#D0D0D0" FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Quick Actions -->
            <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeader}"/>
            <WrapPanel Margin="4,0,4,8">
                <Button x:Name="BtnPingAll" Content="Ping All Switches" Margin="4" Padding="12,6"
                        Background="#1E3A5F" Foreground="White" BorderThickness="0"/>
                <Button x:Name="BtnRefreshAll" Content="Refresh Data" Margin="4" Padding="12,6"
                        Background="#1E3A5F" Foreground="White" BorderThickness="0"/>
                <Button x:Name="BtnExportAll" Content="Export Devices" Margin="4" Padding="12,6"
                        Background="#1E3A5F" Foreground="White" BorderThickness="0"/>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
