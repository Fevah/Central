<dx:DXWindow x:Class="Central.Module.Networking.Hierarchy.HierarchyDetailDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Title="Hierarchy entity"
             Width="520" Height="560"
             WindowStartupLocation="CenterOwner"
             ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleLabel" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock x:Name="SubtitleLabel" FontSize="11" Foreground="#808080" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Parent picker (shown for new Site / Building only) -->
                <StackPanel x:Name="ParentSection" Visibility="Collapsed" Margin="0,0,0,8">
                    <TextBlock x:Name="ParentLabel" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit x:Name="ParentCombo" IsTextEditable="False"
                                      DisplayMember="DisplayText" ValueMember="Id"/>
                </StackPanel>

                <!-- Common: Code + Name -->
                <TextBlock Text="Code" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <dxe:TextEdit x:Name="CodeBox" Margin="0,0,0,8"/>

                <TextBlock Text="Display name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <dxe:TextEdit x:Name="NameBox" Margin="0,0,0,8"/>

                <!-- Status + Lock (two-column row) -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <dxe:ComboBoxEdit x:Name="StatusCombo" IsTextEditable="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Lock" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <dxe:ComboBoxEdit x:Name="LockCombo" IsTextEditable="False"/>
                    </StackPanel>
                </Grid>

                <!-- Region-specific -->
                <StackPanel x:Name="RegionSection" Visibility="Collapsed">
                    <TextBlock Text="B2B mesh policy" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit x:Name="B2bPolicyCombo" IsTextEditable="False" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Site-specific -->
                <StackPanel x:Name="SiteSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="City" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:TextEdit x:Name="CityBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Country" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:TextEdit x:Name="CountryBox"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Timezone (IANA)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:TextEdit x:Name="TimezoneBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max buildings" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="SiteMaxBuildings" MinValue="0" MaxValue="1000" IsFloatValue="False"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Building-specific -->
                <StackPanel x:Name="BuildingSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Building #" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="BuildingNumberBox" MinValue="0" MaxValue="99999" IsFloatValue="False"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Max floors" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="BuildingMaxFloors" MinValue="0" MaxValue="500" IsFloatValue="False"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Max devices" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="BuildingMaxDevices" MinValue="0" MaxValue="999999" IsFloatValue="False"/>
                        </StackPanel>
                    </Grid>
                    <CheckBox x:Name="ReservedCheck" Content="Reserved (shell building, not yet active)"
                              Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Notes -->
                <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <dxe:TextEdit x:Name="NotesBox" Height="80"
                              TextWrapping="Wrap" AcceptsReturn="True"
                              VerticalContentAlignment="Top"/>

                <!-- Read-only metadata (edit mode only) -->
                <Border x:Name="MetaSection" BorderBrush="#333" BorderThickness="0,1,0,0"
                        Margin="0,12,0,0" Padding="0,8,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="MetaLabel" FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="90" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button x:Name="SaveButton" Content="Save" Width="90" Click="Save_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</dx:DXWindow>
