<UserControl x:Class="Central.Module.Networking.Links.BuilderPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Device selector bar -->
        <Border Grid.Row="0" Padding="8,6" Background="#252526"
                BorderThickness="0,0,0,1" BorderBrush="#3C3C3C">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Device:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#CCC" FontWeight="SemiBold" />
                <dxe:ComboBoxEdit x:Name="BuilderDeviceCombo"
                                  Width="300" NullText="Select a device..."
                                  EditValueChanged="BuilderDeviceCombo_EditValueChanged" />
                <TextBlock x:Name="BuilderStatusText" Margin="16,0,0,0"
                           VerticalAlignment="Center" Foreground="#888" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Split: pipeline left, preview right -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="260" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: Pipeline sections -->
            <DockPanel Grid.Column="0" Background="#1E1E1E">
                <TextBlock DockPanel.Dock="Top" Text="PIPELINE" FontWeight="Bold"
                           Foreground="#888" FontSize="11" Margin="12,8,12,4" />
                <Separator DockPanel.Dock="Top" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="BuilderPipeline"
                                  ItemsSource="{Binding BuilderSections}" Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2" Padding="4" CornerRadius="3"
                                        Background="#252526" BorderThickness="0">
                                    <Expander IsExpanded="False">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <Rectangle Width="4" Height="20" RadiusX="2" RadiusY="2" Margin="0,0,8,0">
                                                    <Rectangle.Fill>
                                                        <SolidColorBrush Color="{Binding ColorHex}" />
                                                    </Rectangle.Fill>
                                                </Rectangle>
                                                <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                          VerticalAlignment="Center"
                                                          Checked="Section_Toggled"
                                                          Unchecked="Section_Toggled" />
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold" Foreground="#DDD"
                                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                                                <TextBlock Foreground="#666" FontSize="10"
                                                           Margin="6,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="({0})">
                                                            <Binding Path="LineCount" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding Items}" Margin="32,2,4,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                              Content="{Binding DisplayText}"
                                                              Foreground="#BBB" FontSize="11"
                                                              Margin="0,1"
                                                              Checked="Item_Toggled"
                                                              Unchecked="Item_Toggled" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" Background="#333"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- RIGHT: Config preview -->
            <DockPanel Grid.Column="2" Background="#1E1E1E">
                <Border DockPanel.Dock="Top" Padding="8,4" Background="#252526"
                        BorderThickness="0,0,0,1" BorderBrush="#3C3C3C">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="BuilderLineCount" FontSize="11"
                                   Foreground="#888" VerticalAlignment="Center" />
                        <Button Content="Copy" Padding="12,3" Margin="16,0,0,0"
                                Click="CopyButton_Click" />
                        <Button Content="Download" Padding="12,3" Margin="8,0,0,0"
                                Click="DownloadButton_Click" />
                    </StackPanel>
                </Border>
                <RichTextBox x:Name="BuilderConfigPreview"
                             IsReadOnly="True"
                             FontFamily="Cascadia Mono, Consolas, Courier New"
                             FontSize="11"
                             Background="#1E1E1E" Foreground="#D4D4D4"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
