<UserControl x:Class="Central.Module.Networking.ScopeGrants.ScopeGrantsAdminPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Status bar -->
        <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Scope grants (RBAC)" FontWeight="SemiBold" Foreground="#D0D0D0"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="StatusLabel" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Grid Grid.Row="1" Margin="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="User id:" VerticalAlignment="Center"
                       Margin="0,0,4,0" Foreground="#B0B0B0"/>
            <TextBox Grid.Column="1" x:Name="UserFilterBox"
                     ToolTip="Filter by app_users.id — leave blank for all"/>

            <TextBlock Grid.Column="2" Text="Action:" VerticalAlignment="Center"
                       Margin="10,0,4,0" Foreground="#B0B0B0"/>
            <dxe:ComboBoxEdit Grid.Column="3" x:Name="ActionFilterCombo"
                              IsTextEditable="True"/>

            <TextBlock Grid.Column="4" Text="Entity type:" VerticalAlignment="Center"
                       Margin="10,0,4,0" Foreground="#B0B0B0"/>
            <dxe:ComboBoxEdit Grid.Column="5" x:Name="EntityTypeFilterCombo"
                              IsTextEditable="True"/>

            <Button Grid.Column="7" x:Name="RunFilterButton" Content="Filter"
                    Width="80" Margin="8,0,4,0" Click="OnRunFilter"/>
            <Button Grid.Column="8" x:Name="NewGrantButton" Content="New grant"
                    Width="90" Margin="0,0,4,0" Click="OnNewGrant"/>
            <Button Grid.Column="9" x:Name="DeleteGrantButton" Content="Delete"
                    Width="70" Margin="0,0,4,0" Click="OnDeleteGrant"/>
            <Button Grid.Column="10" x:Name="CheckPermissionButton" Content="Check…"
                    Width="80" Click="OnCheckPermission"
                    ToolTip="Dry-run the resolver for a (user, action, entity_type) triple"/>
        </Grid>

        <!-- Grant grid -->
        <dxg:GridControl Grid.Row="2" x:Name="GrantsGrid"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         ShowBorder="False">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True"
                               ShowIndicator="False"
                               ShowGroupPanel="True"
                               AllowEditing="False"/>
            </dxg:GridControl.View>
            <dxg:GridControl.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show audit history"
                              Click="OnContextShowAudit"
                              ToolTip="Open the Audit panel filtered to this grant's id — shows create / delete / any future edits"/>
                    <Separator/>
                    <MenuItem Header="Copy grant id" Click="OnContextCopyId"/>
                </ContextMenu>
            </dxg:GridControl.ContextMenu>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="UserId"        Header="User"        Width="60"/>
                <dxg:GridColumn FieldName="Action"        Header="Action"      Width="100"/>
                <dxg:GridColumn FieldName="EntityType"    Header="Entity"      Width="130"/>
                <dxg:GridColumn FieldName="ScopeType"     Header="Scope"       Width="90"/>
                <dxg:GridColumn FieldName="ScopeEntityId" Header="Scope id"    Width="240"/>
                <dxg:GridColumn FieldName="Status"        Header="Status"      Width="80"/>
                <dxg:GridColumn FieldName="Notes"         Header="Notes"       Width="*"/>
                <dxg:GridColumn FieldName="Id"            Header="Grant id"    Width="240"/>
                <dxg:GridColumn FieldName="Version"       Header="v"           Width="40"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <!-- Summary -->
        <Border Grid.Row="3" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="8,4">
            <TextBlock x:Name="SummaryLabel" Foreground="#909090"/>
        </Border>
    </Grid>
</UserControl>
