<Window x:Class="Central.Module.Networking.ScopeGrants.CheckPermissionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        Title="Check permission"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                   Margin="0,0,0,10" Foreground="#B0B0B0"
                   Text="Dry-run the scope_grants resolver: would this (user, action, entity_type) tuple be allowed? Optional entity id narrows the question to a specific row; omit for an any-row yes/no."/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="User id:"     VerticalAlignment="Center" Margin="0,4"/>
        <DockPanel Grid.Row="1" Grid.Column="1" LastChildFill="True" Margin="0,4">
            <Button DockPanel.Dock="Right" Content="Me" Width="36" Margin="4,0,0,0"
                    Click="OnFillMe"
                    ToolTip="Fill with your own user id — check 'can I do this?' without looking it up first"/>
            <TextBox x:Name="UserIdBox"/>
        </DockPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Action:"      VerticalAlignment="Center" Margin="0,4"/>
        <dxe:ComboBoxEdit Grid.Row="2" Grid.Column="1" x:Name="ActionCombo"
                          IsTextEditable="True" Margin="0,4"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Entity type:" VerticalAlignment="Center" Margin="0,4"/>
        <dxe:ComboBoxEdit Grid.Row="3" Grid.Column="1" x:Name="EntityTypeCombo"
                          IsTextEditable="True" Margin="0,4"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Entity id:"   VerticalAlignment="Center" Margin="0,4"/>
        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="EntityIdBox" Margin="0,4"
                   ToolTip="Optional UUID of a specific row — empty asks whether the user has *any* access to the entity type"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Check" Width="90" Margin="4,0" IsDefault="True" Click="OnCheck"/>
            <Button Content="Cancel" Width="80" Margin="4,0" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
