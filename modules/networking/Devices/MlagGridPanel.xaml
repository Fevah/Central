<UserControl x:Class="Central.Module.Networking.Devices.MlagGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="MlagGrid"
                     ItemsSource="{Binding MlagConfigs}"
                     AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="MlagView"
                           ShowGroupPanel="True" AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways" NavigationStyle="Row"
                           AllowEditing="False" ShowTotalSummary="False"
                           UseEvenRowBackground="True"
                           ShowAutoFilterRow="True" SearchPanelNullText="Search...">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                                <Setter Property="Background" Value="#FDE9D9" />
                                <Setter Property="Foreground" Value="#7A3B1E" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Building"      Header="Building"    Width="100" AllowGrouping="True" />
            <dxg:GridColumn FieldName="DomainType"    Header="Domain Type" Width="110" />
            <dxg:GridColumn FieldName="MlagDomain"    Header="MLAG Domain" Width="110" />
            <dxg:GridColumn FieldName="SwitchA"       Header="Switch A"    Width="170" />
            <dxg:GridColumn FieldName="SwitchB"       Header="Switch B"    Width="170" />
            <dxg:GridColumn FieldName="PeerLinkAe"    Header="Peer AE"     Width="90" />
            <dxg:GridColumn FieldName="PeerLinkSubnet" Header="Peer Subnet" Width="130" />
            <dxg:GridColumn FieldName="Node0Ip"       Header="Node 0 IP"   Width="120" />
            <dxg:GridColumn FieldName="Node1Ip"       Header="Node 1 IP"   Width="120" />
            <dxg:GridColumn FieldName="Status"        Header="Status"      Width="80">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="MlagStatusCombo" IsTextEditable="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Building" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
