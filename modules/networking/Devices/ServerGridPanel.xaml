<UserControl x:Class="Central.Module.Networking.Devices.ServerGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <UserControl.Resources>
        <!-- Cell style for NIC columns when their NIC status is RESERVED -->
        <Style x:Key="Nic1ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic1Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nic2ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic2Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nic3ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic3Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nic4ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic4Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <dxg:GridControl x:Name="ServersGrid"
                     ItemsSource="{Binding Servers}"
                     AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="ServersView"
                           ShowGroupPanel="True" AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways" NavigationStyle="Row"
                           AllowEditing="True" ShowTotalSummary="False"
                           UseEvenRowBackground="True"
                           ShowAutoFilterRow="True" SearchPanelNullText="Search...">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                                <Setter Property="Background" Value="#FDE9D9" />
                                <Setter Property="Foreground" Value="#7A3B1E" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Building"    Header="Building"    Width="100" AllowGrouping="True" ReadOnly="True" />
            <dxg:GridColumn FieldName="ServerName"  Header="Server"      Width="180" ReadOnly="True" Fixed="Left" />
            <dxg:GridColumn FieldName="ServerAs"    Header="ASN"         Width="70"  ReadOnly="True" />
            <dxg:GridColumn FieldName="LoopbackIp"  Header="Loopback"    Width="130" ReadOnly="True" />
            <dxg:GridColumn FieldName="Nic1Ip"      Header="NIC1 IP"     Width="120" ReadOnly="True" CellStyle="{StaticResource Nic1ReservedCell}" />
            <dxg:GridColumn FieldName="Nic1Router"  Header="NIC1 Router" Width="120" ReadOnly="True" CellStyle="{StaticResource Nic1ReservedCell}" />
            <dxg:GridColumn FieldName="Nic1Subnet"  Header="NIC1 Subnet" Width="130" ReadOnly="True" CellStyle="{StaticResource Nic1ReservedCell}" />
            <dxg:GridColumn FieldName="Nic1Status"  Header="NIC1 Status" Width="90"  CellStyle="{StaticResource Nic1ReservedCell}">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="False">
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="Active" />
                            <dxe:ComboBoxEditItem Content="Down" />
                            <dxe:ComboBoxEditItem Content="RESERVED" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Nic2Ip"      Header="NIC2 IP"     Width="120" ReadOnly="True" CellStyle="{StaticResource Nic2ReservedCell}" />
            <dxg:GridColumn FieldName="Nic2Router"  Header="NIC2 Router" Width="120" ReadOnly="True" CellStyle="{StaticResource Nic2ReservedCell}" />
            <dxg:GridColumn FieldName="Nic2Subnet"  Header="NIC2 Subnet" Width="130" ReadOnly="True" CellStyle="{StaticResource Nic2ReservedCell}" />
            <dxg:GridColumn FieldName="Nic2Status"  Header="NIC2 Status" Width="90"  CellStyle="{StaticResource Nic2ReservedCell}">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="False">
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="Active" />
                            <dxe:ComboBoxEditItem Content="Down" />
                            <dxe:ComboBoxEditItem Content="RESERVED" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Nic3Ip"      Header="NIC3 IP"     Width="120" ReadOnly="True" CellStyle="{StaticResource Nic3ReservedCell}" />
            <dxg:GridColumn FieldName="Nic3Router"  Header="NIC3 Router" Width="120" ReadOnly="True" CellStyle="{StaticResource Nic3ReservedCell}" />
            <dxg:GridColumn FieldName="Nic3Subnet"  Header="NIC3 Subnet" Width="130" ReadOnly="True" CellStyle="{StaticResource Nic3ReservedCell}" />
            <dxg:GridColumn FieldName="Nic3Status"  Header="NIC3 Status" Width="90"  CellStyle="{StaticResource Nic3ReservedCell}">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="False">
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="Active" />
                            <dxe:ComboBoxEditItem Content="Down" />
                            <dxe:ComboBoxEditItem Content="RESERVED" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Nic4Ip"      Header="NIC4 IP"     Width="120" ReadOnly="True" CellStyle="{StaticResource Nic4ReservedCell}" />
            <dxg:GridColumn FieldName="Nic4Router"  Header="NIC4 Router" Width="120" ReadOnly="True" CellStyle="{StaticResource Nic4ReservedCell}" />
            <dxg:GridColumn FieldName="Nic4Subnet"  Header="NIC4 Subnet" Width="130" ReadOnly="True" CellStyle="{StaticResource Nic4ReservedCell}" />
            <dxg:GridColumn FieldName="Nic4Status"  Header="NIC4 Status" Width="90"  CellStyle="{StaticResource Nic4ReservedCell}">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="False">
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="Active" />
                            <dxe:ComboBoxEditItem Content="Down" />
                            <dxe:ComboBoxEditItem Content="RESERVED" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Status"      Header="Status"      Width="80" ReadOnly="True" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="ServerName" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
        <dxg:GridControl.DetailDescriptor>
            <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailNics">
                <dxg:GridControl AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" ShowColumnHeaders="True"
                                       AllowEditing="False" NavigationStyle="Row" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Nic"    Header="NIC"    Width="70" />
                        <dxg:GridColumn FieldName="Ip"     Header="IP"     Width="140" />
                        <dxg:GridColumn FieldName="Router" Header="Router" Width="140" />
                        <dxg:GridColumn FieldName="Subnet" Header="Subnet" Width="100" />
                        <dxg:GridColumn FieldName="Status" Header="Status" Width="80" />
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </dxg:DataControlDetailDescriptor>
        </dxg:GridControl.DetailDescriptor>
    </dxg:GridControl>
</UserControl>
