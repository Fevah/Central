<UserControl x:Class="Central.Module.Networking.Devices.MstpGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="MstpGrid"
                     ItemsSource="{Binding MstpConfigs}"
                     AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="MstpView"
                           ShowGroupPanel="True" AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways" NavigationStyle="Row"
                           AllowEditing="False" ShowTotalSummary="False"
                           UseEvenRowBackground="True"
                           ShowAutoFilterRow="True" SearchPanelNullText="Search...">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                                <Setter Property="Background" Value="#FDE9D9" />
                                <Setter Property="Foreground" Value="#7A3B1E" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Building"     Header="Building"    Width="100" AllowGrouping="True" />
            <dxg:GridColumn FieldName="DeviceName"   Header="Device"      Width="190" />
            <dxg:GridColumn FieldName="DeviceRole"   Header="Role"        Width="120" />
            <dxg:GridColumn FieldName="MstpPriority" Header="Priority"    Width="100" />
            <dxg:GridColumn FieldName="Notes"        Header="Notes"       Width="250" />
            <dxg:GridColumn FieldName="Status"       Header="Status"      Width="80">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="MstpStatusCombo" IsTextEditable="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Building" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
