<UserControl x:Class="Central.Module.Networking.Switches.DeployPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <TextBlock x:Name="DeployHeaderText" Text="Deploy Config"
                       FontWeight="SemiBold" FontSize="14" Foreground="#E0E0E0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="DeployStatusText" Margin="16,0,0,0"
                       Foreground="#AAA" VerticalAlignment="Center" />
        </StackPanel>

        <dx:DXTabControl x:Name="DeployTabs" Grid.Row="1">
            <dx:DXTabItem x:Name="DeployTabA" Header="Switch A">
                <TextBox x:Name="DeployConfigA" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12"
                         Background="#1E1E1E" Foreground="#22C55E"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </dx:DXTabItem>
            <dx:DXTabItem x:Name="DeployTabB" Header="Switch B">
                <TextBox x:Name="DeployConfigB" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12"
                         Background="#1E1E1E" Foreground="#22C55E"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </dx:DXTabItem>
            <dx:DXTabItem x:Name="DeployTabLog" Header="Log">
                <TextBox x:Name="DeployLogText" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="11"
                         Background="#1E1E1E" Foreground="#CCC"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" />
            </dx:DXTabItem>
        </dx:DXTabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8"
                    HorizontalAlignment="Right">
            <Button x:Name="DeployConfirmButton" Content="Confirm &amp; Deploy"
                    Padding="16,6" Margin="0,0,8,0"
                    Background="#22C55E" Foreground="White" FontWeight="SemiBold"
                    Click="DeployConfirmButton_Click" />
            <Button x:Name="DeployCancelButton" Content="Cancel"
                    Padding="16,6"
                    Click="DeployCancelButton_Click" />
        </StackPanel>
    </Grid>
</UserControl>
