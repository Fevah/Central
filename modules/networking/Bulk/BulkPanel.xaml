<UserControl x:Class="Central.Module.Networking.Bulk.BulkPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- Status bar -->
        <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Bulk import / export" FontWeight="SemiBold" Foreground="#D0D0D0"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="StatusLabel" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <!-- Toolbar: entity / mode / dry-run / actions -->
        <Grid Grid.Row="1" Margin="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Entity:" VerticalAlignment="Center"
                       Margin="0,0,4,0" Foreground="#B0B0B0"/>
            <dxe:ComboBoxEdit Grid.Column="1" x:Name="EntityCombo"
                              IsTextEditable="False" ShowSizeGrip="False"/>

            <TextBlock Grid.Column="2" Text="Mode:" VerticalAlignment="Center"
                       Margin="10,0,4,0" Foreground="#B0B0B0"/>
            <dxe:ComboBoxEdit Grid.Column="3" x:Name="ModeCombo"
                              IsTextEditable="False" ShowSizeGrip="False"/>

            <CheckBox Grid.Column="4" x:Name="DryRunCheck" Content="Dry run"
                      Margin="14,0,0,0" VerticalAlignment="Center"
                      IsChecked="True" Foreground="#D0D0D0"
                      ToolTip="When ticked, the engine validates without writing. Apply runs with this OFF."/>

            <dxe:ComboBoxEdit Grid.Column="6" x:Name="FormatCombo"
                              IsTextEditable="False" ShowSizeGrip="False"
                              Width="90" Margin="8,0,4,0"
                              ToolTip="CSV uses the in-panel editor; XLSX rounds-trips through the file dialog directly (editor is bypassed for XLSX apply)"/>

            <Button Grid.Column="7" x:Name="ExportButton" Content="Export…"
                    Width="90" Margin="0,0,4,0" Click="OnExport"
                    ToolTip="Download the current entity's rows — CSV opens in the editor + saves to file; XLSX saves bytes directly to file"/>
            <Button Grid.Column="8" x:Name="OpenButton" Content="Open file…"
                    Width="90" Margin="0,0,4,0" Click="OnOpenFile"
                    ToolTip="CSV: load into editor. XLSX: pick a file to import directly (bypasses the editor since it's binary)"/>
            <Button Grid.Column="9" x:Name="ValidateButton" Content="Validate"
                    Width="90" Margin="0,0,4,0" Click="OnValidate"
                    ToolTip="Run the importer in dry-run regardless of the checkbox (CSV only; XLSX import runs immediately from file)"/>
            <Button Grid.Column="10" x:Name="ApplyButton" Content="Apply"
                    Width="90" Margin="0,0,4,0" Click="OnApply"
                    ToolTip="Run the importer for real (DB writes); confirms first when dry-run is OFF"/>
            <Button Grid.Column="11" x:Name="ClearButton" Content="Clear"
                    Width="80" Click="OnClear"/>
        </Grid>

        <!-- CSV editor (operator paste / load / edit) -->
        <Border Grid.Row="2" BorderBrush="#333" BorderThickness="1" Margin="8,0,8,4">
            <TextBox x:Name="CsvBox"
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="NoWrap"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#1E1E1E"
                     Foreground="#D0D0D0"
                     Padding="6"
                     ToolTip="CSV body — paste, type, or load via 'Open file…'"/>
        </Border>

        <!-- Outcome summary banner -->
        <Border Grid.Row="3" BorderBrush="#333" BorderThickness="0,1,0,1" Padding="8,4" x:Name="SummaryBar"
                Background="#252525" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="SummaryLabel" Foreground="#D0D0D0" FontWeight="SemiBold"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="SummaryDetail" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <!-- Outcomes grid (per-row) -->
        <dxg:GridControl Grid.Row="4" x:Name="OutcomesGrid"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         ShowBorder="False">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True"
                               ShowIndicator="False"
                               ShowGroupPanel="False"
                               AllowEditing="False"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="RowNumber"  Header="Row"        Width="60"/>
                <dxg:GridColumn FieldName="Ok"         Header="OK"         Width="40"/>
                <dxg:GridColumn FieldName="Identifier" Header="Identifier" Width="200"/>
                <dxg:GridColumn FieldName="ErrorText"  Header="Errors"     Width="*"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>
    </Grid>
</UserControl>
