<UserControl x:Class="Central.Module.Networking.Audit.AuditViewerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status bar -->
        <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Audit" FontWeight="SemiBold" Foreground="#D0D0D0"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="StatusLabel" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <!-- Filter bar (two rows so Entity id has space to show a full uuid) -->
        <StackPanel Grid.Row="1" Margin="8,6,8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Entity:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#B0B0B0"/>
                <dxe:ComboBoxEdit Grid.Column="1" x:Name="EntityTypeCombo"
                                  IsTextEditable="True" NullText="(any)"/>

                <TextBlock Grid.Column="2" Text="Action:" VerticalAlignment="Center" Margin="10,0,4,0" Foreground="#B0B0B0"/>
                <TextBox   Grid.Column="3" x:Name="ActionBox"/>

                <TextBlock Grid.Column="4" Text="Actor:" VerticalAlignment="Center" Margin="10,0,4,0" Foreground="#B0B0B0"/>
                <TextBox   Grid.Column="5" x:Name="ActorBox"/>

                <TextBlock Grid.Column="6" Text="From:" VerticalAlignment="Center" Margin="10,0,4,0" Foreground="#B0B0B0"/>
                <dxe:DateEdit Grid.Column="7" x:Name="FromDate"/>

                <TextBlock Grid.Column="8" Text="To:" VerticalAlignment="Center" Margin="10,0,4,0" Foreground="#B0B0B0"/>
                <dxe:DateEdit Grid.Column="9" x:Name="ToDate"/>

                <Button Grid.Column="11" x:Name="ClearFiltersButton" Content="Clear filters"
                        Width="100" Margin="8,0,4,0" Click="OnClearFilters"
                        ToolTip="Empty every filter field including a drill-down entity id from another panel"/>
                <Button Grid.Column="12" x:Name="RunButton" Content="Run Query" Width="100"
                        Click="OnRun" Margin="0,0,0,0"/>
            </Grid>

            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Entity ID:" VerticalAlignment="Center"
                           Margin="0,0,4,0" Foreground="#B0B0B0"
                           ToolTip="When a search / grid context menu drills into the audit panel, the entity uuid it targeted lands here — editable so operators can widen or narrow manually"/>
                <TextBox   Grid.Column="1" x:Name="EntityIdBox" FontFamily="Consolas"/>

                <TextBlock Grid.Column="2" Text="Correlation:" VerticalAlignment="Center" Margin="10,0,4,0" Foreground="#B0B0B0"/>
                <TextBox   Grid.Column="3" x:Name="CorrelationBox" FontFamily="Consolas"/>

                <!-- Quick date-range chips — the most common forensic
                     questions ("what changed in the last hour / day /
                     week") shouldn't need two DatePicker clicks. Each
                     button sets From → now-N, To → now, then runs. -->
                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="Recent:" VerticalAlignment="Center"
                               Margin="0,0,6,0" Foreground="#B0B0B0"/>
                    <Button Content="1h"  Width="40" Margin="0,0,2,0"
                            Click="OnQuickRange1Hour"
                            ToolTip="Filter to audit rows from the last hour"/>
                    <Button Content="24h" Width="40" Margin="0,0,2,0"
                            Click="OnQuickRange1Day"
                            ToolTip="Filter to audit rows from the last 24 hours"/>
                    <Button Content="7d"  Width="40" Margin="0,0,2,0"
                            Click="OnQuickRange7Days"
                            ToolTip="Filter to audit rows from the last 7 days"/>
                    <Button Content="30d" Width="40" Margin="0,0,2,0"
                            Click="OnQuickRange30Days"
                            ToolTip="Filter to audit rows from the last 30 days"/>
                    <Button Content="All" Width="40"
                            Click="OnQuickRangeAll"
                            ToolTip="Clear From + To dates — widens to the full tenant-scope set (up to the 500 row cap)"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Result grid -->
        <dxg:GridControl Grid.Row="2" x:Name="AuditGrid"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         ShowBorder="False">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True"
                               ShowIndicator="False"
                               ShowGroupPanel="True"
                               AllowEditing="False"
                               RowDoubleClick="OnAuditRowDoubleClick"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="SequenceId"    Header="Seq"          Width="50"/>
                <dxg:GridColumn FieldName="CreatedAt"     Header="At"           Width="150"/>
                <dxg:GridColumn FieldName="EntityType"    Header="Entity"       Width="130"/>
                <dxg:GridColumn FieldName="EntityId"      Header="Entity ID"    Width="240"/>
                <dxg:GridColumn FieldName="Action"        Header="Action"       Width="140"/>
                <dxg:GridColumn FieldName="ActorDisplay"  Header="Actor"        Width="130"/>
                <dxg:GridColumn FieldName="CorrelationId" Header="Correlation"  Width="240"/>
                <dxg:GridColumn FieldName="DetailsText"   Header="Details"      Width="*"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>
    </Grid>
</UserControl>
