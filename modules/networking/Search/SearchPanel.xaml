<UserControl x:Class="Central.Module.Networking.Search.SearchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status bar (full width) -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Global search" FontWeight="SemiBold" Foreground="#D0D0D0"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="StatusLabel" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <!-- Saved-views sidebar (spans both rows 1+2) -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                BorderBrush="#333" BorderThickness="0,0,1,0" Background="#1C1C1C">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Saved views" FontWeight="SemiBold"
                           Foreground="#B0B0B0" Padding="8,6,8,4"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="6,0,6,4">
                    <Button x:Name="SaveViewButton" Content="Save current"
                            Width="90" Click="OnSaveView" Margin="0,0,4,0"
                            ToolTip="Save the current query + entity-type filter as a named view"/>
                    <Button x:Name="DeleteViewButton" Content="Delete"
                            Width="60" Click="OnDeleteView"
                            ToolTip="Delete the selected saved view"/>
                </StackPanel>
                <ListBox Grid.Row="2" x:Name="SavedViewsList"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#D0D0D0"
                         SelectionChanged="OnSavedViewSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SubtitleText}"
                                           Foreground="#888" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Column splitter -->
        <GridSplitter Grid.Row="1" Grid.RowSpan="2" Grid.Column="1"
                      Width="3" Background="#2A2A2A"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- Filter + query bar (right pane, row 1) -->
        <Grid Grid.Row="1" Grid.Column="2" Margin="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center"
                       Margin="0,0,4,0" Foreground="#B0B0B0"/>
            <TextBox Grid.Column="1" x:Name="QueryBox"
                     FontFamily="Consolas" FontSize="13"
                     KeyDown="OnQueryKeyDown"
                     ToolTip="Free text — tokenised + stemmed via plainto_tsquery('english')"/>

            <TextBlock Grid.Column="2" Text="Entity types:" VerticalAlignment="Center"
                       Margin="10,0,4,0" Foreground="#B0B0B0"/>
            <dxe:ComboBoxEdit Grid.Column="3" x:Name="EntityTypesCombo"
                              IsTextEditable="True"
                              NullText="(all — leave blank for everything)"
                              ToolTip="Comma-separated: Device,Vlan,Subnet,Server,Link,DhcpRelayTarget"/>

            <TextBlock Grid.Column="4" Text="Limit:" VerticalAlignment="Center"
                       Margin="10,0,4,0" Foreground="#B0B0B0"/>
            <dxe:SpinEdit Grid.Column="5" x:Name="LimitSpin"
                          MinValue="1" MaxValue="500" Value="50"
                          ToolTip="Engine-side clamp is 1-500; default 50"/>

            <Button Grid.Column="6" x:Name="SearchButton" Content="Search"
                    Width="90" Margin="8,0,4,0" Click="OnSearch"/>
            <Button Grid.Column="7" x:Name="ClearButton" Content="Clear"
                    Width="70" Click="OnClear"/>
        </Grid>

        <!-- Results grid (right pane, row 2) -->
        <dxg:GridControl Grid.Row="2" Grid.Column="2" x:Name="ResultsGrid"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         ShowBorder="False">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True"
                               ShowIndicator="False"
                               ShowGroupPanel="True"
                               AllowEditing="False"
                               RowDoubleClick="OnResultDoubleClick"/>
            </dxg:GridControl.View>
            <dxg:GridControl.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open in entity panel"
                              Click="OnContextOpenEntity"
                              ToolTip="Same as double-click — switch to the matching entity panel with selectId"/>
                    <MenuItem Header="Show audit history"
                              Click="OnContextShowAudit"
                              ToolTip="Open the Audit panel filtered to this entity's id"/>
                    <Separator/>
                    <MenuItem Header="Copy id"  Click="OnContextCopyId"/>
                </ContextMenu>
            </dxg:GridControl.ContextMenu>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="EntityType" Header="Entity" Width="120"/>
                <dxg:GridColumn FieldName="Label"      Header="Label"  Width="280"/>
                <dxg:GridColumn FieldName="Snippet"    Header="Snippet" Width="*"/>
                <dxg:GridColumn FieldName="Rank"       Header="Rank"   Width="90"/>
                <dxg:GridColumn FieldName="Id"         Header="Id"     Width="260"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>
    </Grid>
</UserControl>
