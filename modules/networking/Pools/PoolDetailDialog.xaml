<dx:DXWindow x:Class="Central.Module.Networking.Pools.PoolDetailDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             Title="Pool entity"
             Width="560" Height="620"
             WindowStartupLocation="CenterOwner"
             ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleLabel" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock x:Name="SubtitleLabel" FontSize="11" Foreground="#808080" Margin="0,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Parent picker (blocks only — which pool they sit under) -->
                <StackPanel x:Name="ParentSection" Visibility="Collapsed" Margin="0,0,0,8">
                    <TextBlock x:Name="ParentLabel" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit x:Name="ParentCombo" IsTextEditable="False"
                                      DisplayMember="DisplayText" ValueMember="Id"/>
                </StackPanel>

                <!-- Common: code + name -->
                <TextBlock Text="Code" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <dxe:TextEdit x:Name="CodeBox" Margin="0,0,0,8"/>

                <TextBlock Text="Display name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <dxe:TextEdit x:Name="NameBox" Margin="0,0,0,8"/>

                <!-- Status + Lock -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <dxe:ComboBoxEdit x:Name="StatusCombo" IsTextEditable="False"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Lock" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <dxe:ComboBoxEdit x:Name="LockCombo" IsTextEditable="False"/>
                    </StackPanel>
                </Grid>

                <!-- ASN (pool + block) -->
                <StackPanel x:Name="AsnSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First ASN" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="AsnFirstBox" MinValue="1" MaxValue="4294967294"
                                          IsFloatValue="False"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last ASN" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="AsnLastBox" MinValue="1" MaxValue="4294967294"
                                          IsFloatValue="False"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel x:Name="AsnKindSection" Visibility="Collapsed">
                        <TextBlock Text="Kind" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <dxe:ComboBoxEdit x:Name="AsnKindCombo" IsTextEditable="False" Margin="0,0,0,8"/>
                    </StackPanel>
                </StackPanel>

                <!-- IP pool -->
                <StackPanel x:Name="IpSection" Visibility="Collapsed">
                    <TextBlock Text="Network (CIDR)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:TextEdit x:Name="IpNetworkBox" Margin="0,0,0,8"/>
                    <TextBlock Text="Address family" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit x:Name="IpFamilyCombo" IsTextEditable="False" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- VLAN (pool + block) -->
                <StackPanel x:Name="VlanSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First VLAN" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="VlanFirstBox" MinValue="1" MaxValue="4094"
                                          IsFloatValue="False"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last VLAN" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="VlanLastBox" MinValue="1" MaxValue="4094"
                                          IsFloatValue="False"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- VLAN template -->
                <StackPanel x:Name="VlanTemplateSection" Visibility="Collapsed">
                    <TextBlock Text="Role" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit x:Name="VlanRoleCombo" IsTextEditable="True" Margin="0,0,0,8"/>
                    <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:TextEdit x:Name="VlanTemplateDescBox" Height="60" Margin="0,0,0,8"
                                  TextWrapping="Wrap" AcceptsReturn="True"
                                  VerticalContentAlignment="Top"/>
                    <CheckBox x:Name="VlanTemplateDefaultCheck"
                              Content="Default template (use when no template is chosen)"
                              Margin="0,0,0,8"/>
                </StackPanel>

                <!-- MLAG pool -->
                <StackPanel x:Name="MlagSection" Visibility="Collapsed">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First domain ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="MlagFirstBox" MinValue="1" MaxValue="4094"
                                          IsFloatValue="False"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Last domain ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <dxe:SpinEdit x:Name="MlagLastBox" MinValue="1" MaxValue="4094"
                                          IsFloatValue="False"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Block-only: scope -->
                <StackPanel x:Name="ScopeSection" Visibility="Collapsed">
                    <TextBlock Text="Scope level" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <dxe:ComboBoxEdit x:Name="ScopeLevelCombo" IsTextEditable="False" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Notes -->
                <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <dxe:TextEdit x:Name="NotesBox" Height="80"
                              TextWrapping="Wrap" AcceptsReturn="True"
                              VerticalContentAlignment="Top"/>

                <Border x:Name="MetaSection" BorderBrush="#333" BorderThickness="0,1,0,0"
                        Margin="0,12,0,0" Padding="0,8,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="MetaLabel" FontSize="11" Foreground="#808080"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="90" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button x:Name="SaveButton" Content="Save" Width="90" Click="Save_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</dx:DXWindow>
