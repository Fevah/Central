<UserControl x:Class="Central.Module.Networking.Servers.ServerGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: tenant + last-refresh -->
        <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Servers" FontWeight="SemiBold" Foreground="#D0D0D0"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="StatusLabel" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <dxg:GridControl x:Name="Grid" Grid.Row="1"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         ShowBorder="False">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True"
                               ShowIndicator="False"
                               ShowGroupPanel="True"
                               AllowEditing="False"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Hostname"     Header="Hostname"    Width="220"/>
                <dxg:GridColumn FieldName="BuildingCode" Header="Building"    Width="100"/>
                <dxg:GridColumn FieldName="ProfileCode"  Header="Profile"     Width="110"/>
                <dxg:GridColumn FieldName="Asn"          Header="ASN"         Width="80"/>
                <dxg:GridColumn FieldName="LoopbackIp"   Header="Loopback"    Width="130"/>
                <dxg:GridColumn FieldName="NicCount"     Header="NICs"        Width="60"/>
                <dxg:GridColumn FieldName="ManagementIp" Header="Mgmt IP"     Width="130"/>
                <dxg:GridColumn FieldName="LastPingOk"   Header="Ping"        Width="60"/>
                <dxg:GridColumn FieldName="LastPingMs"   Header="ms"          Width="60"/>
                <dxg:GridColumn FieldName="Status"       Header="Status"      Width="90"/>
                <dxg:GridColumn FieldName="Lock"         Header="Lock"        Width="70"/>
                <dxg:GridColumn FieldName="Version"      Header="v"           Width="40"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>
    </Grid>
</UserControl>
