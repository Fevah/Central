<dxc:DXWindow x:Class="Central.Module.Networking.Governance.DeleteDeviceItemDialog"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
              xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
              Title="Delete Device (Add Item)"
              Width="640" Height="480"
              WindowStartupLocation="CenterOwner"
              ResizeMode="CanResize"
              MinWidth="520" MinHeight="400">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderLabel"
                   FontWeight="SemiBold" Foreground="#D0D0D0"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11" Foreground="#909090"
                   Margin="0,0,0,10"
                   Text="Delete is a soft delete — the device's deleted_at column is set at apply time. The row stays in the database for audit and can be recovered via a Change Set rollback, but it's hidden from every active query."/>

        <TextBlock Grid.Row="2" Text="Filter" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="3" x:Name="FilterBox"
                   TextChanged="OnFilterChanged"
                   Margin="0,4,0,8"/>

        <dxg:GridControl Grid.Row="4" x:Name="DevicesGrid"
                         AutoGenerateColumns="None" SelectionMode="Row"
                         ShowBorder="True">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True" ShowIndicator="False"
                               AllowEditing="False"
                               RowDoubleClick="OnRowDoubleClick"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Hostname"     Header="Hostname"   Width="220"/>
                <dxg:GridColumn FieldName="RoleCode"     Header="Role"       Width="90"/>
                <dxg:GridColumn FieldName="BuildingCode" Header="Building"   Width="100"/>
                <dxg:GridColumn FieldName="Status"       Header="Status"     Width="80"/>
                <dxg:GridColumn FieldName="Version"      Header="v"          Width="40"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <TextBlock Grid.Row="5" Text="Notes (optional — why this rename?)"
                   Foreground="#B0B0B0" Margin="0,8,0,4"/>
        <TextBox   Grid.Row="6" x:Name="NotesBox"
                   Margin="0,0,0,8"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="ErrorLabel" Foreground="#E06464"
                       VerticalAlignment="Center" Margin="0,0,12,0"
                       Visibility="Collapsed"/>
            <Button Content="Cancel" Width="90" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"/>
            <Button x:Name="OkButton" Content="Add Delete Item" Width="140"
                    Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </Grid>
</dxc:DXWindow>
