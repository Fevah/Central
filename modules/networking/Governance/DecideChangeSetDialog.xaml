<dxc:DXWindow x:Class="Central.Module.Networking.Governance.DecideChangeSetDialog"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
              Title="Record Decision"
              Width="500" Height="320"
              WindowStartupLocation="CenterOwner"
              ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderLabel"
                   FontWeight="SemiBold" Foreground="#D0D0D0"
                   Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="ProgressLabel"
                   Foreground="#909090" FontSize="11"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="Decision" Margin="0,0,0,4" Foreground="#B0B0B0"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="ApproveRadio" Content="Approve" IsChecked="True"
                         GroupName="Decision" Margin="0,0,16,0"/>
            <RadioButton x:Name="RejectRadio"  Content="Reject"
                         GroupName="Decision"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Notes (optional)" Margin="0,0,0,4" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="5" x:Name="NotesBox"
                   AcceptsReturn="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="6" x:Name="ErrorLabel" Foreground="#E06464"
                   TextWrapping="Wrap" Margin="0,8,0,8"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"/>
            <Button x:Name="OkButton" Content="Record"  Width="100"
                    Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </Grid>
</dxc:DXWindow>
