<dxc:DXWindow x:Class="Central.Module.Networking.Governance.AddChangeSetItemDialog"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
              xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
              Title="Add Change Set Item"
              Width="640" Height="640"
              WindowStartupLocation="CenterOwner"
              ResizeMode="CanResize"
              MinWidth="500" MinHeight="500">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   x:Name="HeaderLabel"
                   FontWeight="SemiBold" Foreground="#D0D0D0"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Entity type" Foreground="#B0B0B0"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Text="Action" Foreground="#B0B0B0" Margin="8,0,0,0"/>
        <dxe:ComboBoxEdit Grid.Row="2" Grid.Column="0" x:Name="EntityTypeCombo"
                          IsTextEditable="False" Margin="0,4,0,8"
                          SelectedIndexChanged="OnEntityTypeChanged"/>
        <dxe:ComboBoxEdit Grid.Row="2" Grid.Column="1" x:Name="ActionCombo"
                          IsTextEditable="False" Margin="8,4,0,8"
                          SelectedIndexChanged="OnActionChanged"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                   x:Name="ActionHint" Foreground="#909090" FontSize="11"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Entity ID (UUID)" Foreground="#B0B0B0"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="Expected version (optional)" Foreground="#B0B0B0" Margin="8,0,0,0"/>
        <TextBox   Grid.Row="5" Grid.Column="0" x:Name="EntityIdBox"       Margin="0,4,0,8"/>
        <TextBox   Grid.Row="5" Grid.Column="1" x:Name="ExpectedVersionBox" Margin="8,4,0,8"/>

        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Text="Before JSON (optional — needed for Update/Rename rollback)"
                   Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="7" Grid.ColumnSpan="2" x:Name="BeforeJsonBox"
                   AcceptsReturn="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto"
                   Height="90" FontFamily="Cascadia Mono, Consolas"
                   Margin="0,4,0,8"/>

        <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Text="After JSON (required for Create/Update/Rename)"
                   Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="9" Grid.ColumnSpan="2" x:Name="AfterJsonBox"
                   AcceptsReturn="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto"
                   FontFamily="Cascadia Mono, Consolas"
                   Margin="0,4,0,8"/>

        <TextBlock Grid.Row="10" Grid.ColumnSpan="2" Text="Notes (optional)" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="11" Grid.ColumnSpan="2" x:Name="NotesBox" Margin="0,4,0,8"/>

        <TextBlock Grid.Row="12" Grid.Column="0" x:Name="ErrorLabel"
                   Foreground="#E06464" TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>
        <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"/>
            <Button x:Name="OkButton" Content="Add Item" Width="110"
                    Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </Grid>
</dxc:DXWindow>
