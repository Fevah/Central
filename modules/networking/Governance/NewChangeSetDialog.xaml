<dxc:DXWindow x:Class="Central.Module.Networking.Governance.NewChangeSetDialog"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
              Title="New Change Set"
              Width="520" Height="320"
              WindowStartupLocation="CenterOwner"
              ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Title (required)" Margin="0,0,0,4" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="1" x:Name="TitleBox"
                   MaxLength="128"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="Description (optional)" Margin="0,0,0,4"
                   VerticalAlignment="Top" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="2" x:Name="DescriptionBox"
                   Margin="0,20,0,10"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto"
                   Height="120" VerticalAlignment="Top"/>

        <TextBlock Grid.Row="3" x:Name="ErrorLabel" Foreground="#E06464"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"/>
            <Button x:Name="OkButton" Content="Create Draft" Width="120"
                    Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </Grid>
</dxc:DXWindow>
