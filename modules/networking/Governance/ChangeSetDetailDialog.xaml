<dxc:DXWindow x:Class="Central.Module.Networking.Governance.ChangeSetDetailDialog"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
              xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
              xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
              Title="Change Set Detail"
              Width="900" Height="640"
              WindowStartupLocation="CenterOwner"
              ResizeMode="CanResize"
              MinWidth="640" MinHeight="480">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title + status + id for copy-paste -->
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock x:Name="TitleLabel" FontWeight="SemiBold" FontSize="15"
                       Foreground="#D0D0D0"/>
            <TextBlock x:Name="SubtitleLabel" Foreground="#909090" FontSize="11"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Lifecycle band: status pills + key timestamps -->
        <Border Grid.Row="1" BorderBrush="#333" BorderThickness="0,0,0,1"
                Padding="0,8" Margin="0,8,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LifecycleLabel" Foreground="#B0B0B0"
                           FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Two tabs: Items (from GetChangeSet) + Audit (by correlationId) -->
        <TabControl Grid.Row="2">
            <TabItem Header="Items">
                <dxg:GridControl x:Name="ItemsGrid"
                                 AutoGenerateColumns="None"
                                 SelectionMode="Row"
                                 ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView AutoWidth="True"
                                       ShowIndicator="False"
                                       AllowEditing="False"/>
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="ItemOrder"        Header="#"           Width="40"/>
                        <dxg:GridColumn FieldName="EntityType"       Header="Entity"      Width="110"/>
                        <dxg:GridColumn FieldName="Action"           Header="Action"      Width="80"/>
                        <dxg:GridColumn FieldName="EntityId"         Header="Entity ID"   Width="180"/>
                        <dxg:GridColumn FieldName="ExpectedVersion"  Header="v"           Width="40"/>
                        <dxg:GridColumn FieldName="AppliedAt"        Header="Applied At"  Width="140"/>
                        <dxg:GridColumn FieldName="ApplyError"       Header="Error"       Width="*"/>
                        <dxg:GridColumn FieldName="Notes"            Header="Notes"       Width="140"/>
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </TabItem>

            <TabItem Header="Approvals">
                <dxg:GridControl x:Name="ApprovalsGrid"
                                 AutoGenerateColumns="None"
                                 SelectionMode="Row"
                                 ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView AutoWidth="True"
                                       ShowIndicator="False"
                                       AllowEditing="False"/>
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="DecidedAt"        Header="When"       Width="150"/>
                        <dxg:GridColumn FieldName="ApproverDisplay"  Header="Approver"   Width="160"/>
                        <dxg:GridColumn FieldName="ApproverUserId"   Header="User ID"    Width="70"/>
                        <dxg:GridColumn FieldName="Decision"         Header="Decision"   Width="90"/>
                        <dxg:GridColumn FieldName="Notes"            Header="Notes"      Width="*"/>
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </TabItem>

            <TabItem Header="Audit Timeline">
                <dxg:GridControl x:Name="AuditGrid"
                                 AutoGenerateColumns="None"
                                 SelectionMode="Row"
                                 ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView AutoWidth="True"
                                       ShowIndicator="False"
                                       AllowEditing="False"/>
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="SequenceId"    Header="Seq"         Width="50"/>
                        <dxg:GridColumn FieldName="CreatedAt"     Header="At"          Width="150"/>
                        <dxg:GridColumn FieldName="EntityType"    Header="Entity"      Width="110"/>
                        <dxg:GridColumn FieldName="EntityId"      Header="Entity ID"   Width="180"/>
                        <dxg:GridColumn FieldName="Action"        Header="Action"      Width="130"/>
                        <dxg:GridColumn FieldName="ActorDisplay"  Header="Actor"       Width="130"/>
                        <dxg:GridColumn FieldName="DetailsText"   Header="Details"     Width="*"/>
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3" x:Name="StatusLabel" Foreground="#909090"
                   FontSize="11" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="RefreshButton" Content="Refresh" Width="90" Margin="0,0,8,0"
                    Click="OnRefresh"/>
            <Button Content="Close" Width="90" Click="OnClose" IsDefault="True"/>
        </StackPanel>
    </Grid>
</dxc:DXWindow>
