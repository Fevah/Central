<dxc:DXWindow x:Class="Central.Module.Networking.Governance.UpdateDeviceItemDialog"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
              xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
              Title="Update Device (Add Item)"
              Width="720" Height="620"
              WindowStartupLocation="CenterOwner"
              ResizeMode="CanResize"
              MinWidth="560" MinHeight="500">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderLabel"
                   FontWeight="SemiBold" Foreground="#D0D0D0"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11" Foreground="#909090"
                   Margin="0,0,0,10"
                   Text="Picks the three most-edited fields (display name, management IP, notes). Other fields go through the generic Add Item dialog. Omitted fields keep their current value — COALESCE semantics on the engine side."/>

        <TextBlock Grid.Row="2" Text="Filter" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="3" x:Name="FilterBox"
                   TextChanged="OnFilterChanged"
                   Margin="0,4,0,8"/>

        <dxg:GridControl Grid.Row="4" x:Name="DevicesGrid"
                         AutoGenerateColumns="None" SelectionMode="Row"
                         ShowBorder="True">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True" ShowIndicator="False"
                               AllowEditing="False"
                               FocusedRowChanged="OnFocusedRowChanged"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Hostname"     Header="Hostname"   Width="220"/>
                <dxg:GridColumn FieldName="RoleCode"     Header="Role"       Width="90"/>
                <dxg:GridColumn FieldName="BuildingCode" Header="Building"   Width="100"/>
                <dxg:GridColumn FieldName="Status"       Header="Status"     Width="80"/>
                <dxg:GridColumn FieldName="Version"      Header="v"          Width="40"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <TextBlock Grid.Row="5" Text="Display name" Foreground="#B0B0B0" Margin="0,8,0,4"/>
        <TextBox   Grid.Row="6" x:Name="DisplayNameBox" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="7" Text="Management IP (e.g. 10.11.152.2)" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="8" x:Name="ManagementIpBox" Margin="0,4,0,8"/>

        <TextBlock Grid.Row="9" Text="Notes" Foreground="#B0B0B0"/>
        <TextBox   Grid.Row="10" x:Name="NotesBox" Margin="0,4,0,8"/>

        <TextBlock Grid.Row="11" x:Name="ErrorLabel" Foreground="#E06464"
                   TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"/>
            <Button x:Name="OkButton" Content="Add Update Item" Width="140"
                    Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </Grid>
</dxc:DXWindow>
