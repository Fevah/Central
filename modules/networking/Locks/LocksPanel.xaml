<UserControl x:Class="Central.Module.Networking.Locks.LocksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Locks" FontWeight="SemiBold" Foreground="#D0D0D0"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="StatusLabel" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <dxg:GridControl Grid.Row="1" x:Name="Grid"
                         AutoGenerateColumns="None"
                         SelectionMode="Row"
                         ShowBorder="False">
            <dxg:GridControl.View>
                <dxg:TableView AutoWidth="True"
                               ShowIndicator="False"
                               ShowGroupPanel="True"
                               AllowEditing="False"
                               RowDoubleClick="OnRowDoubleClick"/>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="LockState"    Header="State"      Width="90"/>
                <dxg:GridColumn FieldName="TableName"    Header="Table"      Width="130"/>
                <dxg:GridColumn FieldName="DisplayLabel" Header="Identifier" Width="240"/>
                <dxg:GridColumn FieldName="Id"           Header="Row ID"     Width="240"/>
                <dxg:GridColumn FieldName="LockReason"   Header="Reason"     Width="*"/>
                <dxg:GridColumn FieldName="LockedBy"     Header="By"         Width="60"/>
                <dxg:GridColumn FieldName="LockedAt"     Header="At"         Width="150"/>
                <dxg:GridColumn FieldName="Version"      Header="v"          Width="40"/>
            </dxg:GridControl.Columns>
            <dxg:GridControl.ContextMenu>
                <ContextMenu x:Name="RowContextMenu">
                    <MenuItem Header="Change State…"  Click="CtxChangeState"/>
                    <MenuItem Header="Clear Lock (Open)" Click="CtxClearLock"/>
                    <Separator/>
                    <MenuItem Header="Refresh"        Click="CtxRefresh"/>
                </ContextMenu>
            </dxg:GridControl.ContextMenu>
        </dxg:GridControl>
    </Grid>
</UserControl>
