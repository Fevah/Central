<UserControl x:Class="Central.Module.Networking.Validation.ValidationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Validation" FontWeight="SemiBold" Foreground="#D0D0D0"/>
                <TextBlock Text=" · " Foreground="#707070"/>
                <TextBlock x:Name="StatusLabel" Foreground="#909090"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <!-- Tab 1: Rule catalog + per-tenant state -->
            <TabItem Header="Rules">
                <dxg:GridControl x:Name="RulesGrid"
                                 AutoGenerateColumns="None"
                                 SelectionMode="Row"
                                 ShowBorder="False">
                    <dxg:GridControl.View>
                        <dxg:TableView AutoWidth="True"
                                       ShowIndicator="False"
                                       ShowGroupPanel="True"
                                       AllowEditing="False"
                                       RowDoubleClick="OnRuleDoubleClick"/>
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Code"                Header="Code"         Width="260"/>
                        <dxg:GridColumn FieldName="Category"            Header="Category"     Width="100"/>
                        <dxg:GridColumn FieldName="EffectiveSeverity"   Header="Severity"     Width="80"/>
                        <dxg:GridColumn FieldName="EffectiveEnabled"    Header="Enabled"      Width="70"/>
                        <dxg:GridColumn FieldName="HasTenantOverride"   Header="Override"     Width="70"/>
                        <dxg:GridColumn FieldName="Name"                Header="Name"         Width="*"/>
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </TabItem>

            <!-- Tab 2: Violations from the most recent run -->
            <TabItem Header="Violations">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="8,4">
                        <TextBlock x:Name="RunSummaryLabel" Foreground="#909090"
                                   Text="Click 'Run All' in the Validation ribbon group to populate."/>
                    </Border>
                    <dxg:GridControl Grid.Row="1" x:Name="ViolationsGrid"
                                     AutoGenerateColumns="None"
                                     SelectionMode="Row"
                                     ShowBorder="False">
                        <dxg:GridControl.View>
                            <dxg:TableView AutoWidth="True"
                                           ShowIndicator="False"
                                           ShowGroupPanel="True"
                                           AllowEditing="False"/>
                        </dxg:GridControl.View>
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn FieldName="Severity"   Header="Severity"    Width="80"/>
                            <dxg:GridColumn FieldName="RuleCode"   Header="Rule"        Width="260"/>
                            <dxg:GridColumn FieldName="EntityType" Header="Entity"      Width="110"/>
                            <dxg:GridColumn FieldName="EntityId"   Header="Entity ID"   Width="220"/>
                            <dxg:GridColumn FieldName="Message"    Header="Message"     Width="*"/>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
