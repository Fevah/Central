<UserControl x:Class="Central.Module.Admin.Views.ApiKeysPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Generate Key" Click="Generate_Click" Padding="12,4" Margin="0,0,4,0" FontWeight="SemiBold" />
            <Button Content="Revoke" Click="Revoke_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Delete" Click="Delete_Click" Padding="12,4" Margin="0,0,4,0" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="12,4" Margin="0,0,16,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#9CA3AF" FontSize="11" />
        </StackPanel>

        <dxg:GridControl x:Name="KeysGrid" Grid.Row="1" AutoGenerateColumns="None" SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="KeysView" AllowEditing="False" NavigationStyle="Row"
                               ShowAutoFilterRow="True" ShowTotalSummary="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Id" Header="ID" Width="50" />
                <dxg:GridColumn FieldName="Name" Header="Name" Width="200" />
                <dxg:GridColumn FieldName="Role" Header="Role" Width="100" />
                <dxg:GridColumn FieldName="IsActive" Header="Active" Width="65" />
                <dxg:GridColumn FieldName="UseCount" Header="Uses" Width="60" />
                <dxg:GridColumn FieldName="LastUsedAt" Header="Last Used" Width="140" />
                <dxg:GridColumn FieldName="CreatedAt" Header="Created" Width="140" />
                <dxg:GridColumn FieldName="ExpiresAt" Header="Expires" Width="140" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Name" DisplayFormat="{}Keys: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
