<UserControl x:Class="Central.Module.Admin.Views.ReferenceConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Core.Converters;assembly=Central.Core">

    <UserControl.Resources>
        <conv:NullToBoolConverter x:Key="NullToBool" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Add" Click="Add_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Save" Click="Save_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#AAA" />
        </StackPanel>

        <!-- Reference Config Grid -->
        <dxg:GridControl x:Name="RefConfigGrid" Grid.Row="1"
                         AutoGenerateColumns="None"
                         SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="RefConfigView"
                               AllowEditing="True" NavigationStyle="Cell"
                               ShowGroupPanel="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               ShowTotalSummary="True"
                               CellValueChanged="RefConfigView_CellValueChanged"
                               ValidateRow="RefConfigView_ValidateRow"
                               InvalidRowException="View_InvalidRowException" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="EntityType"   Header="Entity Type"  Width="120" />
                <dxg:GridColumn FieldName="Prefix"       Header="Prefix"       Width="80" />
                <dxg:GridColumn FieldName="Suffix"       Header="Suffix"       Width="80" />
                <dxg:GridColumn FieldName="PadLength"    Header="Pad Length"   Width="80">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="1" MaxValue="20" IsFloatValue="False" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="NextValue"    Header="Next Value"   Width="100">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="1" IsFloatValue="False" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SampleOutput" Header="Sample"       Width="160" ReadOnly="True" />
                <dxg:GridColumn FieldName="Description"  Header="Description"  Width="250" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="EntityType" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
