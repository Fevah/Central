<UserControl x:Class="Central.Module.Admin.Views.MigrationsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Core.Converters;assembly=Central.Core">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Apply Pending" Click="ApplyPending_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#AAA" />
        </StackPanel>

        <!-- Migrations Grid -->
        <dxg:GridControl x:Name="MigrationsGrid" Grid.Row="1"
                         AutoGenerateColumns="None"
                         SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="MigrationsView"
                               ShowGroupPanel="False"
                               AllowColumnFiltering="True"
                               NavigationStyle="Row"
                               AllowEditing="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               ShowTotalSummary="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="MigrationName" Header="Migration"   Width="250" SortIndex="0" SortOrder="Ascending" />
                <dxg:GridColumn FieldName="StatusText"    Header="Status"      Width="90">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.StatusText}"
                                       Foreground="{Binding RowData.Row.StatusColor, Converter={StaticResource StringToBrush}}"
                                       FontWeight="SemiBold" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="AppliedAt"     Header="Applied At"  Width="160" />
                <dxg:GridColumn FieldName="DurationMs"    Header="Duration (ms)" Width="100" />
                <dxg:GridColumn FieldName="AppliedBy"     Header="Applied By"  Width="100" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="MigrationName" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
