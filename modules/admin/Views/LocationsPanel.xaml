<UserControl x:Class="Central.Module.Admin.Views.LocationsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">

    <UserControl.Resources>
        <conv:NullToBoolConverter x:Key="NullToBool" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Add Country" Click="AddCountry_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Add Region" Click="AddRegion_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Delete" Click="Delete_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Save" Click="Save_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#AAA" />
        </StackPanel>

        <!-- Countries Grid -->
        <DockPanel Grid.Row="1">
            <TextBlock DockPanel.Dock="Top" Text="Countries" FontWeight="SemiBold" Margin="4,2" />
            <dxg:GridControl x:Name="CountriesGrid" AutoGenerateColumns="None"
                             SelectionMode="Row"
                             CurrentItemChanged="CountriesGrid_CurrentItemChanged">
                <dxg:GridControl.View>
                    <dxg:TableView x:Name="CountriesView"
                                   AllowEditing="True" NavigationStyle="Cell"
                                   ShowGroupPanel="False"
                                   ShowAutoFilterRow="True"
                                   UseEvenRowBackground="True"
                                   ShowTotalSummary="True"
                                   ValidateRow="CountriesView_ValidateRow"
                                   InvalidRowException="View_InvalidRowException" />
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn FieldName="Code"      Header="Code"       Width="80" />
                    <dxg:GridColumn FieldName="Name"      Header="Name"       Width="200" />
                    <dxg:GridColumn FieldName="SortOrder" Header="Sort Order" Width="80" />
                </dxg:GridControl.Columns>
                <dxg:GridControl.TotalSummary>
                    <dxg:GridSummaryItem SummaryType="Count" FieldName="Code" DisplayFormat="{}Total: {0}" />
                </dxg:GridControl.TotalSummary>
            </dxg:GridControl>
        </DockPanel>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Height="5" />

        <!-- Regions Grid (filtered by selected country) -->
        <DockPanel Grid.Row="3">
            <TextBlock x:Name="RegionsLabel" DockPanel.Dock="Top" Text="Regions" FontWeight="SemiBold" Margin="4,2" />
            <dxg:GridControl x:Name="RegionsGrid" AutoGenerateColumns="None"
                             SelectionMode="Row">
                <dxg:GridControl.View>
                    <dxg:TableView x:Name="RegionsView"
                                   AllowEditing="True" NavigationStyle="Cell"
                                   ShowGroupPanel="False"
                                   ShowAutoFilterRow="True"
                                   UseEvenRowBackground="True"
                                   ShowTotalSummary="True"
                                   ValidateRow="RegionsView_ValidateRow"
                                   InvalidRowException="View_InvalidRowException" />
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn FieldName="CountryName" Header="Country"    Width="120" ReadOnly="True" />
                    <dxg:GridColumn FieldName="Code"        Header="Code"       Width="80" />
                    <dxg:GridColumn FieldName="Name"        Header="Name"       Width="200" />
                    <dxg:GridColumn FieldName="SortOrder"   Header="Sort Order" Width="80" />
                </dxg:GridControl.Columns>
                <dxg:GridControl.TotalSummary>
                    <dxg:GridSummaryItem SummaryType="Count" FieldName="Code" DisplayFormat="{}Total: {0}" />
                </dxg:GridControl.TotalSummary>
            </dxg:GridControl>
        </DockPanel>
    </Grid>
</UserControl>
