<UserControl x:Class="Central.Module.Admin.Views.PodmanPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Refresh" Click="Refresh_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Start" Click="Start_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Stop" Click="Stop_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Restart" Click="Restart_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="View Logs" Click="ViewLogs_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#AAA" />
        </StackPanel>

        <!-- Containers Grid -->
        <dxg:GridControl x:Name="ContainersGrid" Grid.Row="1"
                         AutoGenerateColumns="None"
                         SelectionMode="Row">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="ContainersView"
                               ShowGroupPanel="False"
                               AllowColumnFiltering="True"
                               NavigationStyle="Row"
                               AllowEditing="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               ShowTotalSummary="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Name"    Header="Name"    Width="180" />
                <dxg:GridColumn FieldName="Image"   Header="Image"   Width="250" />
                <dxg:GridColumn FieldName="State"   Header="State"   Width="80">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.State}"
                                       Foreground="{Binding RowData.Row.StateColor, Converter={StaticResource StringToBrush}}"
                                       FontWeight="SemiBold" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Status"  Header="Status"  Width="160" />
                <dxg:GridColumn FieldName="Created" Header="Created" Width="150" />
                <dxg:GridColumn FieldName="Ports"   Header="Ports"   Width="200" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="Name" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Height="5" Background="#333" />

        <!-- Log Output -->
        <DockPanel Grid.Row="3">
            <TextBlock DockPanel.Dock="Top" Text="Container Logs" FontWeight="SemiBold" Margin="4,2" />
            <TextBox x:Name="LogOutput"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"
                     Background="#1E1E1E" Foreground="#CCC"
                     TextWrapping="Wrap"
                     AcceptsReturn="True" />
        </DockPanel>
    </Grid>
</UserControl>
