<dx:DXWindow x:Class="Central.Module.Admin.Views.GridCustomizerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine"
             Title="Grid Settings"
             Width="400" Height="340"
             WindowStartupLocation="CenterOwner"
             ShowIcon="False">

    <dx:DXWindow.Resources>
        <conv:NullToBoolConverter x:Key="NullToBool" />
    </dx:DXWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Row Height -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Row Height:" VerticalAlignment="Center" Margin="0,0,8,8" />
        <dxe:SpinEdit x:Name="RowHeightSpin" Grid.Row="0" Grid.Column="1"
                       MinValue="10" MaxValue="60" IsFloatValue="False"
                       Value="25" Margin="0,0,0,8" />

        <!-- Alternating Rows -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Alternating Rows:" VerticalAlignment="Center" Margin="0,0,8,8" />
        <CheckBox x:Name="AlternatingRowsCheck" Grid.Row="1" Grid.Column="1"
                  IsChecked="True" VerticalAlignment="Center" Margin="0,0,0,8" />

        <!-- Summary Footer -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Summary Footer:" VerticalAlignment="Center" Margin="0,0,8,8" />
        <CheckBox x:Name="SummaryFooterCheck" Grid.Row="2" Grid.Column="1"
                  IsChecked="True" VerticalAlignment="Center" Margin="0,0,0,8" />

        <!-- Group Panel -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Group Panel:" VerticalAlignment="Center" Margin="0,0,8,8" />
        <CheckBox x:Name="GroupPanelCheck" Grid.Row="3" Grid.Column="1"
                  IsChecked="False" VerticalAlignment="Center" Margin="0,0,0,8" />

        <!-- Auto-Filter Row -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Auto-Filter Row:" VerticalAlignment="Center" Margin="0,0,8,8" />
        <CheckBox x:Name="AutoFilterRowCheck" Grid.Row="4" Grid.Column="1"
                  IsChecked="True" VerticalAlignment="Center" Margin="0,0,0,8" />

        <!-- Spacer -->
        <Border Grid.Row="5" Grid.ColumnSpan="2" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Click="OK_Click" Width="80" Padding="8,4" Margin="0,0,8,0" IsDefault="True" />
            <Button Content="Cancel" Click="Cancel_Click" Width="80" Padding="8,4" IsCancel="True" />
        </StackPanel>
    </Grid>
</dx:DXWindow>
