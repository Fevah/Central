<UserControl x:Class="Central.Module.Admin.Views.RibbonTreePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToCollapsed" NullValue="Collapsed" NotNullValue="Visible"
            xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" NullValue="Visible" NotNullValue="Collapsed"
            xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="+ Page" Click="AddPage_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="+ Group" Click="AddGroup_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="+ Separator" Click="AddSeparator_Click" Margin="0,0,4,0" Padding="8,2" />
            <Button Content="▲" Click="MoveUp_Click" Margin="0,0,2,0" Padding="8,2" ToolTip="Move Up" />
            <Button Content="▼" Click="MoveDown_Click" Margin="0,0,4,0" Padding="8,2" ToolTip="Move Down" />
            <Button Content="👁" Click="ToggleHidden_Click" Margin="0,0,4,0" Padding="8,2" ToolTip="Toggle Hidden" />
            <Button Content="🖼" Click="SetIcon_Click" Margin="0,0,4,0" Padding="8,2" ToolTip="Set Icon" />
            <Button Content="Reset All" Click="ResetAll_Click" Margin="0,0,8,0" Padding="8,2" />
            <Button Content="Apply Changes" Click="Apply_Click" Padding="12,2"
                    FontWeight="SemiBold" />
        </StackPanel>

        <!-- Tree -->
        <dxg:TreeListControl x:Name="RibbonTree" Grid.Row="1"
                              AutoGenerateColumns="None"
                              EnableSmartColumnsGeneration="False">
            <dxg:TreeListControl.View>
                <dxg:TreeListView x:Name="RibbonTreeView"
                                   KeyFieldName="Id" ParentFieldName="ParentId"
                                   AllowEditing="True" NavigationStyle="Cell"
                                   ShowIndicator="True" ShowNodeImages="False"
                                   AutoExpandAllNodes="True"
                                   RowDoubleClick="RibbonTreeView_RowDoubleClick"
                                   AllowDragDrop="True" />
            </dxg:TreeListControl.View>
            <dxg:TreeListControl.Columns>
                <dxg:TreeListColumn FieldName="NodeIcon" Header="" Width="30" AllowEditing="False">
                    <dxg:TreeListColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Image Width="16" Height="16" Source="{Binding RowData.Row.IconPreview}"
                                       Visibility="{Binding RowData.Row.IconPreview, Converter={StaticResource NullToCollapsed}}" />
                                <TextBlock Text="{Binding RowData.Row.NodeIcon}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding RowData.Row.IconPreview, Converter={StaticResource NullToVisible}}" />
                            </Grid>
                        </DataTemplate>
                    </dxg:TreeListColumn.CellTemplate>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="DisplayText" Header="Item" Width="200" AllowEditing="False" />
                <dxg:TreeListColumn FieldName="CustomText" Header="Custom Name" Width="150" />
                <dxg:TreeListColumn FieldName="IconName" Header="Icon" Width="160">
                    <dxg:TreeListColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Width="16" Height="16" Margin="0,0,4,0"
                                       Source="{Binding RowData.Row.IconPreview}" />
                                <TextBlock Text="{Binding RowData.Row.IconName}" VerticalAlignment="Center"
                                           FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </dxg:TreeListColumn.CellTemplate>
                    <dxg:TreeListColumn.EditSettings>
                        <dxe:ButtonEditSettings AllowDefaultButton="False">
                            <dxe:ButtonEditSettings.Buttons>
                                <dxe:ButtonInfo GlyphKind="Search" Click="TreeIconPicker_Click" />
                            </dxe:ButtonEditSettings.Buttons>
                        </dxe:ButtonEditSettings>
                    </dxg:TreeListColumn.EditSettings>
                </dxg:TreeListColumn>
                <dxg:TreeListColumn FieldName="IsHidden" Header="Hidden" Width="60" />
                <dxg:TreeListColumn FieldName="NodeType" Header="Type" Width="70" AllowEditing="False" />
                <dxg:TreeListColumn FieldName="Permission" Header="Permission" Width="120" AllowEditing="False" />
                <dxg:TreeListColumn FieldName="SortOrder" Header="Order" Width="50" />
            </dxg:TreeListControl.Columns>
        </dxg:TreeListControl>
    </Grid>
</UserControl>
