<UserControl x:Class="Central.Module.Admin.Views.RolesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Roles list -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Roles" FontWeight="SemiBold" FontSize="14"
                       Margin="8,8,8,4" Foreground="#E0E0E0" />
            <dxg:GridControl x:Name="RolesGrid"
                             ItemsSource="{Binding Roles}"
                             CurrentItem="{Binding SelectedRole, Mode=TwoWay}"
                             AutoGenerateColumns="None">
                <dxg:GridControl.View>
                    <dxg:TableView x:Name="RolesView"
                                   ShowGroupPanel="False"
                                   ShowColumnHeaders="True"
                                   AllowColumnFiltering="False"
                                   NavigationStyle="Row"
                                   AllowEditing="True"
                                   NewItemRowPosition="Top"
                                   UseEvenRowBackground="True"
                                   ShowTotalSummary="False"
                                   ShowAutoFilterRow="True"
                                   SearchPanelNullText="Search..." />
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn FieldName="Name"        Header="Role Name"   Width="120" Fixed="Left" />
                    <dxg:GridColumn FieldName="Description" Header="Description"  Width="*" />
                    <dxg:GridColumn FieldName="Priority"    Header="Priority"     Width="65" />
                    <dxg:GridColumn FieldName="IsSystem"    Header="System"       Width="60" ReadOnly="True" />
                </dxg:GridControl.Columns>
                <dxg:GridControl.TotalSummary>
                    <dxg:GridSummaryItem SummaryType="Count" FieldName="Name" DisplayFormat="{}Total: {0}" />
                </dxg:GridControl.TotalSummary>
                <dxg:GridControl.DetailDescriptor>
                    <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailUsers">
                        <dxg:GridControl AutoGenerateColumns="None">
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False" ShowColumnHeaders="True"
                                               AllowEditing="False" NavigationStyle="Row" ShowTotalSummary="True" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="Username"    Header="Username"    Width="150" />
                                <dxg:GridColumn FieldName="DisplayName" Header="Display Name" Width="200" />
                                <dxg:GridColumn FieldName="IsActive"    Header="Active"      Width="60" />
                                <dxg:GridColumn FieldName="LastLogin"   Header="Last Login"  Width="140" />
                            </dxg:GridControl.Columns>
                            <dxg:GridControl.TotalSummary>
                                <dxg:GridSummaryItem SummaryType="Count" FieldName="Username" DisplayFormat="{}Users: {0}" />
                            </dxg:GridControl.TotalSummary>
                        </dxg:GridControl>
                    </dxg:DataControlDetailDescriptor>
                </dxg:GridControl.DetailDescriptor>
            </dxg:GridControl>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="#555" />

        <!-- Right: Permissions TreeList for selected role -->
        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="14"
                       Margin="8,8,8,4" Foreground="#E0E0E0">
                <Run Text="Permissions — " /><Run Text="{Binding SelectedRole.Name, FallbackValue='(select a role)'}" />
            </TextBlock>

            <!-- Permissions TreeList -->
            <dxg:TreeListControl x:Name="PermissionsTree"
                                 DockPanel.Dock="Top" Height="280"
                                 AutoGenerateColumns="None">
                <dxg:TreeListControl.View>
                    <dxg:TreeListView x:Name="PermissionsTreeView"
                                      KeyFieldName="Key"
                                      ParentFieldName="ParentKey"
                                      ShowColumnHeaders="True"
                                      ShowIndicator="False"
                                      AutoExpandAllNodes="True"
                                      AllowEditing="True"
                                      NavigationStyle="Cell"
                                      ShowHorizontalLines="False"
                                      CellValueChanged="PermissionsTree_CellValueChanged" />
                </dxg:TreeListControl.View>
                <dxg:TreeListControl.Columns>
                    <dxg:TreeListColumn FieldName="DisplayName" Header="Module / Permission"
                                        Width="200" ReadOnly="True" />
                    <dxg:TreeListColumn FieldName="IsEnabled" Header="Enabled" Width="80">
                        <dxg:TreeListColumn.EditSettings>
                            <dxe:CheckEditSettings />
                        </dxg:TreeListColumn.EditSettings>
                    </dxg:TreeListColumn>
                </dxg:TreeListControl.Columns>
            </dxg:TreeListControl>

            <!-- Sites Access below permissions -->
            <TextBlock DockPanel.Dock="Top" Text="Site Access" FontWeight="SemiBold" FontSize="14"
                       Foreground="#E0E0E0" Margin="8,12,8,6" />
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,0,8,8">
                <ItemsControl ItemsSource="{Binding RoleSites}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Building}" IsChecked="{Binding Allowed}"
                                      Margin="20,2" Foreground="#E0E0E0"
                                      Checked="SiteAccessChanged" Unchecked="SiteAccessChanged" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
