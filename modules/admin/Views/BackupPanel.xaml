<UserControl x:Class="Central.Module.Admin.Views.BackupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <Button Content="Full Backup" Click="RunBackup_Click" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Refresh" Click="Refresh_Click" Padding="8,4" Margin="0,0,8,0" />
            <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#AAA" />
        </StackPanel>

        <!-- Output path -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4">
            <TextBlock Text="Output Path:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <dxe:TextEdit x:Name="OutputPathEdit" Width="400" Margin="0,0,8,0"
                          NullText="Select backup output path..." />
            <Button Content="Browse..." Click="Browse_Click" Padding="8,4" />
        </StackPanel>

        <!-- Backup History Grid -->
        <dxg:GridControl x:Name="BackupGrid" Grid.Row="2"
                         AutoGenerateColumns="None"
                         SelectionMode="Row" Margin="0,4,0,0">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="BackupView"
                               ShowGroupPanel="False"
                               AllowColumnFiltering="True"
                               NavigationStyle="Row"
                               AllowEditing="False"
                               ShowAutoFilterRow="True"
                               UseEvenRowBackground="True"
                               ShowTotalSummary="True" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="BackupType"      Header="Type"        Width="80" />
                <dxg:GridColumn FieldName="FilePath"        Header="File Path"   Width="300" />
                <dxg:GridColumn FieldName="FileSizeDisplay" Header="Size"        Width="80" />
                <dxg:GridColumn FieldName="StartedAt"       Header="Started"     Width="150" SortIndex="0" SortOrder="Descending" />
                <dxg:GridColumn FieldName="CompletedAt"     Header="Completed"   Width="150" />
                <dxg:GridColumn FieldName="Status"          Header="Status"      Width="80">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.Status}"
                                       Foreground="{Binding RowData.Row.StatusColor, Converter={StaticResource StringToBrush}}"
                                       FontWeight="SemiBold" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="ErrorMessage"    Header="Error"       Width="200" />
                <dxg:GridColumn FieldName="TriggeredBy"     Header="Triggered By" Width="100" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="BackupType" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
