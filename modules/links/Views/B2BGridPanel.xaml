<UserControl x:Class="Central.Module.Links.Views.B2BGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <UserControl.Resources>
        <ResourceDictionary>
            <conv:StringToBrushConverter x:Key="StringToBrush"
                xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine" />
        </ResourceDictionary>
    </UserControl.Resources>

    <dxg:GridControl x:Name="B2BGrid" ItemsSource="{Binding B2BLinks}" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="B2BView" ShowGroupPanel="True" AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways" NavigationStyle="Cell"
                           AllowEditing="True" ShowAutoFilterRow="True" SearchPanelNullText="Search..."
                           ShowTotalSummary="False" UseEvenRowBackground="True"
                           ValidateRow="B2BView_ValidateRow"
                           CellValueChanged="B2BView_CellValueChanged">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                                <Setter Property="Foreground" Value="#808080" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="ValidationIcon" Header="" Width="30" AllowEditing="False"
                            AllowColumnFiltering="False" HorizontalHeaderContentAlignment="Center">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding RowData.Row.ValidationIcon}"
                                   Foreground="{Binding RowData.Row.ValidationColor, Converter={StaticResource StringToBrush}}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   ToolTip="{Binding RowData.Row.ValidationTooltip}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="LinkId"     Header="Link ID"     Width="80" Fixed="Left" />
            <dxg:GridColumn FieldName="Vlan"       Header="VLAN"        Width="70" />
            <!-- A side -->
            <dxg:GridColumn FieldName="BuildingA"  Header="Building A"  Width="100" AllowGrouping="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="B2BBuildingACombo" IsTextEditable="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="DeviceA"    Header="Device A"    Width="160">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="PortA"      Header="Port A"      Width="120">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True"
                                              AutoComplete="True"
                                              ValueMember="InterfaceName"
                                              DisplayMember="InterfaceName" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="ModuleA"    Header="Module A"    Width="80" />
            <dxg:GridColumn FieldName="DeviceAIp"  Header="A IP"        Width="120" />
            <dxg:GridColumn FieldName="ConfigA" Header="⚙A" Width="35" AllowColumnFiltering="False" AllowEditing="False" AllowSorting="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="&#x2699;" FontSize="14" Padding="2" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Foreground="#90CAF9"
                                Tag="A" Click="ConfigCog_Click" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <!-- B side -->
            <dxg:GridColumn FieldName="BuildingB"  Header="Building B"  Width="100">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="B2BBuildingBCombo" IsTextEditable="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="DeviceB"    Header="Device B"    Width="160">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="PortB"      Header="Port B"      Width="120">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True"
                                              AutoComplete="True"
                                              ValueMember="InterfaceName"
                                              DisplayMember="InterfaceName" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="ModuleB"    Header="Module B"    Width="80" />
            <dxg:GridColumn FieldName="DeviceBIp"  Header="B IP"        Width="120" />
            <dxg:GridColumn FieldName="ConfigB" Header="⚙B" Width="35" AllowColumnFiltering="False" AllowEditing="False" AllowSorting="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="&#x2699;" FontSize="14" Padding="2" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Foreground="#90CAF9"
                                Tag="B" Click="ConfigCog_Click" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <!-- Link details -->
            <dxg:GridColumn FieldName="Tx"         Header="Tx"          Width="60" />
            <dxg:GridColumn FieldName="Rx"         Header="Rx"          Width="60" />
            <dxg:GridColumn FieldName="Media"      Header="Media"       Width="90" />
            <dxg:GridColumn FieldName="Speed"      Header="Speed"       Width="80" />
            <dxg:GridColumn FieldName="Subnet"     Header="Subnet"      Width="120" />
            <dxg:GridColumn FieldName="Status"     Header="Status"      Width="80">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="B2BStatusCombo" IsTextEditable="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="DeviceA" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
        <dxg:GridControl.DetailDescriptor>
            <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailConfigLines">
                <dxg:GridControl AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" ShowColumnHeaders="True"
                                       AllowEditing="False" NavigationStyle="Row" ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Side"    Header="Switch"  Width="180" AllowGrouping="True" />
                        <dxg:GridColumn FieldName="Command" Header="PicOS Command" Width="600">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RowData.Row.Command}"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                               Foreground="#81C784" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.TotalSummary>
                        <dxg:GridSummaryItem SummaryType="Count" FieldName="Command" DisplayFormat="{}Commands: {0}" />
                    </dxg:GridControl.TotalSummary>
                </dxg:GridControl>
            </dxg:DataControlDetailDescriptor>
        </dxg:GridControl.DetailDescriptor>
    </dxg:GridControl>
</UserControl>
