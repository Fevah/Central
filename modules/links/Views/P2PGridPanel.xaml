<UserControl x:Class="Central.Module.Links.Views.P2PGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <UserControl.Resources>
        <ResourceDictionary>
            <conv:StringToBrushConverter x:Key="StringToBrush"
                xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine" />
        </ResourceDictionary>
    </UserControl.Resources>

    <dxg:GridControl x:Name="P2PGrid" ItemsSource="{Binding P2PLinks}" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="P2PView" ShowGroupPanel="True" AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways" NavigationStyle="Cell"
                           AllowEditing="True" ShowAutoFilterRow="True" SearchPanelNullText="Search..."
                           ShowTotalSummary="False" UseEvenRowBackground="True"
                           ValidateRow="P2PView_ValidateRow"
                           CellValueChanged="P2PView_CellValueChanged">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                                <Setter Property="Foreground" Value="#808080" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="ValidationIcon" Header="" Width="30" AllowEditing="False" AllowSorting="True"
                            AllowColumnFiltering="False" HorizontalHeaderContentAlignment="Center">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding RowData.Row.ValidationIcon}"
                                   Foreground="{Binding RowData.Row.ValidationColor, Converter={StaticResource StringToBrush}}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   ToolTip="{Binding RowData.Row.ValidationTooltip}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Building"   Header="Building"    Width="100" AllowGrouping="True" />
            <dxg:GridColumn FieldName="LinkId"     Header="Link ID"     Width="80" Fixed="Left" />
            <dxg:GridColumn FieldName="Vlan"       Header="VLAN"        Width="70" />
            <dxg:GridColumn FieldName="DeviceA"    Header="Device A"    Width="170">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="PortA"      Header="Port A"      Width="120">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True"
                                              AutoComplete="True"
                                              ValueMember="InterfaceName"
                                              DisplayMember="InterfaceName" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="DeviceAIp"  Header="A IP"        Width="130" />
            <dxg:GridColumn FieldName="DescA"      Header="A Description" Width="200">
                <dxg:GridColumn.CellDisplayTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding RowData.Row.DescA}"
                                   Foreground="{Binding RowData.Row.DescAColor, Converter={StaticResource StringToBrush}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellDisplayTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="ConfigA" Header="⚙A" Width="35" AllowEditing="False" AllowSorting="False" AllowColumnFiltering="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="&#x2699;" FontSize="14" Padding="0" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Foreground="#3B82F6"
                                Tag="A" Click="ConfigCog_Click" ToolTip="View Config A" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="DeviceB"    Header="Device B"    Width="170">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="PortB"      Header="Port B"      Width="120">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True"
                                              AutoComplete="True"
                                              ValueMember="InterfaceName"
                                              DisplayMember="InterfaceName" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="DeviceBIp"  Header="B IP"        Width="130" />
            <dxg:GridColumn FieldName="DescB"      Header="B Description" Width="200">
                <dxg:GridColumn.CellDisplayTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding RowData.Row.DescB}"
                                   Foreground="{Binding RowData.Row.DescBColor, Converter={StaticResource StringToBrush}}" />
                    </DataTemplate>
                </dxg:GridColumn.CellDisplayTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="ConfigB" Header="⚙B" Width="35" AllowEditing="False" AllowSorting="False" AllowColumnFiltering="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="&#x2699;" FontSize="14" Padding="0" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Foreground="#3B82F6"
                                Tag="B" Click="ConfigCog_Click" ToolTip="View Config B" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Subnet"     Header="Subnet"      Width="130" />
            <dxg:GridColumn FieldName="Status"     Header="Status"      Width="80">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="P2PStatusCombo" IsTextEditable="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <!-- Cog columns moved inline after each side's description -->
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="DeviceA" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>

        <!-- Master-detail: expand link → show generated PicOS config commands -->
        <dxg:GridControl.DetailDescriptor>
            <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailConfigLines">
                <dxg:GridControl AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" ShowColumnHeaders="True"
                                       AllowEditing="False" NavigationStyle="Row"
                                       ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Side"    Header="Switch"  Width="180" AllowGrouping="True" />
                        <dxg:GridColumn FieldName="Command" Header="PicOS Command" Width="600">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RowData.Row.Command}"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                               Foreground="#81C784" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.TotalSummary>
                        <dxg:GridSummaryItem SummaryType="Count" FieldName="Command" DisplayFormat="{}Commands: {0}" />
                    </dxg:GridControl.TotalSummary>
                </dxg:GridControl>
            </dxg:DataControlDetailDescriptor>
        </dxg:GridControl.DetailDescriptor>
    </dxg:GridControl>
</UserControl>
