<UserControl x:Class="Central.Module.ServiceDesk.Views.RequestGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush"
            xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar: dirty count + save button -->
        <Border Grid.Row="0" Padding="6,4" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="DirtyCountLabel" Foreground="#F59E0B" VerticalAlignment="Center" FontSize="11" />
                <Button x:Name="SaveChangesBtn" Content="Save Changes to ManageEngine" Padding="10,3"
                        Margin="10,0,0,0" Visibility="Collapsed" Click="SaveChanges_Click" />
                <Button x:Name="DiscardChangesBtn" Content="Discard" Padding="10,3"
                        Margin="6,0,0,0" Visibility="Collapsed" Click="DiscardChanges_Click" />
            </StackPanel>
        </Border>

        <dxg:GridControl x:Name="RequestsGrid" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="RequestsView" ShowGroupPanel="True"
                               AllowColumnFiltering="True" ShowFilterPanelMode="ShowAlways"
                               ShowTotalSummary="True" NavigationStyle="Cell"
                               ShowAutoFilterRow="True" SearchPanelNullText="Search requests..."
                               UseEvenRowBackground="True" AllowEditing="True"
                               CellValueChanged="RequestsView_CellValueChanged" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="OverdueIcon" Header="!" Width="25" AllowSorting="True" ReadOnly="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.OverdueIcon}" Foreground="#EF4444"
                                       FontSize="14" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="DisplayId" Header="ID" Width="70" Fixed="Left" ReadOnly="True" />
                <dxg:GridColumn FieldName="TicketUrl" Header="Link" Width="40" AllowSorting="False"
                                AllowColumnFiltering="False" AllowGrouping="False" ReadOnly="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Hyperlink NavigateUri="{Binding RowData.Row.TicketUrl}"
                                           RequestNavigate="Hyperlink_RequestNavigate"
                                           Foreground="#3B82F6" TextDecorations="None">
                                    <Run Text="Open" />
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Subject" Header="Subject" Width="300" ReadOnly="True" />
                <!-- Editable combo columns — wired in code-behind -->
                <dxg:GridColumn x:Name="ColStatus" FieldName="Status" Header="Status" Width="100" AllowGrouping="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.Status}" FontWeight="SemiBold"
                                       Foreground="{Binding RowData.Row.StatusColor, Converter={StaticResource StringToBrush}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn x:Name="ColPriority" FieldName="Priority" Header="Priority" Width="80" AllowGrouping="True">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RowData.Row.Priority}"
                                       Foreground="{Binding RowData.Row.PriorityColor, Converter={StaticResource StringToBrush}}" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                <dxg:GridColumn x:Name="ColGroup" FieldName="GroupName" Header="Group" Width="160" AllowGrouping="True" />
                <dxg:GridColumn x:Name="ColTechnician" FieldName="TechnicianName" Header="Technician" Width="140" AllowGrouping="True" />
                <dxg:GridColumn x:Name="ColCategory" FieldName="Category" Header="Category" Width="120" AllowGrouping="True" />
                <dxg:GridColumn FieldName="RequesterName" Header="Requester" Width="140" ReadOnly="True" />
                <dxg:GridColumn FieldName="RequesterEmail" Header="Email" Width="180" ReadOnly="True" />
                <dxg:GridColumn FieldName="Site" Header="Site" Width="120" AllowGrouping="True" ReadOnly="True" />
                <dxg:GridColumn FieldName="Department" Header="Department" Width="120" AllowGrouping="True" ReadOnly="True" />
                <dxg:GridColumn FieldName="Template" Header="Type" Width="80" AllowGrouping="True" ReadOnly="True" />
                <dxg:GridColumn FieldName="CreatedAt" Header="Created" Width="140" SortOrder="Descending" ReadOnly="True" />
                <dxg:GridColumn FieldName="DueBy" Header="Due By" Width="140" ReadOnly="True" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="DisplayId" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
            <dxg:GridControl.GroupSummary>
                <dxg:GridSummaryItem SummaryType="Count" DisplayFormat="{}{0} requests" />
            </dxg:GridControl.GroupSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
