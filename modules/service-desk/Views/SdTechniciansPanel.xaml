<UserControl x:Class="Central.Module.ServiceDesk.Views.SdTechniciansPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid">

    <dxg:GridControl x:Name="TechGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="TechView" AllowEditing="True" NavigationStyle="Cell"
                           ShowAutoFilterRow="True" SearchPanelNullText="Search technicians..."
                           ShowTotalSummary="True" UseEvenRowBackground="True"
                           CellValueChanged="TechView_CellValueChanged" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="IsActive" Header="Active" Width="60" />
            <dxg:GridColumn FieldName="Name" Header="Name" Width="200" Fixed="Left" ReadOnly="True" />
            <dxg:GridColumn FieldName="Email" Header="Email" Width="220" ReadOnly="True" />
            <dxg:GridColumn FieldName="Department" Header="Department" Width="150" AllowGrouping="True" ReadOnly="True" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Name" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
