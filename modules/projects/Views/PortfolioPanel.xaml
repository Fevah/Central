<UserControl x:Class="Central.Module.Projects.PortfolioPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Portfolio" FontWeight="SemiBold" FontSize="14" Foreground="White" VerticalAlignment="Center" />
            <Button Content="Refresh" Padding="10,4" Margin="12,0,0,0" Click="Refresh_Click" />
        </StackPanel>
        <!-- Portfolio tree: Portfolio → Programme → Project with roll-up stats -->
        <dxg:TreeListControl x:Name="PortfolioTree" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:TreeListControl.View>
                <dxg:TreeListView KeyFieldName="TreeId" ParentFieldName="TreeParentId"
                                   ShowColumnHeaders="True" ShowIndicator="False"
                                   AutoExpandAllNodes="True" AllowEditing="False"
                                   ShowTotalSummary="True" UseEvenRowBackground="True"
                                   SearchPanelNullText="Search portfolio..." />
            </dxg:TreeListControl.View>
            <dxg:TreeListControl.Columns>
                <dxg:TreeListColumn FieldName="Name" Header="Name" Width="240" Fixed="Left" />
                <dxg:TreeListColumn FieldName="Level" Header="Level" Width="90" />
                <dxg:TreeListColumn FieldName="TaskCount" Header="Tasks" Width="60" />
                <dxg:TreeListColumn FieldName="TotalPoints" Header="Points" Width="70" />
                <dxg:TreeListColumn FieldName="CompletedPct" Header="Complete" Width="80" />
                <dxg:TreeListColumn FieldName="OpenBugs" Header="Open Bugs" Width="80" />
                <dxg:TreeListColumn FieldName="ActiveSprints" Header="Sprints" Width="70" />
            </dxg:TreeListControl.Columns>
        </dxg:TreeListControl>
    </Grid>
</UserControl>
