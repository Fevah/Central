<UserControl x:Class="Central.Module.Projects.QADashboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Project:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="ProjectSelector" Width="180" Height="24" NullText="All Projects"
                               IsTextEditable="False" EditValueChanged="ProjectSelector_Changed"
                               DisplayMember="Name" ValueMember="Id" />
            <Button x:Name="RefreshButton" Content="Refresh" Padding="10,4" Margin="8,0,0,0" Click="Refresh_Click" />
        </StackPanel>

        <!-- Charts -->
        <Grid Grid.Row="1" Margin="8,0,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Bug count by severity (stacked bar) -->
            <dxc:ChartControl x:Name="SeverityChart" Grid.Row="0" Grid.Column="0" Margin="0,0,4,4">
                <dxc:ChartControl.Titles>
                    <dxc:Title Content="Bugs by Severity" HorizontalAlignment="Center" />
                </dxc:ChartControl.Titles>
                <dxc:XYDiagram2D>
                    <dxc:BarSideBySideSeries2D x:Name="SeveritySeries" DisplayName="Count"
                                                 ArgumentDataMember="Label" ValueDataMember="Count">
                        <dxc:BarSideBySideSeries2D.Brush>
                            <SolidColorBrush Color="#EF4444" />
                        </dxc:BarSideBySideSeries2D.Brush>
                    </dxc:BarSideBySideSeries2D>
                </dxc:XYDiagram2D>
            </dxc:ChartControl>

            <!-- Bug aging (time since creation) -->
            <dxc:ChartControl x:Name="AgingChart" Grid.Row="0" Grid.Column="1" Margin="4,0,0,4">
                <dxc:ChartControl.Titles>
                    <dxc:Title Content="Bug Aging" HorizontalAlignment="Center" />
                </dxc:ChartControl.Titles>
                <dxc:XYDiagram2D>
                    <dxc:BarSideBySideSeries2D x:Name="AgingSeries" DisplayName="Count"
                                                 ArgumentDataMember="Label" ValueDataMember="Count">
                        <dxc:BarSideBySideSeries2D.Brush>
                            <SolidColorBrush Color="#F59E0B" />
                        </dxc:BarSideBySideSeries2D.Brush>
                    </dxc:BarSideBySideSeries2D>
                </dxc:XYDiagram2D>
            </dxc:ChartControl>

            <!-- Resolution rate (opened vs closed over time) -->
            <dxc:ChartControl x:Name="ResolutionChart" Grid.Row="1" Grid.Column="0" Margin="0,4,4,0">
                <dxc:ChartControl.Titles>
                    <dxc:Title Content="Opened vs Closed (30 days)" HorizontalAlignment="Center" />
                </dxc:ChartControl.Titles>
                <dxc:XYDiagram2D>
                    <dxc:LineSeries2D x:Name="OpenedSeries" DisplayName="Opened"
                                       ArgumentDataMember="Date" ValueDataMember="Count">
                        <dxc:LineSeries2D.Brush>
                            <SolidColorBrush Color="#EF4444" />
                        </dxc:LineSeries2D.Brush>
                    </dxc:LineSeries2D>
                    <dxc:LineSeries2D x:Name="ClosedSeries" DisplayName="Closed"
                                       ArgumentDataMember="Date" ValueDataMember="Count">
                        <dxc:LineSeries2D.Brush>
                            <SolidColorBrush Color="#22C55E" />
                        </dxc:LineSeries2D.Brush>
                    </dxc:LineSeries2D>
                </dxc:XYDiagram2D>
                <dxc:ChartControl.Legend>
                    <dxc:Legend HorizontalPosition="Right" VerticalPosition="Top" />
                </dxc:ChartControl.Legend>
            </dxc:ChartControl>

            <!-- Top reporters/assignees -->
            <dxc:ChartControl x:Name="AssigneeChart" Grid.Row="1" Grid.Column="1" Margin="4,4,0,0">
                <dxc:ChartControl.Titles>
                    <dxc:Title Content="Open Bugs by Assignee" HorizontalAlignment="Center" />
                </dxc:ChartControl.Titles>
                <dxc:XYDiagram2D>
                    <dxc:BarSideBySideSeries2D x:Name="AssigneeSeries" DisplayName="Open"
                                                 ArgumentDataMember="Label" ValueDataMember="Count">
                        <dxc:BarSideBySideSeries2D.Brush>
                            <SolidColorBrush Color="#3B82F6" />
                        </dxc:BarSideBySideSeries2D.Brush>
                    </dxc:BarSideBySideSeries2D>
                </dxc:XYDiagram2D>
            </dxc:ChartControl>
        </Grid>
    </Grid>
</UserControl>
