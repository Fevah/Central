<UserControl x:Class="Central.Module.Projects.ReportBuilderPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Report:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="ReportSelector" Width="200" Height="24" NullText="New Report"
                               IsTextEditable="False" EditValueChanged="ReportSelector_Changed"
                               DisplayMember="DisplayPath" ValueMember="Id" />
            <TextBlock Text="  " />
            <Button x:Name="RunButton" Content="Run Query" Padding="10,4" Margin="0,0,4,0"
                    Click="RunQuery_Click" FontWeight="SemiBold" />
            <Button x:Name="SaveButton" Content="Save Report" Padding="10,4" Margin="0,0,4,0"
                    Click="SaveReport_Click" />
            <Button x:Name="ExportButton" Content="Export CSV" Padding="10,4" Margin="0,0,8,0"
                    Click="ExportCsv_Click" />
            <TextBlock Text="  " />
            <TextBlock Text="Entity:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="EntityTypeSelector" Width="100" Height="24" IsTextEditable="False"
                               EditValue="task" />
        </StackPanel>

        <!-- Filter Builder -->
        <Border Grid.Row="1" Background="#1E293B" Margin="8,0,8,4" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="Filters" FontWeight="SemiBold" Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    <Button x:Name="AddFilterButton" Content="+ Add Filter" Padding="8,2" Margin="12,0,0,0"
                            Click="AddFilter_Click" FontSize="11" />
                    <Button x:Name="ClearFiltersButton" Content="Clear All" Padding="8,2" Margin="4,0,0,0"
                            Click="ClearFilters_Click" FontSize="11" />
                </StackPanel>
                <!-- Filter conditions grid -->
                <dxg:GridControl x:Name="FilterGrid" Grid.Row="1" AutoGenerateColumns="None"
                                  MaxHeight="150" Margin="0,4,0,0">
                    <dxg:GridControl.View>
                        <dxg:TableView AllowEditing="True" NavigationStyle="Cell"
                                        ShowTotalSummary="False" ShowGroupPanel="False" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Logic" Header="Logic" Width="60">
                            <dxg:GridColumn.EditSettings>
                                <dxe:ComboBoxEditSettings IsTextEditable="False">
                                    <dxe:ComboBoxEditSettings.ItemsSource>
                                        <x:Array Type="sys:String">
                                            <sys:String>AND</sys:String>
                                            <sys:String>OR</sys:String>
                                        </x:Array>
                                    </dxe:ComboBoxEditSettings.ItemsSource>
                                </dxe:ComboBoxEditSettings>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="Field" Header="Field" Width="120">
                            <dxg:GridColumn.EditSettings>
                                <dxe:ComboBoxEditSettings x:Name="FieldCombo" IsTextEditable="False" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="Operator" Header="Op" Width="90">
                            <dxg:GridColumn.EditSettings>
                                <dxe:ComboBoxEditSettings IsTextEditable="False">
                                    <dxe:ComboBoxEditSettings.ItemsSource>
                                        <x:Array Type="sys:String">
                                            <sys:String>=</sys:String>
                                            <sys:String>!=</sys:String>
                                            <sys:String>&gt;</sys:String>
                                            <sys:String>&lt;</sys:String>
                                            <sys:String>&gt;=</sys:String>
                                            <sys:String>&lt;=</sys:String>
                                            <sys:String>contains</sys:String>
                                            <sys:String>between</sys:String>
                                            <sys:String>in</sys:String>
                                            <sys:String>isNull</sys:String>
                                            <sys:String>isNotNull</sys:String>
                                        </x:Array>
                                    </dxe:ComboBoxEditSettings.ItemsSource>
                                </dxe:ComboBoxEditSettings>
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                        <dxg:GridColumn FieldName="Value" Header="Value" Width="160" />
                        <dxg:GridColumn FieldName="Value2" Header="Value2" Width="100" />
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </Grid>
        </Border>

        <!-- Results Grid (auto-generated columns from query result) -->
        <dxg:GridControl x:Name="ResultsGrid" Grid.Row="2" AutoGenerateColumns="AddNew">
            <dxg:GridControl.View>
                <dxg:TableView x:Name="ResultsView"
                                AllowEditing="False"
                                ShowAutoFilterRow="True"
                                ShowTotalSummary="True"
                                ShowFilterPanelMode="ShowAlways"
                                UseEvenRowBackground="True"
                                SearchPanelNullText="Search results..." />
            </dxg:GridControl.View>
        </dxg:GridControl>
    </Grid>
</UserControl>
