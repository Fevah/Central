<UserControl x:Class="Central.Module.Projects.KanbanBoardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine">
    <UserControl.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />

        <!-- Card template for each task -->
        <DataTemplate x:Key="KanbanCardTemplate">
            <Border Background="#1E293B" CornerRadius="6" Margin="4,3" Padding="10,8"
                    BorderThickness="0,0,0,0" Cursor="Hand"
                    MouseLeftButtonDown="Card_MouseDown">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.3" BlurRadius="4" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!-- Row 1: Color stripe + Title -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Width="4" Height="14" CornerRadius="2" Margin="0,0,6,0"
                                Background="{Binding Color, Converter={StaticResource StringToBrush}}" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="White"
                                   TextTrimming="CharacterEllipsis" MaxWidth="200" FontSize="12" />
                    </StackPanel>
                    <!-- Row 2: Type + Priority badges -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                        <Border Background="#374151" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                            <TextBlock Text="{Binding TaskType}" FontSize="10" Foreground="#9CA3AF" />
                        </Border>
                        <TextBlock Text="{Binding PriorityIcon}" FontSize="10" FontWeight="Bold"
                                   Foreground="{Binding PriorityColor, Converter={StaticResource StringToBrush}}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PointsDisplay}" FontSize="10" Foreground="#60A5FA"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Row 3: Assigned + Due -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="{Binding AssignedToName}" FontSize="10" Foreground="#6B7280"
                                   MaxWidth="120" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding DueDateDisplay}" FontSize="10" Foreground="#6B7280"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Project:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="ProjectSelector" Width="180" Height="24" NullText="Select Project"
                               IsTextEditable="False" EditValueChanged="ProjectSelector_Changed"
                               DisplayMember="Name" ValueMember="Id" />
            <TextBlock Text="  " />
            <dxe:ComboBoxEdit x:Name="SwimLaneSelector" Width="140" Height="24" NullText="No Swim Lanes"
                               IsTextEditable="False" EditValueChanged="SwimLane_Changed" />
            <TextBlock Text="  " />
            <Button x:Name="AddCardButton" Content="+ Card" Padding="10,4" Margin="0,0,4,0"
                    Click="AddCard_Click" FontWeight="SemiBold" />
            <Button x:Name="ConfigButton" Content="Board Config" Padding="10,4"
                    Click="Config_Click" />
        </StackPanel>

        <!-- Board columns as horizontal ScrollViewer -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="ColumnsHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Margin="4,4" Background="#111827" CornerRadius="8" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <!-- Column header -->
                                <Border Grid.Row="0" Background="#1F2937" CornerRadius="8,8,0,0" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding ColumnName}" FontWeight="SemiBold" Foreground="White" FontSize="13" />
                                        <TextBlock Text="{Binding WipDisplay}" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#9CA3AF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOverWip}" Value="True">
                                                            <Setter Property="Foreground" Value="#EF4444" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <!-- Cards list -->
                                <ListBox Grid.Row="1" x:Name="CardList"
                                         ItemsSource="{Binding Cards}"
                                         ItemTemplate="{StaticResource KanbanCardTemplate}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         AllowDrop="True"
                                         Drop="Column_Drop"
                                         DragOver="Column_DragOver"
                                         Tag="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
