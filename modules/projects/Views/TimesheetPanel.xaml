<UserControl x:Class="Central.Module.Projects.TimesheetPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Week of:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:DateEdit x:Name="WeekPicker" Width="120" Height="24" EditValueChanged="WeekPicker_Changed" />
            <Button x:Name="AddEntryButton" Content="+ Log Time" Padding="10,4" Margin="8,0,4,0"
                    Click="AddEntry_Click" FontWeight="SemiBold" />
            <TextBlock x:Name="TotalHoursText" VerticalAlignment="Center" Foreground="#22C55E"
                       FontSize="12" FontWeight="SemiBold" Margin="12,0,0,0" />
        </StackPanel>
        <dxg:GridControl x:Name="TimesheetGrid" Grid.Row="1" AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="True" NavigationStyle="Cell" ShowTotalSummary="True"
                                UseEvenRowBackground="True" ShowAutoFilterRow="True"
                                ValidateRow="TimesheetView_ValidateRow"
                                InvalidRowException="TimesheetView_InvalidRowException" />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="EntryDateDisplay" Header="Date" Width="90" ReadOnly="True" />
                <dxg:GridColumn FieldName="TaskTitle" Header="Task" Width="200" ReadOnly="True" />
                <dxg:GridColumn FieldName="Hours" Header="Hours" Width="70">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings MinValue="0" MaxValue="24" IsFloatValue="True" Mask="n2" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="ActivityType" Header="Activity" Width="100">
                    <dxg:GridColumn.EditSettings>
                        <dxe:ComboBoxEditSettings IsTextEditable="False">
                            <dxe:ComboBoxEditSettings.ItemsSource>
                                <x:Array Type="sys:String">
                                    <sys:String>Development</sys:String>
                                    <sys:String>Testing</sys:String>
                                    <sys:String>Review</sys:String>
                                    <sys:String>Meeting</sys:String>
                                    <sys:String>Admin</sys:String>
                                </x:Array>
                            </dxe:ComboBoxEditSettings.ItemsSource>
                        </dxe:ComboBoxEditSettings>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Notes" Header="Notes" Width="200" />
                <dxg:GridColumn FieldName="UserName" Header="User" Width="100" ReadOnly="True" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Sum" FieldName="Hours" DisplayFormat="{}Total: {0:n2}h" />
                <dxg:GridSummaryItem SummaryType="Count" FieldName="TaskTitle" DisplayFormat="{}Entries: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</UserControl>
