<UserControl x:Class="Central.Module.Devices.Views.AsnGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="AsnGrid"
                     ItemsSource="{Binding AsnDefinitions}"
                     AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="AsnView"
                           ShowGroupPanel="False"
                           AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways"
                           NavigationStyle="Cell"
                           AllowEditing="True"
                           ShowAutoFilterRow="True"
                           UseEvenRowBackground="True"
                           ShowTotalSummary="False" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Asn"         Header="ASN"         Width="90"  Fixed="Left" ReadOnly="True" SortIndex="0" SortOrder="Ascending" />
            <dxg:GridColumn FieldName="AsnType"     Header="Type"        Width="120" AllowGrouping="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="AsnTypeCombo" IsTextEditable="True">
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="Building Router" />
                            <dxe:ComboBoxEditItem Content="P2P" />
                            <dxe:ComboBoxEditItem Content="B2B" />
                            <dxe:ComboBoxEditItem Content="Server" />
                            <dxe:ComboBoxEditItem Content="Firewall" />
                            <dxe:ComboBoxEditItem Content="Reserved" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Description" Header="Description" Width="300" />
            <dxg:GridColumn FieldName="DeviceCount" Header="Count"       Width="60"  ReadOnly="True" />
            <dxg:GridColumn FieldName="Devices" Header="Bound Devices" Width="300" ReadOnly="True" />
            <dxg:GridColumn Header="Bind" Width="180" FieldName="BindDevice" UnboundType="String">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="AsnBoundDevicesCombo"
                                              ValueMember="SwitchName"
                                              DisplayMember="SwitchName"
                                              IsTextEditable="True"
                                              AutoComplete="True"
                                              IncrementalFiltering="True"
                                              ImmediatePopup="True"
                                              PopupMaxHeight="350" PopupMinWidth="400">
                        <dxe:ComboBoxEditSettings.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding SwitchName}" FontWeight="SemiBold" Margin="4,2" />
                                    <TextBlock Grid.Column="1" Text="{Binding Building}" Foreground="#888" Margin="4,2" />
                                    <TextBlock Grid.Column="2" Text="{Binding Asn}" Foreground="#90CAF9" Margin="4,2" />
                                    <TextBlock Grid.Column="3" Text="{Binding DeviceType}" Foreground="#666" Margin="4,2" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </dxe:ComboBoxEditSettings.ItemTemplate>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="SortOrder"   Header="Sort"        Width="60"  Visible="False" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Asn" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
        <dxg:GridControl.DetailDescriptor>
            <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailDevices">
                <dxg:GridControl AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" ShowColumnHeaders="True"
                                       AllowEditing="False" NavigationStyle="Row" ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="SwitchName"  Header="Device"    Width="180" />
                        <dxg:GridColumn FieldName="Building"    Header="Building"  Width="100" />
                        <dxg:GridColumn FieldName="DeviceType"  Header="Type"      Width="140" />
                        <dxg:GridColumn FieldName="PrimaryIp"   Header="Primary IP" Width="130" />
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.TotalSummary>
                        <dxg:GridSummaryItem SummaryType="Count" FieldName="SwitchName" DisplayFormat="{}Devices: {0}" />
                    </dxg:GridControl.TotalSummary>
                </dxg:GridControl>
            </dxg:DataControlDetailDescriptor>
        </dxg:GridControl.DetailDescriptor>
    </dxg:GridControl>
</UserControl>
