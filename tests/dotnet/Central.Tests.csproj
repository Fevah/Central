<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Modules target net10.0-windows (they host WPF UserControls).
         Test project matches so it can ProjectReference every module
         for the engine-level ribbon audit. UseWPF=false keeps the
         test SDK as plain Sdk; WPF assemblies come transitively from
         the module references. -->
    <TargetFramework>net10.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\libs\engine\Central.Engine.csproj" />
    <ProjectReference Include="..\..\services\api\Central.Api.csproj" />
    <ProjectReference Include="..\..\libs\persistence\Central.Persistence.csproj" />
    <ProjectReference Include="..\..\libs\tenancy\Central.Tenancy.csproj" />
    <ProjectReference Include="..\..\libs\collaboration\Central.Collaboration.csproj" />
    <ProjectReference Include="..\..\libs\security\Central.Security.csproj" />
    <ProjectReference Include="..\..\libs\observability\Central.Observability.csproj" />
    <ProjectReference Include="..\..\libs\workflows\Central.Workflows.csproj" />
    <ProjectReference Include="..\..\libs\licensing\Central.Licensing.csproj" />

    <!-- Module references so the engine-level ribbon audit test
         can enumerate every IModuleRibbon implementation at test
         time. Without these, reflection wouldn't find non-Networking
         modules + the audit would silently pass with zero coverage
         on the drift surface the test is meant to guard. -->
    <ProjectReference Include="..\..\modules\audit\Central.Module.Audit.csproj" />
    <ProjectReference Include="..\..\modules\crm\Central.Module.CRM.csproj" />
    <ProjectReference Include="..\..\modules\global\Central.Module.Global.csproj" />
    <ProjectReference Include="..\..\modules\networking\Central.Module.Networking.csproj" />
    <ProjectReference Include="..\..\modules\projects\Central.Module.Projects.csproj" />
    <ProjectReference Include="..\..\modules\service-desk\Central.Module.ServiceDesk.csproj" />
  </ItemGroup>

</Project>