# Central API Gateway configuration
# Start with: gateway-service.exe (reads these env vars)

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Backend service URLs
AUTH_SERVICE_URL=http://localhost:8081
ADMIN_SERVICE_URL=http://localhost:8080
AUDIT_SERVICE_URL=http://localhost:8082
SYNC_SERVICE_URL=http://localhost:8083
STORAGE_SERVICE_URL=http://localhost:8084
CENTRAL_API_URL=http://localhost:5000

# JWT (must match auth-service secret — set in deployment, never commit real values)
# AUTH_SERVICE_JWT_SECRET must be set at deployment time — do not hardcode
AUTH_SERVICE_JWT_SECRET=CHANGE_ME_AT_DEPLOYMENT

# Logging
RUST_LOG=gateway_service=info,tower_http=info
