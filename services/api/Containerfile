FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

ENV EnableWindowsTargeting=true

# Copy all project files for restore
COPY Central.Core/Central.Core.csproj Central.Core/
COPY Central.Data/Central.Data.csproj Central.Data/
COPY Central.Api.Client/Central.Api.Client.csproj Central.Api.Client/
COPY Central.Api/Central.Api.csproj Central.Api/
COPY Central.Tenancy/Central.Tenancy.csproj Central.Tenancy/
COPY Central.Licensing/Central.Licensing.csproj Central.Licensing/
COPY Central.Security/Central.Security.csproj Central.Security/
COPY Central.Collaboration/Central.Collaboration.csproj Central.Collaboration/
COPY Central.Observability/Central.Observability.csproj Central.Observability/
COPY Central.Workflows/Central.Workflows.csproj Central.Workflows/
COPY NuGet.config .
RUN mkdir -p packages-offline && \
    dotnet restore Central.Api/Central.Api.csproj --force --packages /src/.nuget

# Copy all source
COPY Central.Core/ Central.Core/
COPY Central.Data/ Central.Data/
COPY Central.Api.Client/ Central.Api.Client/
COPY Central.Api/ Central.Api/
COPY Central.Tenancy/ Central.Tenancy/
COPY Central.Licensing/ Central.Licensing/
COPY Central.Security/ Central.Security/
COPY Central.Collaboration/ Central.Collaboration/
COPY Central.Observability/ Central.Observability/
COPY Central.Workflows/ Central.Workflows/
RUN dotnet publish Central.Api/Central.Api.csproj -c Release -o /app \
    -p:EnableWindowsTargeting=true \
    -p:RestorePackagesPath=/src/.nuget

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app .

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

ENV ASPNETCORE_URLS=http://+:5000
ENV CENTRAL_DSN="Host=postgres;Port=5432;Database=central;Username=central;Password=central"
EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -sf http://localhost:5000/api/health || exit 1

ENTRYPOINT ["dotnet", "Central.Api.dll"]
