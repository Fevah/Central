FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

ENV EnableWindowsTargeting=true

# Build context is the repo root (docker build . -f services/api/Containerfile).
# Paths below reflect the post-restructure tree: apps/ libs/ modules/ services/ tests/.

# Copy NuGet config + the sln so paths resolve
COPY NuGet.config Central.sln ./

# Csproj files only, for a faster `dotnet restore` layer cache
COPY libs/engine/Central.Engine.csproj                 libs/engine/
COPY libs/persistence/Central.Persistence.csproj       libs/persistence/
COPY libs/api-client/Central.ApiClient.csproj          libs/api-client/
COPY libs/tenancy/Central.Tenancy.csproj               libs/tenancy/
COPY libs/licensing/Central.Licensing.csproj           libs/licensing/
COPY libs/security/Central.Security.csproj             libs/security/
COPY libs/collaboration/Central.Collaboration.csproj   libs/collaboration/
COPY libs/observability/Central.Observability.csproj   libs/observability/
COPY libs/workflows/Central.Workflows.csproj           libs/workflows/
COPY services/api/Central.Api.csproj                   services/api/

RUN dotnet restore services/api/Central.Api.csproj --packages /src/.nuget

# Copy the source trees referenced by Central.Api
COPY libs/engine/           libs/engine/
COPY libs/persistence/      libs/persistence/
COPY libs/api-client/       libs/api-client/
COPY libs/tenancy/          libs/tenancy/
COPY libs/licensing/        libs/licensing/
COPY libs/security/         libs/security/
COPY libs/collaboration/    libs/collaboration/
COPY libs/observability/    libs/observability/
COPY libs/workflows/        libs/workflows/
COPY services/api/          services/api/

RUN dotnet publish services/api/Central.Api.csproj -c Release -o /app \
    -p:EnableWindowsTargeting=true \
    -p:RestorePackagesPath=/src/.nuget

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app .

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

ENV ASPNETCORE_URLS=http://+:5000
ENV CENTRAL_DSN="Host=postgres;Port=5432;Database=central;Username=central;Password=central"
EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD curl -sf http://localhost:5000/api/health || exit 1

ENTRYPOINT ["dotnet", "Central.Api.dll"]
