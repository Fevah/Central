%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 11 13
%%EndPageSetup
q 0 0 11 13 rectclip
1 0 0 -1 0 13 cm q
q
0 0 11 13 re W n
% Fallback Image: x=0 y=0 w=11 h=13 res=300ppi size=7590
[ 11.04 0 0 -13.2 0 13.2 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 46
  /Height 55
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 46 0 0 -55 0 55 ]
