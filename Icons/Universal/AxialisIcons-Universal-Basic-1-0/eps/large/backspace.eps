%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 19 14
%%EndPageSetup
q 0 0 19 14 rectclip
1 0 0 -1 0 14 cm q
q
0 0 19 14 re W n
% Fallback Image: x=0 y=0 w=19 h=14 res=300ppi size=14160
[ 19.2 0 0 -14.16 0 14.16 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 80
  /Height 59
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 80 0 0 -59 0 59 ]
>>
