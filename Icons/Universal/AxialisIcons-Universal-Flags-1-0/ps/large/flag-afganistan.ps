q 0 0 18 18 rectclip
1 0 0 -1 0 18 cm q
0.486275 0.482353 0.478431 rg
0 2.25 5.961 13.5 re f
0.952941 0.47451 0.501961 rg
5.961 2.25 6.078 13.5 re f
0.388235 0.74902 0.501961 rg
12.039 2.25 5.961 13.5 re f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
>>
