q 0 0 12 12 rectclip
1 0 0 -1 0 12 cm q
0.486275 0.482353 0.478431 rg
0 1.5 3.977 9 re f
0.952941 0.47451 0.501961 rg
3.977 1.5 4.047 9 re f
0.388235 0.74902 0.501961 rg
8.023 1.5 3.977 9 re f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 12 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -50 0 50 ]
>>
