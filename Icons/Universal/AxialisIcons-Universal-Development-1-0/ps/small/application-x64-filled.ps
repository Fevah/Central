q 0 0 12 12 rectclip
1 0 0 -1 0 12 cm q
0.392157 0.521569 0.764706 rg
1.5 0 m 1.5 2.25 l 12 2.25 l 12 0 l h
8.25 1.5 m 7.5 1.5 l 7.5 0.75 l 8.25 0.75 l h
9.75 1.5 m 9 1.5 l 9 0.75 l 9.75 0.75 l h
11.25 1.5 m 10.5 1.5 l 10.5 0.75 l 11.25 0.75 l h
11.25 1.5 m f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 12 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -50 0 50 ]
>>
