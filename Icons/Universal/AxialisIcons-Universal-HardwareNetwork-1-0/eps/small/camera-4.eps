0 0 12 11 re W n
% Fallback Image: x=0 y=0 w=12 h=11 res=300ppi size=6900
[ 12 0 0 -11.04 0 11.04 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 46
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -46 0 46 ]
