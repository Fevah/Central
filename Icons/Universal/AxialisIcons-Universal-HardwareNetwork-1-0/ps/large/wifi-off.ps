q 0 0 18 18 rectclip
1 0 0 -1 0 18 cm q
0.482353 g
18 17.25 m 12.75 17.25 l 12.75 15.75 l 18 15.75 l h
5.25 17.25 m 0 17.25 l 0 15.75 l 5.25 15.75 l h
9.75 12.375 m 8.25 12.375 l 8.25 9.602 l 9.75 9.602 l h
9.75 12.375 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
