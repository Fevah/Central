1.125 9 m 3 9 l 3 9.75 l 1.125 9.75 l h
1.5 10.5 m 3 10.5 l 3 11.25 l 1.5 11.25 l h
1.875 12 m 3 12 l 3 12.75 l 1.875 12.75 l h
0.75 7.5 m 3 7.5 l 3 8.25 l 0.75 8.25 l h
0.375 6 m 3 6 l 3 6.75 l 0.375 6.75 l h
0 4.5 m 3 4.5 l 3 5.25 l 0 5.25 l h
0 4.5 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
