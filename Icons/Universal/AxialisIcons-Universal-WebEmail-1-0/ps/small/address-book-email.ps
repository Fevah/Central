q 0 0 12 12 rectclip
1 0 0 -1 0 12 cm q
0.933333 0.67451 0.333333 rg
10.5 6.75 0.75 2.25 re f
0.796078 0.321569 0.364706 rg
10.5 3.75 0.75 2.25 re f
0.321569 0.698039 0.313726 rg
10.5 0.75 0.75 2.25 re f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 12 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -50 0 50 ]
>>
