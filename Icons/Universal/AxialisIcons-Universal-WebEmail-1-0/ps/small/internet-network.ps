12 11.25 m 8.625 11.25 l 8.625 10.5 l 12 10.5 l h
3.375 11.25 m 0 11.25 l 0 10.5 l 3.375 10.5 l h
6.375 9.375 m 5.625 9.375 l 5.625 8.625 l 6.375 8.625 l h
6.375 9.375 m f
0.933333 0.67451 0.333333 rg
3.75 9.75 4.5 2.25 re f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 12 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -50 0 50 ]
