  /Width 75
  /Height 71
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -71 0 71 ]
