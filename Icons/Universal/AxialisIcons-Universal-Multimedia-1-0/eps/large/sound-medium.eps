%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 16 17
%%EndPageSetup
q 0 0 16 17 rectclip
1 0 0 -1 0 17 cm q
q
0 0 16 17 re W n
% Fallback Image: x=0 y=0 w=16 h=17 res=300ppi size=14271
[ 16.08 0 0 -17.04 0 17.04 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 67
  /Height 71
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 67 0 0 -71 0 71 ]
