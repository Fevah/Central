1 0 0 -1 0 18 cm q
0.933333 0.67451 0.333333 rg
15.75 10.5 1.5 3.75 re f
0.796078 0.321569 0.364706 rg
15.75 6 1.5 3.75 re f
0.321569 0.698039 0.313726 rg
15.75 1.5 1.5 3.75 re f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
