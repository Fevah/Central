q 0 0 7 12 rectclip
1 0 0 -1 0 12 cm q
q
0 0 7 12 re W n
% Fallback Image: x=0 y=0 w=7 h=12 res=300ppi size=4500
[ 7.2 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 30
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 30 0 0 -50 0 50 ]
