q 0 0 14 18 rectclip
1 0 0 -1 0 18 cm q
q
0 0 14 18 re W n
% Fallback Image: x=0 y=0 w=14 h=18 res=300ppi size=13275
[ 14.16 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceGray setcolorspace
<<
  /ImageType 1
  /Width 59
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 59 0 0 -75 0 75 ]
