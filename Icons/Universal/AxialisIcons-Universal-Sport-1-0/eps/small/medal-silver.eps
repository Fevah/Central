%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 10 13
%%EndPageSetup
q 0 0 10 13 rectclip
1 0 0 -1 0 13 cm q
q
0 0 10 13 re W n
% Fallback Image: x=0 y=0 w=10 h=13 res=300ppi size=6930
[ 10.08 0 0 -13.2 0 13.2 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 42
  /Height 55
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 42 0 0 -55 0 55 ]
