%%BeginSetup
%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 15 18
%%EndPageSetup
q 0 0 15 18 rectclip
1 0 0 -1 0 18 cm q
q
0 0 15 18 re W n
% Fallback Image: x=0 y=0 w=15 h=18 res=300ppi size=14175
[ 15.12 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 63
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 63 0 0 -75 0 75 ]
>>
