 1.711 l 2.961 1.457 3.137 1.25 3.363 1.129 c 4.555 0.484 l 4.828 1.004 
l 3.641 1.648 l 3.543 1.699 3.461 1.801 3.418 1.918 c 2.824 3.504 l 2.93
 3.773 2.902 4.109 2.746 4.348 c 2.672 4.461 2.578 4.543 2.469 4.594 c h
2.469 4.594 m f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 12 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -50 0 50 ]
