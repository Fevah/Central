%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 12 12
%%EndPageSetup
q 0 0 12 12 rectclip
1 0 0 -1 0 12 cm q
1 g
3.422 4.75 m 2.949 7.227 l 7.68 5.547 m 5.594 3.906 l f
0.427451 0.431373 0.443137 rg
2.492 7.215 m 2.992 4.594 l 3.875 4.762 l 3.375 7.387 l h
5.254 4.215 m 5.812 3.508 l 8.016 5.238 l 7.457 5.945 l h
5.254 4.215 m f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 12 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -50 0 50 ]
