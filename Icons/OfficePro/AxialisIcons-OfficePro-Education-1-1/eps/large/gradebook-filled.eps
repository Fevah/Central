%%EndPageSetup
q 0 0 21 23 rectclip
1 0 0 -1 0 23 cm q
1 g
1.875 20.273 m 1.875 22.125 l 19.875 22.125 l 19.875 0.375 l 1.875 0.375
 l 1.875 2.273 l f
q
0 0 21 23 re W n
% Fallback Image: x=0 y=0 w=21 h=23 res=300ppi size=25344
[ 21.12 0 0 -23.04 0 23.04 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 88
  /Height 96
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 88 0 0 -96 0 96 ]
