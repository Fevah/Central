q 0 0 24 24 rectclip
1 0 0 -1 0 24 cm q
1 g
22.875 4.875 m 22.875 19.875 l 14.25 19.875 l 14.25 12.711 l 10.625 9 l
 8.625 9 l 8.625 4.875 l h
22.875 4.875 m f
3.375 4.875 5.25 4.125 re f
3.375 1.125 19.5 3.75 re f
0.933333 0.239216 0.231373 rg
8.25 9 m 9 9 l 9 5.25 l 8.25 5.25 l 8.25 7.5 l 3.75 7.5 l 3.75 8.25 l 8.25
 8.25 l h
8.25 9 m f
q
0 0 24 24 re W n
% Fallback Image: x=0 y=0 w=24 h=24 res=300ppi size=30000
[ 0.24 0 0 -0.24 0 24 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 100 def
  /Height 100 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 100 ] def
end
