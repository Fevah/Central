%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 23 23
%%EndPageSetup
q 0 0 23 23 rectclip
1 0 0 -1 0 23 cm q
1 g
5.625 4.125 14.25 15 re f
0.375 4.125 5.25 15 re f
q
0 0 23 23 re W n
% Fallback Image: x=0 y=0 w=23 h=23 res=300ppi size=27648
[ 0.24 0 0 -0.24 0 23.04 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 96 def
  /Height 96 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 96 ] def
end
