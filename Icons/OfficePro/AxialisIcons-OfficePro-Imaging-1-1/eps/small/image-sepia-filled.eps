1 0 0 -1 0 11 cm q
1 g
0.418 0.602 11.207 9.598 re f
q
0 0 12 11 re W n
% Fallback Image: x=0 y=0 w=12 h=11 res=300ppi size=6900
[ 0.24 0 0 -0.24 0 11.04 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 50 def
  /Height 46 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 46 ] def
end
