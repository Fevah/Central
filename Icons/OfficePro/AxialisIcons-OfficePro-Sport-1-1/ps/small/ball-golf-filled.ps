%%BeginPageSetup
%%PageMedia: 4x4mm
%%PageBoundingBox: 0 0 12 12
12 12 cairo_set_page_size
%%EndPageSetup
q 0 0 12 12 rectclip
1 0 0 -1 0 12 cm q
1 g
11.625 6 m 11.625 9.105 9.105 11.625 6 11.625 c 2.895 11.625 0.375 9.105
 0.375 6 c 0.375 2.895 2.895 0.375 6 0.375 c 9.105 0.375 11.625 2.895 11.625
 6 c h
11.625 6 m f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 0.24 0 0 -0.24 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 50 def
  /Height 50 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 50 ] def
end
