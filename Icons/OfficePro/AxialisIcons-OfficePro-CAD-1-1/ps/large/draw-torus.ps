q 0 0 24 24 rectclip
1 0 0 -1 0 24 cm q
0.937255 0.243137 0.231373 rg
12 13.688 m 11.07 13.688 10.313 12.93 10.313 12 c 10.313 11.07 11.07 10.313
 12 10.313 c 12.93 10.313 13.688 11.07 13.688 12 c 13.688 12.93 12.93 13.688
 12 13.688 c h
12 13.688 m f
q
0 0 24 24 re W n
% Fallback Image: x=0 y=0 w=24 h=24 res=300ppi size=30000
[ 24 0 0 -24 0 24 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 100
  /Height 100
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 100 0 0 -100 0 100 ]
