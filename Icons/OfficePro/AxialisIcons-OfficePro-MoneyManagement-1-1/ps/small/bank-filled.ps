 4.125 l 1.875 10.125 l 1.125 10.125 l 1.125 11.625 l 10.887 11.625 l 10.875
 10.125 l 10.125 10.125 l 10.125 4.125 l h
11.625 4.125 m f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 0.24 0 0 -0.24 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 50 def
  /Height 50 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 50 ] def
end
