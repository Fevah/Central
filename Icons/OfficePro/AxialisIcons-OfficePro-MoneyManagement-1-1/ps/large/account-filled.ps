q 0 0 24 24 rectclip
1 0 0 -1 0 24 cm q
1 g
8.625 1.125 m 8.625 6.66 l 11.188 7.047 13.156 9.223 13.156 11.84 c 13.156
 13.266 12.559 14.637 11.516 15.621 c 12.219 16.055 12.863 16.605 13.434
 17.262 c 13.734 17.609 14.012 17.984 14.258 18.375 c 22.875 18.375 l 22.875
 1.125 l h
8.625 1.125 m f
q
0 0 24 24 re W n
% Fallback Image: x=0 y=0 w=24 h=24 res=300ppi size=30000
[ 0.24 0 0 -0.24 0 24 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 100 def
  /Height 100 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 100 ] def
end
