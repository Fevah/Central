<dx:DXWindow x:Class="Central.Desktop.Services.ChartDrillDownWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             Title="Drill-Down" Width="1100" Height="650"
             WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderLabel" Grid.Row="0" FontSize="14" FontWeight="SemiBold"
                   Foreground="#E0E0E0" Margin="12,10,12,6" />

        <dxg:GridControl x:Name="DrillGrid" Grid.Row="1">
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="True" AllowEditing="False" NavigationStyle="Row"
                               ShowAutoFilterRow="True" ShowTotalSummary="True"
                               UseEvenRowBackground="True" SearchPanelNullText="Search..." />
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="DisplayId" Header="ID" Width="70" Fixed="Left" />
                <dxg:GridColumn FieldName="Subject" Header="Subject" Width="300" />
                <dxg:GridColumn FieldName="Status" Header="Status" Width="90" AllowGrouping="True" />
                <dxg:GridColumn FieldName="Priority" Header="Priority" Width="80" AllowGrouping="True" />
                <dxg:GridColumn FieldName="GroupName" Header="Group" Width="150" AllowGrouping="True" />
                <dxg:GridColumn FieldName="TechnicianName" Header="Technician" Width="140" AllowGrouping="True" />
                <dxg:GridColumn FieldName="RequesterName" Header="Requester" Width="140" />
                <dxg:GridColumn FieldName="Site" Header="Site" Width="100" AllowGrouping="True" />
                <dxg:GridColumn FieldName="CreatedAt" Header="Created" Width="140" />
                <dxg:GridColumn FieldName="DueBy" Header="Due By" Width="140" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" FieldName="DisplayId" DisplayFormat="{}Total: {0}" />
            </dxg:GridControl.TotalSummary>
        </dxg:GridControl>
    </Grid>
</dx:DXWindow>
