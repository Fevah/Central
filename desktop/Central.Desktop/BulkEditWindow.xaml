<dx:DXDialogWindow x:Class="Central.Desktop.BulkEditWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   Title="Bulk Edit"
                   Width="450" Height="300"
                   WindowStartupLocation="CenterOwner"
                   ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock x:Name="CountLabel" Text="" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16" />

        <TextBlock Text="Field to update:" Margin="0,0,0,4" />
        <dxe:ComboBoxEdit x:Name="FieldCombo" Height="28" Margin="0,0,0,12"
                           IsTextEditable="False"
                           EditValueChanged="FieldCombo_Changed" />

        <TextBlock Text="New value:" Margin="0,0,0,4" />
        <dxe:TextEdit x:Name="ValueEdit" Height="28" Margin="0,0,0,16" />

        <TextBlock x:Name="PreviewText" Text="" FontSize="11"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Margin="0,0,0,16" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Apply" Width="100" Height="30" Margin="0,0,8,0" Click="Apply_Click" IsDefault="True" />
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</dx:DXDialogWindow>
