<UserControl x:Class="Central.Module.GlobalAdmin.Views.GlobalUsersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="UsersGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="UsersView"
                           ShowGroupPanel="False"
                           AllowColumnFiltering="True"
                           AllowEditing="False"
                           ShowAutoFilterRow="True" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="email" Header="Email" Width="200" Fixed="Left" />
            <dxg:GridColumn FieldName="display_name" Header="Display Name" Width="150" />
            <dxg:GridColumn FieldName="email_verified" Header="Verified" Width="80" />
            <dxg:GridColumn FieldName="is_global_admin" Header="Global Admin" Width="100" />
            <dxg:GridColumn FieldName="tenant_count" Header="Tenants" Width="80" />
            <dxg:GridColumn FieldName="tenant_slugs" Header="Tenant Slugs" Width="200" />
            <dxg:GridColumn FieldName="created_at" Header="Created" Width="140" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="email" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
