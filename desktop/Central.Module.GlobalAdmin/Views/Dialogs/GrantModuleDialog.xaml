<dxc:DXDialogWindow x:Class="Central.Module.GlobalAdmin.Views.Dialogs.GrantModuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
        Title="Grant Module Licenses" Width="450" Height="420"
        WindowStartupLocation="CenterOwner">

    <dxlc:LayoutControl Orientation="Vertical" Padding="12">

        <dxlc:LayoutItem Label="Tenant">
            <dxe:TextEdit x:Name="TenantLabel" IsReadOnly="True" />
        </dxlc:LayoutItem>

        <TextBlock Text="Select modules to grant:" Margin="0,8,0,4" FontWeight="SemiBold" />

        <dxe:ListBoxEdit x:Name="ModuleList" Height="220"
                         SelectionMode="Multiple"
                         DisplayMember="DisplayText"
                         ValueMember="Id" />

        <dxlc:LayoutItem Label="Expires">
            <dxe:DateEdit x:Name="ExpiryDate" NullText="(no expiry)" AllowNullInput="True" />
        </dxlc:LayoutItem>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">
            <Button x:Name="SelectAllBtn" Content="Select All" Padding="8,4" Margin="0,0,8,0" />
            <Button x:Name="SelectNoneBtn" Content="Select None" Padding="8,4" />
        </StackPanel>

    </dxlc:LayoutControl>
</dxc:DXDialogWindow>
