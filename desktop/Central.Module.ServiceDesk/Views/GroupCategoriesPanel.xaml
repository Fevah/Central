<UserControl x:Class="Central.Module.ServiceDesk.Views.GroupCategoriesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4">
            <TextBlock Text="Group Categories" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0"
                       VerticalAlignment="Center" />
            <Button Content="Add Category" Margin="15,0,4,0" Padding="10,3" Click="AddCategory_Click" />
            <Button Content="Delete" Padding="10,3" Margin="0,0,4,0" Click="Delete_Click" />
            <Button Content="Move Up" Padding="10,3" Margin="0,0,4,0" Click="MoveUp_Click" />
            <Button Content="Move Down" Padding="10,3" Margin="0,0,4,0" Click="MoveDown_Click" />
            <Button Content="Save" Padding="10,3" FontWeight="Bold" Click="Save_Click" />
        </StackPanel>

        <dxg:TreeListControl x:Name="Tree" Grid.Row="1"
                              AutoGenerateColumns="None"
                              ItemsSource="{x:Null}">
            <dxg:TreeListControl.View>
                <dxg:TreeListView x:Name="TreeView"
                                   KeyFieldName="NodeId"
                                   ParentFieldName="ParentNodeId"
                                   AllowEditing="True"
                                   NavigationStyle="Cell"
                                   ShowTotalSummary="False"
                                   AutoExpandAllNodes="True"
                                   AllowDragDrop="True"
                                   ShowAutoFilterRow="False" />
            </dxg:TreeListControl.View>
            <dxg:TreeListControl.Columns>
                <dxg:TreeListColumn FieldName="DisplayName" Header="Name" Width="250" />
                <dxg:TreeListColumn FieldName="IsActive" Header="Active" Width="55" />
                <dxg:TreeListColumn FieldName="TicketCount" Header="Tickets" Width="60" ReadOnly="True" />
                <dxg:TreeListColumn FieldName="NodeType" Header="Type" Width="70" ReadOnly="True" />
            </dxg:TreeListControl.Columns>
        </dxg:TreeListControl>
    </Grid>
</UserControl>
