<UserControl x:Class="Central.Module.ServiceDesk.Views.SdGroupsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="GroupsGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="GroupsView" AllowEditing="True" NavigationStyle="Cell"
                           ShowAutoFilterRow="True" SearchPanelNullText="Search groups..."
                           ShowTotalSummary="True" UseEvenRowBackground="True"
                           ValidateRow="GroupsView_ValidateRow" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Name" Header="Group Name" Width="250" />
            <dxg:GridColumn FieldName="IsActive" Header="Active" Width="60" />
            <dxg:GridColumn FieldName="SortOrder" Header="Order" Width="60" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Name" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
