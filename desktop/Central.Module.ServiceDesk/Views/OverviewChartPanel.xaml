<UserControl x:Class="Central.Module.ServiceDesk.Views.OverviewChartPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- KPI Cards -->
        <ItemsControl x:Name="KpiCards" Grid.Row="0" Margin="4,4,4,4">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Summary bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,2,4,4">
            <TextBlock x:Name="SummaryLabel" Foreground="#808080" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Chart -->
        <dxc:ChartControl x:Name="OverviewChart" Grid.Row="2"
                           MouseDoubleClick="OverviewChart_MouseDoubleClick">
            <dxc:ChartControl.CrosshairOptions>
                <dxc:CrosshairOptions ShowArgumentLabels="True" ShowValueLabels="True" ShowArgumentLine="True"
                                      SnapMode="NearestArgument" />
            </dxc:ChartControl.CrosshairOptions>
            <dxc:XYDiagram2D>
                <dxc:XYDiagram2D.AxisX>
                    <dxc:AxisX2D GridLinesVisible="True" GridLinesBrush="#2A2A2A">
                        <dxc:AxisX2D.Label><dxc:AxisLabel Foreground="#B0B0B0" /></dxc:AxisX2D.Label>
                    </dxc:AxisX2D>
                </dxc:XYDiagram2D.AxisX>
                <dxc:XYDiagram2D.AxisY>
                    <dxc:AxisY2D GridLinesVisible="True" GridLinesBrush="#2A2A2A">
                        <dxc:AxisY2D.Label><dxc:AxisLabel Foreground="#B0B0B0" /></dxc:AxisY2D.Label>
                    </dxc:AxisY2D>
                </dxc:XYDiagram2D.AxisY>
                <dxc:XYDiagram2D.SecondaryAxesY>
                    <dxc:SecondaryAxisY2D x:Name="AxisYResolution" Alignment="Far" GridLinesVisible="False">
                        <dxc:SecondaryAxisY2D.Label><dxc:AxisLabel Foreground="#4A7AB5" /></dxc:SecondaryAxisY2D.Label>
                    </dxc:SecondaryAxisY2D>
                    <dxc:SecondaryAxisY2D x:Name="AxisYOpen" Alignment="Far" GridLinesVisible="False">
                        <dxc:SecondaryAxisY2D.Label><dxc:AxisLabel Foreground="#D4A04A" /></dxc:SecondaryAxisY2D.Label>
                    </dxc:SecondaryAxisY2D>
                </dxc:XYDiagram2D.SecondaryAxesY>
                <dxc:BarSideBySideSeries2D x:Name="CreatedSeries" DisplayName="Issues created"
                    ArgumentDataMember="Label" ValueDataMember="Created" CrosshairLabelPattern="{}{S}: {V}">
                    <dxc:BarSideBySideSeries2D.Model><dxc:BorderlessSimpleBar2DModel /></dxc:BarSideBySideSeries2D.Model>
                    <dxc:BarSideBySideSeries2D.Brush><SolidColorBrush Color="#8B3A3A" /></dxc:BarSideBySideSeries2D.Brush>
                </dxc:BarSideBySideSeries2D>
                <dxc:BarSideBySideSeries2D x:Name="CompletedSeries" DisplayName="Issues closed"
                    ArgumentDataMember="Label" ValueDataMember="Completed" CrosshairLabelPattern="{}{S}: {V}">
                    <dxc:BarSideBySideSeries2D.Model><dxc:BorderlessSimpleBar2DModel /></dxc:BarSideBySideSeries2D.Model>
                    <dxc:BarSideBySideSeries2D.Brush><SolidColorBrush Color="#8B9A5B" /></dxc:BarSideBySideSeries2D.Brush>
                </dxc:BarSideBySideSeries2D>
                <dxc:LineSeries2D x:Name="ResolutionSeries" DisplayName="Avg resolution days"
                    ArgumentDataMember="Label" ValueDataMember="AvgResolutionDays"
                    CrosshairLabelPattern="{}{S}: {V:F1} days" MarkerVisible="True">
                    <dxc:LineSeries2D.Brush><SolidColorBrush Color="#4A7AB5" /></dxc:LineSeries2D.Brush>
                    <dxc:LineSeries2D.MarkerModel><dxc:CircleMarker2DModel /></dxc:LineSeries2D.MarkerModel>
                </dxc:LineSeries2D>
                <dxc:LineSeries2D x:Name="OpenSeries" DisplayName="Open issues"
                    ArgumentDataMember="Label" ValueDataMember="OpenCount"
                    CrosshairLabelPattern="{}{S}: {V}" MarkerVisible="True">
                    <dxc:LineSeries2D.Brush><SolidColorBrush Color="#D4A04A" /></dxc:LineSeries2D.Brush>
                    <dxc:LineSeries2D.MarkerModel><dxc:CircleMarker2DModel /></dxc:LineSeries2D.MarkerModel>
                </dxc:LineSeries2D>
                <!-- Cumulative total created (dark red line) -->
                <dxc:LineSeries2D x:Name="TotalCreatedLine" DisplayName="Total created"
                    ArgumentDataMember="Label" ValueDataMember="CumulativeCreated"
                    CrosshairLabelPattern="{}{S}: {V}" MarkerVisible="False" Visible="False">
                    <dxc:LineSeries2D.Brush><SolidColorBrush Color="#8B3A3A" /></dxc:LineSeries2D.Brush>
                </dxc:LineSeries2D>
                <!-- Cumulative total closed (olive green line) -->
                <dxc:LineSeries2D x:Name="TotalClosedLine" DisplayName="Total closed"
                    ArgumentDataMember="Label" ValueDataMember="CumulativeClosed"
                    CrosshairLabelPattern="{}{S}: {V}" MarkerVisible="False" Visible="False">
                    <dxc:LineSeries2D.Brush><SolidColorBrush Color="#8B9A5B" /></dxc:LineSeries2D.Brush>
                </dxc:LineSeries2D>
            </dxc:XYDiagram2D>
            <dxc:ChartControl.Legend>
                <dxc:Legend HorizontalPosition="Center" VerticalPosition="Top" Orientation="Horizontal" Foreground="#B0B0B0" />
            </dxc:ChartControl.Legend>
        </dxc:ChartControl>
    </Grid>
</UserControl>
