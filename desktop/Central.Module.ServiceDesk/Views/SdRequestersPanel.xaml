<UserControl x:Class="Central.Module.ServiceDesk.Views.SdRequestersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid">

    <dxg:GridControl x:Name="ReqGrid" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="ReqView" AllowEditing="False" NavigationStyle="Row"
                           ShowAutoFilterRow="True" SearchPanelNullText="Search requesters..."
                           ShowTotalSummary="True" UseEvenRowBackground="True" ShowGroupPanel="True" />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Name" Header="Name" Width="200" Fixed="Left" />
            <dxg:GridColumn FieldName="Email" Header="Email" Width="220" />
            <dxg:GridColumn FieldName="Phone" Header="Phone" Width="120" />
            <dxg:GridColumn FieldName="Department" Header="Department" Width="150" AllowGrouping="True" />
            <dxg:GridColumn FieldName="Site" Header="Site" Width="120" AllowGrouping="True" />
            <dxg:GridColumn FieldName="JobTitle" Header="Job Title" Width="150" />
            <dxg:GridColumn FieldName="IsVip" Header="VIP" Width="50" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Name" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
