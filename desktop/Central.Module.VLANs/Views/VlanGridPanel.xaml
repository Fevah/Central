<UserControl x:Class="Central.Module.VLANs.Views.VlanGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="VlansGrid" ItemsSource="{Binding VlanEntries}" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="VlansView"
                           ShowGroupPanel="True"
                           AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways"
                           NavigationStyle="Cell"
                           AllowEditing="True"
                           ShowAutoFilterRow="True"
                           SearchPanelNullText="Search..."
                           UseEvenRowBackground="True"
                           CellValueChanged="VlansView_CellValueChanged"
                           ShownEditor="VlansView_ShownEditor"
                           ShowTotalSummary="False">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.IsDefault}" Value="True">
                                <Setter Property="Background" Value="#3322C55E" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Row.IsBlocked}" Value="True">
                                <Setter Property="Background" Value="#55EF4444" />
                                <Setter Property="Foreground" Value="#99999999" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Row.BlockLocked}" Value="True">
                                <Setter Property="Background" Value="#331565C0" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
                <dxg:TableView.GroupRowStyle>
                    <Style TargetType="dxg:GroupRowControl">
                        <Setter Property="Background" Value="#1565C0" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Style>
                </dxg:TableView.GroupRowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="VlanIdSort" Header="Sort"  Width="60"  Fixed="Left"
                            SortIndex="0" SortOrder="Ascending" />
            <dxg:GridColumn FieldName="VlanId"         Header="VLAN"           Width="70"  Fixed="Left" />
            <dxg:GridColumn FieldName="Block"          Header="/21 Block"      Width="130"
                            GroupIndex="0" SortOrder="Ascending" />
            <dxg:GridColumn FieldName="IsDefault"      Header="Default"        Width="60">
                <dxg:GridColumn.EditSettings>
                    <dxe:CheckEditSettings />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Name"           Header="Name"           Width="200" />
            <dxg:GridColumn FieldName="Subnet"         Header="Subnet"         Width="80">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="VlansSubnetCombo" IsTextEditable="False" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Gateway"        Header="Gateway"        Width="140" />
            <dxg:GridColumn FieldName="UsableRange"    Header="Usable Range"   Width="200" />
            <dxg:GridColumn FieldName="Status"         Header="Status"         Width="80">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="VlansStatusCombo" IsTextEditable="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Site"           Header="Site"           Width="100" AllowEditing="False" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="VlanId" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
        <dxg:GridControl.GroupSummary>
            <dxg:GridSummaryItem FieldName="VlanId" SummaryType="Count" DisplayFormat="({0} VLANs)" />
        </dxg:GridControl.GroupSummary>
        <dxg:GridControl.DetailDescriptor>
            <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailSites">
                <dxg:GridControl AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" ShowColumnHeaders="True"
                                       AllowEditing="False" NavigationStyle="Row" ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Building" Header="Site"     Width="120" />
                        <dxg:GridColumn FieldName="VlanName" Header="Name"     Width="150" />
                        <dxg:GridColumn FieldName="Gateway"  Header="Gateway"  Width="130" />
                        <dxg:GridColumn FieldName="Subnet"   Header="Subnet"   Width="80" />
                        <dxg:GridColumn FieldName="Status"   Header="Status"   Width="80" />
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.TotalSummary>
                        <dxg:GridSummaryItem SummaryType="Count" FieldName="Building" DisplayFormat="{}Sites: {0}" />
                    </dxg:GridControl.TotalSummary>
                </dxg:GridControl>
            </dxg:DataControlDetailDescriptor>
        </dxg:GridControl.DetailDescriptor>
    </dxg:GridControl>
</UserControl>
