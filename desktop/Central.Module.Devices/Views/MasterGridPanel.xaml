<UserControl x:Class="Central.Module.Devices.Views.MasterGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:GridControl x:Name="MasterGrid"
                     ItemsSource="{Binding MasterDevices}"
                     AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="MasterView"
                           ShowGroupPanel="True"
                           AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways"
                           NavigationStyle="Row"
                           AllowEditing="False"
                           ShowAutoFilterRow="True"
                           UseEvenRowBackground="True"
                           ShowTotalSummary="False">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                                <Setter Property="Background" Value="#FDE9D9" />
                                <Setter Property="Foreground" Value="#7A3B1E" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="DeviceName"     Header="Device"       Width="190" Fixed="Left" />
            <dxg:GridColumn FieldName="DeviceType"     Header="Type"         Width="140" AllowGrouping="True" />
            <dxg:GridColumn FieldName="Status"         Header="Status"       Width="90"  AllowGrouping="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="MasterStatusCombo" IsTextEditable="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Building"       Header="Building"     Width="100" AllowGrouping="True" />
            <dxg:GridColumn FieldName="Region"         Header="Region"       Width="80"  AllowGrouping="True" />
            <dxg:GridColumn FieldName="PrimaryIp"      Header="Primary IP"   Width="130" />
            <dxg:GridColumn FieldName="ManagementIp"   Header="Mgmt IP"      Width="130" />
            <dxg:GridColumn FieldName="LoopbackIp"     Header="Loopback"     Width="130" />
            <dxg:GridColumn FieldName="LoopbackSubnet" Header="Loop Subnet"  Width="140" />
            <dxg:GridColumn FieldName="MgmtL3Ip"      Header="Mgmt L3"      Width="130" />
            <dxg:GridColumn FieldName="Asn" Header="ASN" Width="80" AllowGrouping="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="MasterAsnCombo"
                                              ValueMember="Asn" DisplayMember="Asn"
                                              IsTextEditable="True" ImmediatePopup="True"
                                              AutoComplete="True" IncrementalFiltering="True"
                                              PopupMaxHeight="350" PopupMinWidth="550">
                        <dxe:ComboBoxEditSettings.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Asn}" FontWeight="SemiBold" Margin="4,2" />
                                    <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="#90CAF9" Margin="4,2" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding DeviceCount, StringFormat='{}{0} dev'}" Foreground="#888" Margin="4,2" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </dxe:ComboBoxEditSettings.ItemTemplate>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="MlagDomain"     Header="MLAG"         Width="70" />
            <dxg:GridColumn FieldName="MlagPeer"       Header="MLAG Peer"    Width="170" />
            <dxg:GridColumn FieldName="MstpPriority"   Header="MSTP"         Width="70" />
            <dxg:GridColumn FieldName="P2PLinkCount"   Header="P2P"          Width="55" />
            <dxg:GridColumn FieldName="B2BLinkCount"   Header="B2B"          Width="55" />
            <dxg:GridColumn FieldName="FWLinkCount"    Header="FW"           Width="55" />
            <dxg:GridColumn FieldName="HasConfig"      Header="Config"       Width="65" />
            <dxg:GridColumn FieldName="AeRange"        Header="AE Range"     Width="90" />
            <dxg:GridColumn FieldName="Model"          Header="Model"        Width="130" />
            <dxg:GridColumn FieldName="SerialNumber"   Header="Serial"       Width="130" />
            <dxg:GridColumn FieldName="UplinkSwitch"   Header="Uplink"       Width="170" />
            <dxg:GridColumn FieldName="UplinkPort"     Header="Uplink Port"  Width="100" />
            <dxg:GridColumn FieldName="Notes"          Header="Notes"        Width="200" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="DeviceName" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
    </dxg:GridControl>
</UserControl>
