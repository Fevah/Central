<UserControl x:Class="Central.Module.Admin.Views.LookupsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <dxg:TreeListControl x:Name="AdminGrid"
                         ItemsSource="{Binding LookupItems}"
                         AutoGenerateColumns="None"
                         CurrentItem="{Binding SelectedLookup, Mode=TwoWay}">
        <dxg:TreeListControl.View>
            <dxg:TreeListView x:Name="AdminView"
                              KeyFieldName="Id"
                              ParentFieldName="ParentId"
                              AllowColumnFiltering="True"
                              ShowFilterPanelMode="ShowAlways"
                              NavigationStyle="Row"
                              AllowEditing="True"
                              NewItemRowPosition="Top"
                              ShowAutoFilterRow="True" />
        </dxg:TreeListControl.View>
        <dxg:TreeListControl.Columns>
            <dxg:TreeListColumn FieldName="Id"        Header="ID"         Width="60"  ReadOnly="True" />
            <dxg:TreeListColumn FieldName="Category"  Header="Category"   Width="160">
                <dxg:TreeListColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True">
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="status" />
                            <dxe:ComboBoxEditItem Content="device_type" />
                            <dxe:ComboBoxEditItem Content="building" />
                            <dxe:ComboBoxEditItem Content="region" />
                            <dxe:ComboBoxEditItem Content="nic_status" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:TreeListColumn.EditSettings>
            </dxg:TreeListColumn>
            <dxg:TreeListColumn FieldName="Value"      Header="Value"      Width="220" />
            <dxg:TreeListColumn FieldName="GridName"   Header="Grid"       Width="260">
                <dxg:TreeListColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True">
                        <dxe:ComboBoxEditSettings.StyleSettings>
                            <dxe:CheckedComboBoxStyleSettings />
                        </dxe:ComboBoxEditSettings.StyleSettings>
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="Devices" />
                            <dxe:ComboBoxEditItem Content="Master" />
                            <dxe:ComboBoxEditItem Content="ASN" />
                            <dxe:ComboBoxEditItem Content="P2P" />
                            <dxe:ComboBoxEditItem Content="B2B" />
                            <dxe:ComboBoxEditItem Content="FW" />
                            <dxe:ComboBoxEditItem Content="VLANs" />
                            <dxe:ComboBoxEditItem Content="MLAG" />
                            <dxe:ComboBoxEditItem Content="MSTP" />
                            <dxe:ComboBoxEditItem Content="Server AS" />
                            <dxe:ComboBoxEditItem Content="IP Ranges" />
                            <dxe:ComboBoxEditItem Content="Servers" />
                            <dxe:ComboBoxEditItem Content="Switches" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:TreeListColumn.EditSettings>
            </dxg:TreeListColumn>
            <dxg:TreeListColumn FieldName="Module"     Header="Module"     Width="160">
                <dxg:TreeListColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True">
                        <dxe:ComboBoxEditSettings.StyleSettings>
                            <dxe:CheckedComboBoxStyleSettings />
                        </dxe:ComboBoxEditSettings.StyleSettings>
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="devices" />
                            <dxe:ComboBoxEditItem Content="switches" />
                            <dxe:ComboBoxEditItem Content="admin" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:TreeListColumn.EditSettings>
            </dxg:TreeListColumn>
            <dxg:TreeListColumn FieldName="SortOrder"  Header="Sort Order" Width="90" />
        </dxg:TreeListControl.Columns>
    </dxg:TreeListControl>
</UserControl>
