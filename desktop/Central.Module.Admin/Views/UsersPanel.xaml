<UserControl x:Class="Central.Module.Admin.Views.UsersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">

    <UserControl.Resources>
        <Style x:Key="InactiveRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.IsActive}" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Row.IsProtected}" Value="True">
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <dxg:GridControl x:Name="UsersGrid"
                     ItemsSource="{Binding Users}"
                     CurrentItem="{Binding SelectedUser, Mode=TwoWay}"
                     AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="UsersView"
                           ShowGroupPanel="False"
                           AllowColumnFiltering="True"
                           NavigationStyle="Cell"
                           AllowEditing="True"
                           NewItemRowPosition="Top"
                           RowStyle="{StaticResource InactiveRowStyle}"
                           UseEvenRowBackground="True"
                           ShowTotalSummary="True"
                           ShowAutoFilterRow="True"
                           SearchPanelNullText="Search..." />
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="Username"    Header="Username"     Width="150" Fixed="Left" />
            <dxg:GridColumn FieldName="DisplayName" Header="Display Name" Width="170" />
            <dxg:GridColumn FieldName="Email"       Header="Email"        Width="180" />
            <dxg:GridColumn FieldName="Role"        Header="Role"         Width="110">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="UserRoleCombo" IsTextEditable="False" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="UserType"    Header="Type"         Width="110">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="False">
                        <dxe:ComboBoxEditSettings.Items>
                            <dxe:ComboBoxEditItem Content="System" />
                            <dxe:ComboBoxEditItem Content="Admin" />
                            <dxe:ComboBoxEditItem Content="Standard" />
                            <dxe:ComboBoxEditItem Content="ActiveDirectory" />
                            <dxe:ComboBoxEditItem Content="Service" />
                        </dxe:ComboBoxEditSettings.Items>
                    </dxe:ComboBoxEditSettings>
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Department"  Header="Department"   Width="130" />
            <dxg:GridColumn FieldName="Title"       Header="Title"        Width="130" />
            <dxg:GridColumn FieldName="Company"     Header="Company"      Width="130" />
            <dxg:GridColumn FieldName="Phone"       Header="Phone"        Width="110" />
            <dxg:GridColumn FieldName="Mobile"      Header="Mobile"       Width="110" />
            <dxg:GridColumn FieldName="IsActive"    Header="Active"       Width="65" />
            <dxg:GridColumn FieldName="AutoLogin"   Header="Auto Login"   Width="80" />
            <dxg:GridColumn FieldName="AdGuid"      Header="AD GUID"      Width="120" ReadOnly="True" Visible="False" />
            <dxg:GridColumn FieldName="LastAdSync"  Header="Last AD Sync" Width="140" ReadOnly="True" Visible="False" />
            <dxg:GridColumn FieldName="LastLoginAt"  Header="Last Login"   Width="140" ReadOnly="True" />
            <dxg:GridColumn FieldName="LoginCount"   Header="Logins"       Width="60"  ReadOnly="True" />
            <dxg:GridColumn FieldName="CreatedAt"    Header="Created"      Width="140" ReadOnly="True" />
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="Username" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
        <dxg:GridControl.DetailDescriptor>
            <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailPermissions">
                <dxg:GridControl AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="True" ShowColumnHeaders="True"
                                       AllowEditing="False" NavigationStyle="Row" ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Category" Header="Module"     Width="100" AllowGrouping="True" />
                        <dxg:GridColumn FieldName="Code"     Header="Permission" Width="150" />
                        <dxg:GridColumn FieldName="Name"     Header="Description" Width="200" />
                        <dxg:GridColumn FieldName="Granted"  Header="Granted"    Width="70" />
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.TotalSummary>
                        <dxg:GridSummaryItem SummaryType="Count" FieldName="Code" DisplayFormat="{}Permissions: {0}" />
                    </dxg:GridControl.TotalSummary>
                </dxg:GridControl>
            </dxg:DataControlDetailDescriptor>
        </dxg:GridControl.DetailDescriptor>
    </dxg:GridControl>
</UserControl>
