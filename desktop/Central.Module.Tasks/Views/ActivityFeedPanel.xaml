<UserControl x:Class="Central.Module.Tasks.Views.ActivityFeedPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
            <TextBlock Text="Project:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,4,0" />
            <dxe:ComboBoxEdit x:Name="ProjectSelector" Width="180" Height="24" NullText="All Projects"
                               IsTextEditable="False" EditValueChanged="ProjectSelector_Changed"
                               DisplayMember="Name" ValueMember="Id" />
            <Button Content="Refresh" Padding="10,4" Margin="8,0,0,0" Click="Refresh_Click" />
        </StackPanel>
        <ListBox x:Name="FeedList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="4,2" Padding="8,6" Background="#1E293B" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ActionIcon}" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="#60A5FA" />
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="{Binding Summary}" Foreground="White" FontSize="12" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding UserName}" Foreground="#6B7280" FontSize="10" Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" Foreground="#4B5563" FontSize="10"
                                       VerticalAlignment="Top" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
