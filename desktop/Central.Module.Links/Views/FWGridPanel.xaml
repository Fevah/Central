<UserControl x:Class="Central.Module.Links.Views.FWGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors">
    <UserControl.Resources>
        <ResourceDictionary>
            <conv:StringToBrushConverter x:Key="StringToBrush"
                xmlns:conv="clr-namespace:Central.Core.Converters;assembly=Central.Core" />
        </ResourceDictionary>
    </UserControl.Resources>

    <dxg:GridControl x:Name="FWGrid" ItemsSource="{Binding FWLinks}" AutoGenerateColumns="None">
        <dxg:GridControl.View>
            <dxg:TableView x:Name="FWView" ShowGroupPanel="True" AllowColumnFiltering="True"
                           ShowFilterPanelMode="ShowAlways" NavigationStyle="Cell"
                           AllowEditing="True" ShowAutoFilterRow="True" SearchPanelNullText="Search..."
                           ShowTotalSummary="False" UseEvenRowBackground="True"
                           ValidateRow="FWView_ValidateRow"
                           CellValueChanged="FWView_CellValueChanged">
                <dxg:TableView.RowStyle>
                    <Style TargetType="dxg:RowControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                                <Setter Property="Foreground" Value="#808080" />
                                <Setter Property="FontStyle" Value="Italic" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </dxg:TableView.RowStyle>
            </dxg:TableView>
        </dxg:GridControl.View>
        <dxg:GridControl.Columns>
            <dxg:GridColumn FieldName="ValidationIcon" Header="" Width="30" AllowEditing="False"
                            AllowColumnFiltering="False" HorizontalHeaderContentAlignment="Center">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding RowData.Row.ValidationIcon}"
                                   Foreground="{Binding RowData.Row.ValidationColor, Converter={StaticResource StringToBrush}}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   ToolTip="{Binding RowData.Row.ValidationTooltip}" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="Building"     Header="Building"     Width="100" AllowGrouping="True">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="FWBuildingCombo" IsTextEditable="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="LinkId"       Header="Link ID"      Width="80" Fixed="Left" />
            <dxg:GridColumn FieldName="Vlan"         Header="VLAN"         Width="70" />
            <!-- Switch side -->
            <dxg:GridColumn FieldName="Switch"       Header="Switch"       Width="170">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="SwitchPort"   Header="Switch Port"  Width="120">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True"
                                              AutoComplete="True"
                                              ValueMember="InterfaceName"
                                              DisplayMember="InterfaceName" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="SwitchIp"     Header="Switch IP"    Width="130" />
            <dxg:GridColumn FieldName="ConfigA" Header="Cfg SW" Width="55" AllowEditing="False" AllowSorting="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="&#x2699;" FontSize="14" Padding="2" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Foreground="#90CAF9"
                                Tag="A" Click="ConfigCog_Click" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <!-- Firewall side -->
            <dxg:GridColumn FieldName="Firewall"     Header="Firewall"     Width="170">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True" AutoComplete="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="FirewallPort" Header="FW Port"      Width="120">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings IsTextEditable="True" ImmediatePopup="True"
                                              AutoComplete="True"
                                              ValueMember="InterfaceName"
                                              DisplayMember="InterfaceName" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
            <dxg:GridColumn FieldName="FirewallIp"   Header="FW IP"        Width="130" />
            <dxg:GridColumn FieldName="ConfigB" Header="Cfg FW" Width="55" AllowEditing="False" AllowSorting="False">
                <dxg:GridColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="&#x2699;" FontSize="14" Padding="2" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" Foreground="#90CAF9"
                                Tag="B" Click="ConfigCog_Click" />
                    </DataTemplate>
                </dxg:GridColumn.CellTemplate>
            </dxg:GridColumn>
            <!-- Link details -->
            <dxg:GridColumn FieldName="Subnet"       Header="Subnet"       Width="130" />
            <dxg:GridColumn FieldName="Status"       Header="Status"       Width="80">
                <dxg:GridColumn.EditSettings>
                    <dxe:ComboBoxEditSettings x:Name="FWStatusCombo" IsTextEditable="True" />
                </dxg:GridColumn.EditSettings>
            </dxg:GridColumn>
        </dxg:GridControl.Columns>
        <dxg:GridControl.TotalSummary>
            <dxg:GridSummaryItem SummaryType="Count" FieldName="DeviceA" DisplayFormat="{}Total: {0}" />
        </dxg:GridControl.TotalSummary>
        <dxg:GridControl.DetailDescriptor>
            <dxg:DataControlDetailDescriptor ItemsSourcePath="DetailConfigLines">
                <dxg:GridControl AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView ShowGroupPanel="False" ShowColumnHeaders="True"
                                       AllowEditing="False" NavigationStyle="Row" ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Side"    Header="Switch"  Width="180" AllowGrouping="True" />
                        <dxg:GridColumn FieldName="Command" Header="PicOS Command" Width="600">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RowData.Row.Command}"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                               Foreground="#81C784" />
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.TotalSummary>
                        <dxg:GridSummaryItem SummaryType="Count" FieldName="Command" DisplayFormat="{}Commands: {0}" />
                    </dxg:GridControl.TotalSummary>
                </dxg:GridControl>
            </dxg:DataControlDetailDescriptor>
        </dxg:GridControl.DetailDescriptor>
    </dxg:GridControl>
</UserControl>
