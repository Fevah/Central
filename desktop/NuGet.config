<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="DevExpress" value="https://nuget.devexpress.com/WfTygbMUTRRTBswwwjXlZCPghcbel7RNgz797YAfgXQJG2FIAR/api/v3/index.json" />
    <add key="DevExpress-Offline" value="packages-offline" />
  </packageSources>
  <!-- Note: DX NuGet key is a per-license feed URL, not a secret API key.
       It identifies the license holder, not an auth credential.
       Safe to commit for internal repos. For public repos, use DEVEXPRESS_NUGET_KEY env var. -->
</configuration>
