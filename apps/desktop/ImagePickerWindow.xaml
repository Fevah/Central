<dx:DXDialogWindow x:Class="Central.Desktop.ImagePickerWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   Title="Select Icon"
                   Width="750" Height="620"
                   WindowStartupLocation="CenterOwner"
                   ResizeMode="CanResize">
    <dx:DXDialogWindow.Resources>
        <ItemsPanelTemplate x:Key="HorizontalWrap">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </dx:DXDialogWindow.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left: Icon Sets | Right: Search + Gallery -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Packs + Categories (both multi-select checkboxes) -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Packs" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0" />
                </StackPanel>
                <dxe:ListBoxEdit x:Name="PackList" DockPanel.Dock="Top" Height="80" Margin="0,0,0,6"
                                  SelectionMode="Multiple" ShowBorder="True"
                                  EditValueChanged="PackList_Changed">
                    <dxe:ListBoxEdit.StyleSettings>
                        <dxe:CheckedListBoxEditStyleSettings />
                    </dxe:ListBoxEdit.StyleSettings>
                </dxe:ListBoxEdit>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Categories" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button Content="All" Click="SelectAllCategories_Click" Padding="6,1" FontSize="10" Margin="0,0,2,0" />
                    <Button Content="None" Click="ClearAllCategories_Click" Padding="6,1" FontSize="10" />
                </StackPanel>
                <dxe:ListBoxEdit x:Name="CategoryList"
                                  SelectionMode="Multiple"
                                  ShowBorder="True"
                                  EditValueChanged="CategoryList_EditValueChanged">
                    <dxe:ListBoxEdit.StyleSettings>
                        <dxe:CheckedListBoxEditStyleSettings />
                    </dxe:ListBoxEdit.StyleSettings>
                </dxe:ListBoxEdit>
            </DockPanel>

            <!-- Right: Search + Gallery -->
            <DockPanel Grid.Column="1">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <dxe:TextEdit x:Name="SearchBox" Width="300" Height="26"
                                   NullText="Search icons..."
                                   EditValueChanged="Filter_Changed" />
                    <TextBlock x:Name="CountLabel" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="#9CA3AF" FontSize="11" />
                </StackPanel>

                <ListBox x:Name="IconList"
                 Background="#1E1E1E" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="IconList_MouseDoubleClick"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="64" Height="72" Margin="3" Padding="4"
                            Background="#2D2D3D" CornerRadius="4"
                            ToolTip="{Binding TooltipText}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center">
                                <Image Source="{Binding ImageSource}" Width="32" Height="32"
                                       HorizontalAlignment="Center" Margin="0,4,0,2" />
                                <TextBlock Text="{Binding ShortName}" FontSize="8"
                                           Foreground="#9CA3AF" HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="56" />
                            </StackPanel>
                            <TextBlock Text="{Binding PackLabel}" FontSize="7"
                                       Foreground="#6B7280" HorizontalAlignment="Right"
                                       VerticalAlignment="Top" Margin="0,1,2,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Delete Selected" Width="110" Height="28" Margin="0,0,8,0"
                    Click="DeleteIcon_Click" Foreground="#EF4444" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Width="300">
                <Button Content="Clear Icon" Width="90" Height="28" Margin="0,0,8,0" Click="ClearIcon_Click" />
                <Button Content="Select" Width="80" Height="28" Margin="0,0,8,0" Click="SelectIcon_Click" IsDefault="True" />
                <Button Content="Cancel" Width="80" Height="28" IsCancel="True" />
            </StackPanel>
        </StackPanel>
    </Grid>
</dx:DXDialogWindow>
