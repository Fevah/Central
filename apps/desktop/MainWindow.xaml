<dxr:DXRibbonWindow
    x:Class="Central.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxdiag="http://schemas.devexpress.com/winfx/2008/xaml/diagram"
    xmlns:vm="clr-namespace:Central.Desktop.ViewModels"
    xmlns:conv="clr-namespace:Central.Engine.Converters;assembly=Central.Engine"
    xmlns:devViews="clr-namespace:Central.Module.Devices.Views;assembly=Central.Module.Devices"
    xmlns:linkViews="clr-namespace:Central.Module.Networking.Links;assembly=Central.Module.Networking"
    xmlns:swViews="clr-namespace:Central.Module.Networking.Switches;assembly=Central.Module.Networking"
    xmlns:rtViews="clr-namespace:Central.Module.Networking.Routing;assembly=Central.Module.Networking"
    xmlns:vlViews="clr-namespace:Central.Module.Networking.Vlans;assembly=Central.Module.Networking"
    xmlns:admViews="clr-namespace:Central.Module.Admin.Views;assembly=Central.Module.Admin"
    xmlns:sdViews="clr-namespace:Central.Module.ServiceDesk.Views;assembly=Central.Module.ServiceDesk"
    xmlns:taskViews="clr-namespace:Central.Module.Projects;assembly=Central.Module.Projects"
    xmlns:gaViews="clr-namespace:Central.Module.GlobalAdmin.Views;assembly=Central.Module.GlobalAdmin"
    xmlns:local="clr-namespace:Central.Desktop.Views"
    Title="Central"
    Icon="pack://application:,,,/central.png"
    Width="1440" Height="900"
    WindowStartupLocation="CenterScreen">

    <dxr:DXRibbonWindow.DataContext>
        <vm:MainViewModel />
    </dxr:DXRibbonWindow.DataContext>

    <dxr:DXRibbonWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
        <conv:NullToBoolConverter x:Key="NullToBoolConverter" />
        <conv:StringToBrushConverter x:Key="StringToBrush" />
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            <Setter Property="FontSize"    Value="10" />
            <Setter Property="Margin"      Value="0,0,0,1" />
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ReservedRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Cell style for NIC columns when their NIC status is RESERVED -->
        <Style x:Key="Nic1ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic1Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nic2ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic2Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nic3ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic3Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nic4ReservedCell" TargetType="dxg:LightweightCellEditor">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Nic4Status}" Value="RESERVED">
                    <Setter Property="Background" Value="#FDE9D9" />
                    <Setter Property="Foreground" Value="#7A3B1E" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- SSH Log row style: red for failed, green tint for success -->
        <Style x:Key="SshLogRowStyle" TargetType="dxg:RowControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Row.Success}" Value="False">
                    <Setter Property="Background" Value="#3C1414" />
                    <Setter Property="Foreground" Value="#FF8888" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Row.Success}" Value="True">
                    <Setter Property="Background" Value="#143C14" />
                    <Setter Property="Foreground" Value="#88FF88" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </dxr:DXRibbonWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Ribbon -->
            <RowDefinition Height="*"    />   <!-- Content -->
            <RowDefinition Height="24"   />   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ RIBBON ═══ -->
        <dxr:RibbonControl x:Name="Ribbon" Grid.Row="0" RibbonStyle="Office2019"
                           ToolbarShowMode="ShowAbove" AllowCustomization="True">

            <!-- ═══ Quick Access Toolbar ═══ -->
            <dxr:RibbonControl.ToolbarItems>
                <dxb:BarButtonItem Content="Save Layout"
                                   Glyph="{dx:DXImage Image=Save_16x16}"
                                   ItemClick="GlobalSaveLayout_ItemClick" />
                <dxb:BarButtonItem Content="Refresh"
                                   Glyph="{dx:DXImage Image=Refresh_16x16}"
                                   ItemClick="RefreshButton_ItemClick" />
                <dxb:BarButtonItem Content="Undo"
                                   Glyph="{dx:DXImage Image=Undo_16x16}"
                                   ItemClick="UndoButton_ItemClick" />
            </dxr:RibbonControl.ToolbarItems>

            <!-- ═══ Backstage (File menu) ═══ -->
            <dxr:RibbonControl.ApplicationMenu>
                <dxr:BackstageViewControl>
                    <!-- User Profile -->
                    <dxr:BackstageTabItem x:Name="BackstageUserTab" Content="User Profile"
                                          Glyph="{dx:DXImage Image=BOUser_16x16}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24" MaxWidth="600">
                            <TextBlock Text="User Profile" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />

                            <!-- Identity card -->
                            <Border Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                                            Background="#3B82F6" VerticalAlignment="Top" Margin="0,0,12,0">
                                        <TextBlock x:Name="BackstageInitials" Text="CS" FontSize="18" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="BackstageDisplayName" Text="" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock x:Name="BackstageUsername" Text="" FontSize="12"
                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                        <TextBlock x:Name="BackstageRole" Text="" FontSize="12" Margin="0,4,0,0"
                                                   Foreground="#3B82F6" FontWeight="SemiBold" />
                                        <TextBlock x:Name="BackstageEmail" Text="" FontSize="11" Margin="0,2,0,0"
                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Session info -->
                            <TextBlock Text="SESSION" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Login Type:" Width="110" />
                                <TextBlock x:Name="BackstageLoginType" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Permissions:" Width="110" />
                                <TextBlock x:Name="BackstagePermCount" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Sites:" Width="110" />
                                <TextBlock x:Name="BackstageSites" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- Layout & Settings -->
                            <TextBlock Text="SETTINGS" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="BackstageSaveLayout" Content="Save Layout" Width="130" Height="28" Margin="0,0,8,0" />
                                <Button x:Name="BackstageResetLayout" Content="Reset Layout" Width="130" Height="28" Margin="0,0,8,0" />
                                <Button x:Name="BackstageCloseAllPanels" Content="Close All Panels" Width="140" Height="28" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="BackstageOpenDefaultPanels" Content="Open Default Panels" Width="160" Height="28" Margin="0,0,8,0" />
                                <Button x:Name="BackstageRefreshData" Content="Refresh All Data" Width="140" Height="28" />
                            </StackPanel>
                            <CheckBox x:Name="BackstageHideReserved" Content="Hide reserved devices" Margin="0,8,0,4"
                                      IsChecked="{Binding HideReserved, Mode=TwoWay}" />
                            <CheckBox x:Name="BackstageAutoScan" Content="Enable auto ping scan" Margin="0,4,0,4"
                                      IsChecked="{Binding IsScanEnabled, Mode=TwoWay}" />

                            <!-- Recent Activity -->
                            <TextBlock Text="RECENT ACTIVITY" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,16,0,8" />
                            <ListView x:Name="BackstageRecentActivity" Height="150"
                                      Background="Transparent" BorderThickness="0"
                                      Foreground="#D4D4D4" FontSize="11">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="" Width="24" DisplayMemberBinding="{Binding Icon}" />
                                        <GridViewColumn Header="Time" Width="70" DisplayMemberBinding="{Binding Time}" />
                                        <GridViewColumn Header="Event" Width="350" DisplayMemberBinding="{Binding Title}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                        </ScrollViewer>
                    </dxr:BackstageTabItem>

                    <!-- Theme -->
                    <dxr:BackstageTabItem x:Name="BackstageThemeTab" Content="Theme"
                                          Glyph="{dx:DXImage Image=ChangeFontStyle_16x16}">
                        <StackPanel Margin="24">
                            <TextBlock Text="Application Theme" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />
                            <TextBlock Text="Select a theme to change the appearance of the application."
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       Margin="0,0,0,16" />
                            <dxb:GalleryControl x:Name="BackstageThemeGallery">
                                <dxb:GalleryControl.Gallery>
                                    <dxb:Gallery AllowFilter="True" ColCount="4" RowCount="8" />
                                </dxb:GalleryControl.Gallery>
                            </dxb:GalleryControl>
                        </StackPanel>
                    </dxr:BackstageTabItem>

                    <!-- Connection -->
                    <dxr:BackstageTabItem x:Name="BackstageConnectionTab" Content="Connection"
                                          Glyph="{dx:DXImage Image=Database_16x16}">
                        <StackPanel Margin="24" MaxWidth="500">
                            <TextBlock Text="Connection Settings" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Mode:" Width="100" />
                                <TextBlock x:Name="BackstageConnMode" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Database:" Width="100" />
                                <TextBlock x:Name="BackstageConnDb" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Status:" Width="100" />
                                <TextBlock x:Name="BackstageConnStatus" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="API Server:" Width="100" />
                                <TextBlock x:Name="BackstageApiUrl" FontWeight="SemiBold" Text="Not configured" />
                            </StackPanel>

                            <TextBlock Text="DATA MODE" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,16,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="ModeDirectDbButton" Content="Direct DB (Standalone)"
                                        Padding="12,6" Margin="0,0,8,0" />
                                <Button x:Name="ModeApiButton" Content="API Server (Multi-user)"
                                        Padding="12,6" Margin="0,0,8,0" />
                                <Button x:Name="ModeTestApiButton" Content="Test API Connection"
                                        Padding="12,6" />
                            </StackPanel>
                            <TextBlock x:Name="BackstageModeStatus" Text="" FontSize="11" Margin="0,4,0,0"
                                       Foreground="#22C55E" />
                        </StackPanel>
                    </dxr:BackstageTabItem>

                    <!-- Settings -->
                    <dxr:BackstageTabItem x:Name="BackstageSettingsTab" Content="Settings"
                                          Glyph="{dx:DXImage Image=EditDataSource_16x16}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="BackstageSettingsPanel" Margin="24" MaxWidth="600">
                                <TextBlock Text="Module Settings" FontSize="22" FontWeight="Bold" Margin="0,0,0,8" />
                                <TextBlock Text="Settings are saved per user and persist across sessions."
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                           Margin="0,0,0,16" />
                                <!-- Dynamically populated by PopulateSettingsPanel() -->
                            </StackPanel>
                        </ScrollViewer>
                    </dxr:BackstageTabItem>

                    <!-- About -->
                    <dxr:BackstageTabItem Content="About"
                                          Glyph="{dx:DXImage Image=About_16x16}">
                        <StackPanel Margin="24" MaxWidth="500">
                            <TextBlock Text="Central" FontSize="28" FontWeight="Bold" Margin="0,0,0,4" />
                            <TextBlock Text="Enterprise Infrastructure Platform" FontSize="14"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,16" />
                            <TextBlock Text="Version 5.0 — Enterprise Desktop" FontSize="12" Margin="0,0,0,4" />
                            <TextBlock Text=".NET 10 · DevExpress 25.2 · PostgreSQL 18 · Podman" FontSize="11"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,16" />
                            <TextBlock Text="Network infrastructure, service desk, and IT operations management." FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock Text="11 projects · 23 module panels · JWT API · SignalR real-time" FontSize="11"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                        </StackPanel>
                    </dxr:BackstageTabItem>

                    <!-- Separator + buttons -->
                    <dxr:BackstageSeparatorItem />
                    <dxr:BackstageButtonItem x:Name="BackstageLogout" Content="Switch User"
                                             Glyph="{dx:DXImage Image=Security_Permission_16x16}" />
                    <dxr:BackstageButtonItem x:Name="BackstageExit" Content="Exit"
                                             Glyph="{dx:DXImage Image=Close_16x16}" />
                </dxr:BackstageViewControl>
            </dxr:RibbonControl.ApplicationMenu>

            <dxr:RibbonDefaultPageCategory x:Name="DefaultRibbonCategory">

                <!-- ── Home Tab ── -->
                <dxr:RibbonPage Caption="Home">
                    <dxr:RibbonPageGroup Caption="Undo">
                        <dxb:BarSplitButtonItem x:Name="UndoButton" Content="Undo"
                                           LargeGlyph="{dx:DXImage Image=Undo_32x32}"
                                           RibbonStyle="Large"
                                           IsEnabled="False"
                                           ItemClick="UndoButton_ItemClick" />
                        <dxb:BarSplitButtonItem x:Name="RedoButton" Content="Redo"
                                           LargeGlyph="{dx:DXImage Image=Redo_32x32}"
                                           RibbonStyle="Large"
                                           IsEnabled="False"
                                           ItemClick="RedoButton_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Actions">
                        <dxb:BarButtonItem Content="Add"
                                           LargeGlyph="{dx:DXImage Image=AddItem_32x32}"
                                           RibbonStyle="Large"
                                           ItemClick="GlobalAdd_ItemClick" />
                        <dxb:BarButtonItem Content="Delete"
                                           LargeGlyph="{dx:DXImage Image=Delete_32x32}"
                                           RibbonStyle="Large"
                                           ItemClick="GlobalDelete_ItemClick" />
                        <dxb:BarButtonItem Content="Edit"
                                           LargeGlyph="{dx:DXImage Image=Edit_32x32}"
                                           RibbonStyle="Large"
                                           ItemClick="GlobalEdit_ItemClick" />
                        <dxb:BarButtonItem Content="Refresh"
                                           LargeGlyph="{dx:DXImage Image=Refresh_32x32}"
                                           RibbonStyle="Large"
                                           ItemClick="RefreshButton_ItemClick" />
                        <dxb:BarButtonItem Content="Bulk Edit"
                                           Glyph="{dx:DXImage Image=EditDataSource_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="BulkEditButton_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Row">
                        <dxb:BarButtonItem Content="Move Up"
                                           Glyph="{dx:DXImage Image=MoveUp_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalMoveUp_ItemClick" />
                        <dxb:BarButtonItem Content="Move Down"
                                           Glyph="{dx:DXImage Image=MoveDown_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalMoveDown_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Filter">
                        <dxb:BarButtonItem Content="Clear Filter"
                                           Glyph="{dx:DXImage Image=ClearFilter_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalClearFilter_ItemClick" />
                        <dxb:BarCheckItem x:Name="GlobalAutoFilterToggle"
                                          Content="Filter Row"
                                          Glyph="{dx:DXImage Image=ShowAutoFilter_16x16}"
                                          RibbonStyle="SmallWithText"
                                          IsChecked="True"
                                          CheckedChanged="GlobalAutoFilter_CheckedChanged" />
                        <dxb:BarItemSeparator />
                        <dxb:BarButtonItem Content="Save Filter"
                                           Glyph="{dx:DXImage Image=Save_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="SaveFilter_ItemClick" />
                        <dxb:BarSplitButtonItem x:Name="LoadFilterSplit" Content="Load Filter"
                                                Glyph="{dx:DXImage Image=LoadFrom_16x16}"
                                                RibbonStyle="SmallWithText"
                                                ItemClick="LoadFilter_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Group">
                        <dxb:BarButtonItem Content="Expand All"
                                           Glyph="{dx:DXImage Image=ExpandAll_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalExpandAll_ItemClick" />
                        <dxb:BarButtonItem Content="Collapse All"
                                           Glyph="{dx:DXImage Image=CollapseAll_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalCollapseAll_ItemClick" />
                        <dxb:BarButtonItem Content="Clear Grouping"
                                           Glyph="{dx:DXImage Image=ClearGrouping_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalClearGrouping_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Layout">
                        <dxb:BarButtonItem Content="Save Layout"
                                           Glyph="{dx:DXImage Image=Save_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalSaveLayout_ItemClick" />
                        <dxb:BarButtonItem Content="Reset Layout"
                                           Glyph="{dx:DXImage Image=Reset_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="GlobalResetLayout_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="View">
                        <dxb:BarCheckItem x:Name="ToggleSearchPanel" Content="Search Panel"
                                          Glyph="{dx:DXImage Image=Find_16x16}"
                                          RibbonStyle="SmallWithText"
                                          IsChecked="False"
                                          CheckedChanged="ToggleSearchPanel_CheckedChanged" />
                        <dxb:BarCheckItem x:Name="ToggleAutoFilter" Content="Filter Row"
                                          Glyph="{dx:DXImage Image=ShowAutoFilter_16x16}"
                                          RibbonStyle="SmallWithText"
                                          IsChecked="True"
                                          CheckedChanged="ToggleAutoFilter_CheckedChanged" />
                        <dxb:BarCheckItem x:Name="ToggleGroupPanel" Content="Group Panel"
                                          Glyph="{dx:DXImage Image=GroupBy_16x16}"
                                          RibbonStyle="SmallWithText"
                                          IsChecked="True"
                                          CheckedChanged="ToggleGroupPanel_CheckedChanged" />
                        <dxb:BarCheckItem x:Name="ToggleGridLines" Content="Grid Lines"
                                          Glyph="{dx:DXImage Image=Grid_16x16}"
                                          RibbonStyle="SmallWithText"
                                          IsChecked="False"
                                          CheckedChanged="ToggleGridLines_CheckedChanged" />
                        <dxb:BarCheckItem x:Name="ToggleSummary" Content="Summary Row"
                                          Glyph="{dx:DXImage Image=Sum_16x16}"
                                          RibbonStyle="SmallWithText"
                                          IsChecked="False"
                                          CheckedChanged="ToggleSummary_CheckedChanged" />
                        <dxb:BarItemSeparator />
                        <dxb:BarButtonItem Content="Best Fit"
                                           Glyph="{dx:DXImage Image=BestFitColumns_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="BestFitColumns_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Theme">
                        <dxr:RibbonGalleryBarItem x:Name="ThemeGalleryItem"
                                                   Content="Theme"
                                                   LargeGlyph="{dx:DXImage Image=ChangeFontStyle_32x32}"
                                                   RibbonStyle="Large" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Data">
                        <dxb:BarButtonItem Content="Test DB"
                                           LargeGlyph="{dx:DXImage Image=Database_32x32}"
                                           RibbonStyle="Large"
                                           Command="{Binding TestConnectionCommand}" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Export">
                        <dxb:BarButtonItem Content="Export Devices"
                                           LargeGlyph="{dx:DXImage Image=ExportToXLS_32x32}"
                                           RibbonStyle="Large"
                                           Command="{Binding ExportDevicesCommand}" />
                        <dxb:BarButtonItem Content="Import Data"
                                           Glyph="{dx:DXImage Image=Import_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="ImportData_ItemClick" />
                        <dxb:BarButtonItem Content="Print Preview"
                                           Glyph="{dx:DXImage Image=Preview_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="PrintPreview_ItemClick" />
                        <dxb:BarButtonItem Content="Column Chooser"
                                           Glyph="{dx:DXImage Image=CustomizeGrid_16x16}"
                                           RibbonStyle="SmallWithText"
                                           ItemClick="ColumnChooser_ItemClick" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Web App">
                        <dxb:BarButtonItem Content="Open Web App"
                                           LargeGlyph="{dx:DXImage Image=Browser_32x32}"
                                           RibbonStyle="Large"
                                           Command="{Binding OpenWebAppCommand}" />
                    </dxr:RibbonPageGroup>
                    <dxr:RibbonPageGroup Caption="Diagram">
                        <dxb:BarCheckItem  Content="Network Diagram"
                                           LargeGlyph="{dx:DXImage Image=ShowDependencies_32x32}"
                                           RibbonStyle="Large"
                                           IsChecked="{Binding IsDiagramPanelOpen, Mode=TwoWay}" />
                    </dxr:RibbonPageGroup>
                </dxr:RibbonPage>

                <!-- ── Devices Tab ── -->
                <dxr:RibbonPage Caption="Devices">
                    <dxr:RibbonPageGroup Caption="Actions">
                        <dxb:BarButtonItem Content="Refresh"
                                           LargeGlyph="{dx:DXImage Image=Refresh_32x32}"
                                           RibbonStyle="Large"
                                           ItemClick="RefreshButton_ItemClick" />
                        <dxb:BarButtonItem Content="New"
                                           LargeGlyph="{dx:DXImage Image=AddItem_32x32}"
                                           RibbonStyle="Large"
                                           IsVisible="{Binding CanEditDevices}"
                                           ItemClick="NewButton_ItemClick" />
                        <dxb:BarButtonItem Content="Delete"
                                           LargeGlyph="{dx:DXImage Image=Delete_32x32}"
