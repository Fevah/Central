        <!-- ═══════════════════════════════════════════════ DOCK LAYOUT ═══ -->
        <dxdo:DockLayoutManager x:Name="DockManager" Grid.Row="1"
                                FloatingMode="Desktop">
            <dxdo:LayoutGroup Orientation="Horizontal">

                <!-- Left nav panel -->
                <dxdo:LayoutPanel Caption="Sites" AllowClose="False"
                                  ItemWidth="200" AllowFloat="True">
                    <ItemsControl ItemsSource="{Binding SiteSummaries}"
                                  Padding="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="SiteBorder"
                                        Margin="2,2" Padding="8,6"
                                        CornerRadius="4"
                                        Cursor="Hand"
                                        Background="#1A5276"
                                        BorderThickness="1.5"
                                        BorderBrush="#2E86C1"
                                        MouseLeftButtonDown="SiteToggle_Click">
                                    <StackPanel>
                                        <TextBlock x:Name="SiteName" Text="{Binding Building}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#FFFFFF" />
                                        <TextBlock x:Name="SiteInfo" Text="{Binding Summary}" FontSize="11" Margin="0,1,0,0"
                                                   Foreground="#B0C4DE" />
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                        <Setter TargetName="SiteBorder" Property="Background" Value="#3A3A3A" />
                                        <Setter TargetName="SiteBorder" Property="BorderBrush" Value="#555555" />
                                        <Setter TargetName="SiteBorder" Property="Opacity" Value="0.55" />
                                        <Setter TargetName="SiteName" Property="Foreground" Value="#999999" />
                                        <Setter TargetName="SiteInfo" Property="Foreground" Value="#666666" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </dxdo:LayoutPanel>

