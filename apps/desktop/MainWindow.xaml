        <!-- ═══════════════════════════════════════════════ STATUS BAR ═══ -->
        <dxr:RibbonStatusBarControl Grid.Row="2">
            <dxr:RibbonStatusBarControl.LeftItems>
                <dxb:BarStaticItem x:Name="StatusBarDbIndicator">
                    <dxb:BarStaticItem.ContentTemplate>
                        <DataTemplate>
                            <Ellipse Width="8" Height="8" Fill="{Binding DbStatus}" Margin="0,0,6,0" />
                        </DataTemplate>
                    </dxb:BarStaticItem.ContentTemplate>
                </dxb:BarStaticItem>
                <dxb:BarStaticItem Content="{Binding StatusText}" />
            </dxr:RibbonStatusBarControl.LeftItems>
            <dxr:RibbonStatusBarControl.RightItems>
                <dxb:BarStaticItem Content="{Binding DeviceCountText}" />
                <dxb:BarStaticItem Content="  ·  " />
                <dxb:BarStaticItem x:Name="StatusBarAuthIndicator">
                    <dxb:BarStaticItem.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{Binding ConnectionModeColor}" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding ConnectionModeText}" FontSize="11" Margin="0,0,6,0" />
                            </StackPanel>
                        </DataTemplate>
                    </dxb:BarStaticItem.ContentTemplate>
                </dxb:BarStaticItem>
                <dxb:BarStaticItem Content="  ·  " />
                <dxb:BarStaticItem Content="{Binding CurrentUserDisplay}" />
                <dxb:BarStaticItem Content="{Binding CurrentUserRole, StringFormat=' ({0})'}" />
            </dxr:RibbonStatusBarControl.RightItems>
        </dxr:RibbonStatusBarControl>

        <!-- Global search overlay (Ctrl+F) -->
        <Border x:Name="GlobalSearchBar" Grid.Row="1"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,16,0" Padding="8,6"
                Background="#1E293B" BorderBrush="#3B82F6" BorderThickness="1"
                CornerRadius="6" Visibility="Collapsed"
                MaxWidth="400">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x1F50D;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBox x:Name="GlobalSearchBox" Width="280" Height="26"
                         Background="#0F172A" Foreground="#F1F5F9" BorderThickness="0"
                         FontSize="12" VerticalContentAlignment="Center"
                         TextChanged="GlobalSearchBox_TextChanged"
                         KeyDown="GlobalSearchBox_KeyDown" />
                <TextBlock x:Name="GlobalSearchCount" Text="" FontSize="11"
                           Foreground="#94A3B8" Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Toast notification overlay -->
        <Border x:Name="ToastBorder" Grid.Row="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,16,16" Padding="12,8"
                Background="#1E293B" BorderBrush="#334155" BorderThickness="1"
                CornerRadius="6" Visibility="Collapsed"
                MaxWidth="400">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastIcon" Text="" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                <StackPanel>
                    <TextBlock x:Name="ToastTitle" Text="" FontWeight="SemiBold" FontSize="12" Foreground="#F1F5F9" />
                    <TextBlock x:Name="ToastMessage" Text="" FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </Border>

