q 0 0 23 21 rectclip
1 0 0 -1 0 21 cm q
1 g
0.375 0.375 21.75 20.176 re f
q
0 0 23 21 re W n
% Fallback Image: x=0 y=0 w=23 h=21 res=300ppi size=25344
[ 23.04 0 0 -21.12 0 21.12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 96
  /Height 88
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
