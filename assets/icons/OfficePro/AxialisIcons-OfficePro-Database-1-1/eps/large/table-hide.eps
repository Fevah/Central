%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 22 21
%%EndPageSetup
q 0 0 22 21 rectclip
1 0 0 -1 0 21 cm q
q
0 0 22 21 re W n
% Fallback Image: x=0 y=0 w=22 h=21 res=300ppi size=24288
[ 0.24 0 0 -0.24 0 21.12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 92 def
  /Height 88 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 88 ] def
end
