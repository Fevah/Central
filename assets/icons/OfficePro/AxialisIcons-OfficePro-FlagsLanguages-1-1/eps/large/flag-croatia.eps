1 0 0 -1 0 18 cm q
1 g
0 6 22.5 6 re f
0.482353 0.639216 0.839216 rg
0 12 22.5 6 re f
q
0 0 23 18 re W n
% Fallback Image: x=0 y=0 w=23 h=18 res=300ppi size=21600
[ 0.24 0 0 -0.24 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 96 def
  /Height 75 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 75 ] def
end
