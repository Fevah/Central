23.25 21 m 23.25 3 l 23.238 3 l 0.762 21 l h
23.25 21 m f
0.968627 0.807843 0.45098 rg
23.25 6.109 m 23.25 3 l 19.438 3 l 0.75 17.891 l 0.75 21 l 4.563 21 l h
23.25 6.109 m f
0.47451 0.478431 0.482353 rg
23.25 5 m 23.25 3 l 20.727 3 l 0.75 19 l 0.75 21 l 3.273 21 l h
23.25 5 m f
q
0 0 24 24 re W n
% Fallback Image: x=0 y=0 w=24 h=24 res=300ppi size=30000
[ 0.24 0 0 -0.24 0 24 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 100 def
  /Height 100 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 100 ] def
end
