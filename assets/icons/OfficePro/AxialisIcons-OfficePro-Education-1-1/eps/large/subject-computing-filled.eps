%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 23 20
%%EndPageSetup
q 0 0 23 20 rectclip
1 0 0 -1 0 20 cm q
1 g
0.375 0.375 21.75 16.5 re f
q
0 0 23 20 re W n
% Fallback Image: x=0 y=0 w=23 h=20 res=300ppi size=24192
[ 23.04 0 0 -20.16 0 20.16 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 96
  /Height 84
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 96 0 0 -84 0 84 ]
