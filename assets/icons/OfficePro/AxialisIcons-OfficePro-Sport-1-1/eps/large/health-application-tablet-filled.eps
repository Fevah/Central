%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 18 23
%%EndPageSetup
q 0 0 18 23 rectclip
1 0 0 -1 0 23 cm q
1 g
0.375 0.375 17.25 21.75 re f
q
0 0 18 23 re W n
% Fallback Image: x=0 y=0 w=18 h=23 res=300ppi size=21600
[ 0.24 0 0 -0.24 0 23.04 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 75 def
  /Height 96 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 96 ] def
end
