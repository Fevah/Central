 7.445 l 11.355 7.422 11.559 7.406 11.762 7.406 c 14.547 7.406 16.816 9.641
 16.816 12.383 c 16.816 13.766 16.234 15.059 15.246 15.984 c 15.918 16.398
 16.535 16.93 17.078 17.559 c 17.305 17.82 17.512 18.09 17.699 18.375 c 
22.875 18.375 l 22.875 1.125 l h
8.625 1.125 m f
q
0 0 24 24 re W n
% Fallback Image: x=0 y=0 w=24 h=24 res=300ppi size=30000
[ 0.24 0 0 -0.24 0 24 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 100 def
  /Height 100 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 100 ] def
end
