24 24 cairo_set_page_size
%%EndPageSetup
q 0 0 24 24 rectclip
1 0 0 -1 0 24 cm q
1 g
4.125 1.125 m 4.125 11.25 l 17.25 11.25 l 17.25 19.125 l 22.875 19.125 
l 22.875 1.125 l h
4.125 1.125 m f
0.219608 g
3.75 0.75 m 3.75 11.25 l 4.5 11.25 l 4.5 1.5 l 22.5 1.5 l 22.5 18.75 l 
17.25 18.75 l 17.25 19.5 l 23.25 19.5 l 23.25 0.75 l h
3.75 0.75 m f
q
0 0 24 24 re W n
% Fallback Image: x=0 y=0 w=24 h=24 res=300ppi size=30000
[ 0.24 0 0 -0.24 0 24 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 100 def
  /Height 100 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 100 ] def
end
