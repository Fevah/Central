q 0 0 24 24 rectclip
1 0 0 -1 0 24 cm q
1 g
1.125 1.875 21.75 16.5 re f
0.219608 g
23.25 18.75 m 0.75 18.75 l 0.75 1.5 l 23.25 1.5 l h
1.5 18 m 22.5 18 l 22.5 2.25 l 1.5 2.25 l h
1.5 18 m f
0.572549 0.796078 0.933333 rg
12.375 18.375 m 1.125 18.375 l 1.125 21.375 l 9.398 21.375 l h
12.375 18.375 m f
q
0 0 24 24 re W n
% Fallback Image: x=0 y=0 w=24 h=24 res=300ppi size=30000
[ 0.24 0 0 -0.24 0 24 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
8 dict dup begin
  /ImageType 1 def
  /Width 100 def
  /Height 100 def
  /Interpolate false def
  /BitsPerComponent 8 def
  /Decode [ 0 1 0 1 0 1 ] def
  /DataSource cairo_ascii85_file /FlateDecode filter def
  /ImageMatrix [ 1 0 0 -1 0 100 ] def
end
