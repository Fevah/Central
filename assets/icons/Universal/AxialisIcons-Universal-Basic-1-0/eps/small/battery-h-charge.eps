q 0 0 12 8 rectclip
1 0 0 -1 0 8 cm q
q
0 0 12 8 re W n
% Fallback Image: x=0 y=0 w=12 h=8 res=300ppi size=5100
[ 12 0 0 -8.16 0 8.16 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 34
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -34 0 34 ]
