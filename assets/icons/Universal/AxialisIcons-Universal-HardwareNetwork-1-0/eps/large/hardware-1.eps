q 0 0 18 16 rectclip
1 0 0 -1 0 16 cm q
q
0 0 18 16 re W n
% Fallback Image: x=0 y=0 w=18 h=16 res=300ppi size=15075
[ 18 0 0 -16.08 0 16.08 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 67
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -67 0 67 ]
