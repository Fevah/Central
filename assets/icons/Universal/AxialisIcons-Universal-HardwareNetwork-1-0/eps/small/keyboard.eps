q 0 0 12 7 rectclip
1 0 0 -1 0 7 cm q
q
0 0 12 7 re W n
% Fallback Image: x=0 y=0 w=12 h=7 res=300ppi size=4500
[ 12 0 0 -7.2 0 7.2 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 30
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -30 0 30 ]
>>
