q 0 0 18 18 rectclip
1 0 0 -1 0 18 cm q
0.482353 g
1.5 0 m 1.5 18 l 16.5 18 l 16.5 4.875 l 11.645 0 l h
15 16.5 m 3 16.5 l 3 1.5 l 11.25 1.5 l 11.25 5.27 l 15 5.25 l h
15 16.5 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
>>
