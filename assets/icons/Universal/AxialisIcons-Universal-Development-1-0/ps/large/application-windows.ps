1.5 0 m 1.5 4.5 l 16.5 4.5 l 16.5 0 l h
9 3 m 7.5 3 l 7.5 1.5 l 9 1.5 l h
12 3 m 10.5 3 l 10.5 1.5 l 12 1.5 l h
15 3 m 13.5 3 l 13.5 1.5 l 15 1.5 l h
15 3 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
