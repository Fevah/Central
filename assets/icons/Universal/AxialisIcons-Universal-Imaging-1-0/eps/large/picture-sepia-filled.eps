q 0 0 18 15 rectclip
1 0 0 -1 0 15 cm q
q
0 0 18 15 re W n
% Fallback Image: x=0 y=0 w=18 h=15 res=300ppi size=14175
[ 18 0 0 -15.12 0 15.12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 63
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -63 0 63 ]
