q 0 0 12 12 rectclip
1 0 0 -1 0 12 cm q
0.431373 0.435294 0.447059 rg
6.633 10.367 m 6.109 9.828 l 9.27 6.73 l 9.789 7.27 l h
6.633 10.367 m f
5.957 2.891 m 6.449 2.32 l 9.695 5.121 l 9.207 5.688 l h
5.957 2.891 m f
q
0 0 12 12 re W n
% Fallback Image: x=0 y=0 w=12 h=12 res=300ppi size=7500
[ 12 0 0 -12 0 12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 50
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -50 0 50 ]
>>
