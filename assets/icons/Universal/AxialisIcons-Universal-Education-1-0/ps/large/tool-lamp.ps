q 0 0 18 18 rectclip
1 0 0 -1 0 18 cm q
0.431373 0.435294 0.447059 rg
9.152 14.695 m 13.891 10.086 l 14.672 10.887 l 9.934 15.5 l h
9.152 14.695 m f
13.797 8.539 m 8.926 4.375 l 9.66 3.527 l 14.531 7.691 l h
13.797 8.539 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
>>
