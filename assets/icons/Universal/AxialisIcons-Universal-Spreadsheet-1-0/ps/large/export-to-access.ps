1 0 0 -1 0 18 cm q
0.482353 g
9.75 9.305 m 9.75 3.375 l 6.395 0 l 0 0 l 0 11.25 l 8.965 11.25 l h
1.5 9.75 m 1.5 1.5 l 6 1.5 l 6 3.77 l 8.25 3.75 l 8.25 9.75 l h
1.5 9.75 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
