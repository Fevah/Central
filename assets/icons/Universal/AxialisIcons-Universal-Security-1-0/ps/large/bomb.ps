1.77 0.824 m 4.258 1.945 l 5.629 0.008 l 5.781 2.531 l 7.664 3.18 l 5.563
 4.125 l 5.73 6.523 l 4.34 4.957 l 1.738 6.859 l 3.195 4.297 l 0.012 4.035
 l 3.016 2.898 l h
1.77 0.824 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
