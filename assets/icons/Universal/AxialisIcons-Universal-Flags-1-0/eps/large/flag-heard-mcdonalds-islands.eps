%%EndPageSetup
q 0 0 18 14 rectclip
1 0 0 -1 0 14 cm q
0.478431 0.635294 0.835294 rg
0 0 18 13.5 re f
q
0 0 18 14 re W n
% Fallback Image: x=0 y=0 w=18 h=14 res=300ppi size=13275
[ 18 0 0 -14.16 0 14.16 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 59
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -59 0 59 ]
