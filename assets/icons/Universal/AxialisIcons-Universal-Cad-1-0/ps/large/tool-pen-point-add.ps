%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageMedia: 6x6mm
%%PageBoundingBox: 0 0 18 18
18 18 cairo_set_page_size
%%EndPageSetup
q 0 0 18 18 rectclip
1 0 0 -1 0 18 cm q
0.0901961 0.670588 0.309804 rg
3 7.5 m 3 4.5 l 0 4.5 l 0 3 l 3 3 l 3 0 l 4.5 0 l 4.5 3 l 7.5 3 l 7.5 4.5
 l 4.5 4.5 l 4.5 7.5 l h
3 7.5 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
>>
