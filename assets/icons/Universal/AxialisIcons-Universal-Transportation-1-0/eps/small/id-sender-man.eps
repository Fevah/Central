q 0 0 12 9 rectclip
1 0 0 -1 0 9 cm q
q
0 0 12 9 re W n
% Fallback Image: x=0 y=0 w=12 h=9 res=300ppi size=5700
[ 12 0 0 -9.12 0 9.12 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 50
  /Height 38
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 50 0 0 -38 0 38 ]
