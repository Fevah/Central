%%EndPageSetup
q 0 0 17 17 rectclip
1 0 0 -1 0 17 cm q
q
0 0 17 17 re W n
% Fallback Image: x=0 y=0 w=17 h=17 res=300ppi size=15123
[ 17.04 0 0 -17.04 0 17.04 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceGray setcolorspace
<<
