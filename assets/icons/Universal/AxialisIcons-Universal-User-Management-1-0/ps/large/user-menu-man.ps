18 4.5 m 12 4.5 l 12 3.75 l 18 3.75 l h
18 6.75 m 12 6.75 l 12 6 l 18 6 l h
18 9 m 12 9 l 12 8.25 l 18 8.25 l h
18 11.25 m 12 11.25 l 12 10.5 l 18 10.5 l h
18 13.5 m 12 13.5 l 12 12.75 l 18 12.75 l h
18 13.5 m f
q
0 0 18 18 re W n
% Fallback Image: x=0 y=0 w=18 h=18 res=300ppi size=16875
[ 18 0 0 -18 0 18 ] concat
/cairo_ascii85_file currentfile /ASCII85Decode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Width 75
  /Height 75
  /Interpolate false
  /BitsPerComponent 8
  /Decode [ 0 1 0 1 0 1 ]
  /DataSource cairo_ascii85_file /FlateDecode filter
  /ImageMatrix [ 75 0 0 -75 0 75 ]
