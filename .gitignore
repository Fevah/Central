# Build outputs (pre-restructure paths + post-restructure paths — both
# kept active while the restructure is in progress)
desktop/**/bin/
desktop/**/obj/
web-client/node_modules/
web-client/dist/
web-client/.angular/
apps/**/bin/
apps/**/obj/
libs/**/bin/
libs/**/obj/
modules/**/bin/
modules/**/obj/
services/**/bin/
services/**/obj/
tests/**/bin/
tests/**/obj/
apps/web/node_modules/
apps/web/dist/
apps/web/.angular/

# Rust build artefacts
services/**/target/

# Offline NuGet / DX package caches
packages-offline/
**/packages-offline/

# IDE
.vs/
.vscode/
*.suo
*.user

# Backup dumps
*.dump
*.bak

# Secrets
.env
*.pfx
*.key

# OS
Thumbs.db
.DS_Store

# Temp
*.tmp
crash.log

# Large binaries
*.exe
*.dll
!desktop/**/*.dll

# Python
__pycache__/
*.pyc

# Logs
logs/
*.log

# NuGet
*.nupkg

# SecureAPP symlink/copy (separate repo)
SecureAPP/

# Vagrant local VM state — disk images, mem dumps, lock files (60+ GB)
# These are local-only; never commit. Pre-existing tracked entries should
# be removed with `git rm --cached -r infra/vagrant/.vagrant/`.
.vagrant/
**/.vagrant/

# Terraform local state
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Docker/podman build context leftovers
*.tar
*.tar.gz
!backups/**/*.sql.gz
