# Build outputs
desktop/**/bin/
desktop/**/obj/
web-client/node_modules/
web-client/dist/
web-client/.angular/

# IDE
.vs/
.vscode/
*.suo
*.user

# Backup dumps
*.dump
*.bak

# Secrets
.env
*.pfx
*.key

# OS
Thumbs.db
.DS_Store

# Temp
*.tmp
crash.log

# Large binaries
*.exe
*.dll
!desktop/**/*.dll

# Python
__pycache__/
*.pyc

# Logs
logs/
*.log

# NuGet
*.nupkg

# SecureAPP symlink/copy (separate repo)
SecureAPP/

# Vagrant local VM state — disk images, mem dumps, lock files (60+ GB)
# These are local-only; never commit. Pre-existing tracked entries should
# be removed with `git rm --cached -r infra/vagrant/.vagrant/`.
.vagrant/
**/.vagrant/

# Terraform local state
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Docker/podman build context leftovers
*.tar
*.tar.gz
!backups/**/*.sql.gz
