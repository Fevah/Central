<ResourceDictionary x:Class="TIG.TotalLink.Client.MVVM.ResourceDictionary.GridColumnEditorResource"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dxci="http://schemas.devexpress.com/winfx/2008/xaml/core/internal"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control"
                    xmlns:converter="clr-namespace:TIG.TotalLink.Client.Editor.Converter"
                    xmlns:gridEditStrategy="clr-namespace:TIG.TotalLink.Client.Editor.GridEditStrategy"
                    xmlns:behavior="clr-namespace:TIG.TotalLink.Client.Editor.Behavior"
                    xmlns:view="clr-namespace:TIG.TotalLink.Client.Editor.View"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:helper="clr-namespace:TIG.TotalLink.Client.Editor.Helper"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:themes="http://schemas.devexpress.com/winfx/2008/xaml/editors/themekeys"
                    xmlns:definition="clr-namespace:TIG.TotalLink.Client.Editor.Definition">

    <!--<ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/TIG.TotalLink.Client.MVVM;component/ResourceDictionary/EditorResource.xaml" />
    </ResourceDictionary.MergedDictionaries>-->

    <converter:BoolToEditorPlacementConverter x:Key="BoolToEditorPlacementConverter" />
    <dx:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converter:GuidToNullConverter x:Key="GuidToNullConverter" />
    <converter:PasswordStringConverter x:Key="PasswordStringConverter" />
    <converter:MultiMethodToValueConverter x:Key="MultiMethodToValueConverter" />
    <converter:UniversalToLocalDateTimeConverter x:Key="UniversalToLocalDateTimeConverter" />
    <converter:MultiUniversalDateTimeToLocalStringConverter x:Key="MultiUniversalDateTimeToLocalStringConverter" />
    <converter:CommentsStringToCountConverter x:Key="CommentsStringToCountConverter" />
    <converter:MinuteToHourConverter x:Key="MinuteToHourConverter" />
    <converter:RtfToStringConverter x:Key="RtfToStringConverter" />
    <converter:StringCleanConverter x:Key="StringCleanConverter" />
    <converter:MultiStringFormatConverter x:Key="MultiStringFormatConverter" />
    <converter:IntToDecimalConverter x:Key="IntToDecimalConverter" />
    <converter:LongToDecimalConverter x:Key="LongToDecimalConverter" />
    <dx:ObjectToStringConverter x:Key="ObjectToStringConverter" />
    <converter:FormatCountConverter x:Key="FormatCountConverter" />
    <converter:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter" />
    <dxmvvm:ObjectToObjectConverter x:Key="ComboImageWidthConverter"
                                    DefaultTarget="Auto">
        <dxmvvm:MapItem Source="{x:Static definition:EnumEditorDefinitionBase+DisplayModes.ImageOnly}"
                        Target="*" />
    </dxmvvm:ObjectToObjectConverter>
    <dxmvvm:ObjectToObjectConverter x:Key="ComboTextWidthConverter"
                                    DefaultTarget="*">
        <dxmvvm:MapItem Source="{x:Static definition:EnumEditorDefinitionBase+DisplayModes.ImageOnly}"
                        Target="Auto" />
    </dxmvvm:ObjectToObjectConverter>

    <gridEditStrategy:TextEditGridEditStrategy x:Key="TextEditGridEditStrategy" />
    <gridEditStrategy:SpinEditGridEditStrategy x:Key="SpinEditGridEditStrategy" />
    <gridEditStrategy:PasswordBoxEditGridEditStrategy x:Key="PasswordBoxEditGridEditStrategy" />
    <gridEditStrategy:MaskedTextEditGridEditStrategy x:Key="MaskedTextEditGridEditStrategy" />


    <!-- ************************* -->
    <!-- * GRID COLUMN TEMPLATES * -->
    <!-- ************************* -->

    <!-- Defines templates for editors that appear in a column of a stand-alone GridControl. (e.g. ListView) -->

    <!-- Default -->
    <DataTemplate x:Key="DefaultGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx />
        </ContentControl>
    </DataTemplate>

    <!-- Text -->
    <DataTemplate x:Key="TextGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:ButtonEdit x:Name="PART_Editor"
                                        EditMode="InplaceActive"
                                        AllowDefaultButton="False"
                                        HorizontalContentAlignment="Left"
                                        EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        MaskType="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.MaskType}"
                                        Mask="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.RegexMask}"
                                        MaxLength="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).MaxLength}"
                                        IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                        AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                        NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}"
                                        behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource TextEditGridEditStrategy}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Spin -->
    <DataTemplate x:Key="SpinGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay}"
                                             TextAlignment="Right" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:SpinEdit x:Name="PART_Editor"
                                      EditMode="InplaceActive"
                                      IsFloatValue="False"
                                      MaskType="Numeric"
                                      Mask="D"
                                      MaskUseAsDisplayFormat="False"
                                      DisplayFormatString="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.DisplayFormat}"
                                      EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      MaxLength="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).MaxLength}"
                                      IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                      MinValue="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.MinValue}"
                                      MaxValue="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.MaxValue}"
                                      Increment="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.Increment}"
                                      AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                      NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}"
                                      behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource SpinEditGridEditStrategy}">
                            <dxmvvm:Interaction.Behaviors>
                                <behavior:AttachConverterBehavior PropertyName="EditValue"
                                                                  TargetType="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).FieldType}">
                                    <behavior:AttachConverterBehavior.Mappings>
                                        <helper:ConverterMapping Type="{x:Type system:Int32}"
                                                                 Converter="{StaticResource IntToDecimalConverter}" />
                                        <helper:ConverterMapping Type="{x:Type system:Int64}"
                                                                 Converter="{StaticResource LongToDecimalConverter}" />
                                    </behavior:AttachConverterBehavior.Mappings>
                                </behavior:AttachConverterBehavior>
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:SpinEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Checkbox -->
    <DataTemplate x:Key="CheckboxGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx behavior:CommitOnValueChangedBehavior.Enabled="True">
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <dxe:CheckEdit EditMode="InplaceInactive"
                                       IsReadOnly="True"
                                       EditValue="{Binding Value, Mode=OneWay}"
                                       IsThreeState="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:CheckEdit x:Name="PART_Editor"
                                       EditMode="InplaceActive"
                                       EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                       IsThreeState="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Grid -->
    <DataTemplate x:Key="GridGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <view:GridEdit MaxHeight="200"
                                       EditorDefinition="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor}"
                                       ShowBorder="False" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- PopupGrid -->
    <DataTemplate x:Key="PopupGridGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, Converter={StaticResource FormatCountConverter}}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:PopupBaseEdit x:Name="PART_Editor"
                                           EditMode="InplaceActive"
                                           IsTextEditable="False"
                                           IsReadOnly="True"
                                           ShowSizeGrip="True"
                                           PopupMinHeight="100"
                                           PopupMaxHeight="400"
                                           EditValue="{Binding Value, Mode=OneWay}"
                                           DisplayTextConverter="{StaticResource FormatCountConverter}">
                            <dxe:PopupBaseEdit.PopupContentTemplate>
                                <ControlTemplate>
                                    <view:GridEdit EditorDefinition="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor}"
                                                   ShowBorder="False" />
                                </ControlTemplate>
                            </dxe:PopupBaseEdit.PopupContentTemplate>
                        </dxe:PopupBaseEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- LookUp -->
    <DataTemplate x:Key="LookUpGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <view:LookUpEdit x:Name="PART_Editor"
                                         EditMode="InplaceActive"
                                         ShowSizeGrip="True"
                                         ValidateOnTextInput="False"
                                         PopupMinHeight="100"
                                         PopupMaxHeight="400"
                                         IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                         EditorDefinition="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor}"
                                         AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                         NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}"
                                         behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource TextEditGridEditStrategy}">
                            <dxmvvm:Interaction.Behaviors>
                                <behavior:DataObjectPropertyNameBindingBehavior TargetPropertyName="EditValue"
                                                                                Path="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).PropertyName}" />
                            </dxmvvm:Interaction.Behaviors>
                        </view:LookUpEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Label -->
    <DataTemplate x:Key="LabelGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx AllowEditing="False">
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, Converter={StaticResource ObjectToStringConverter}}"
                                             TextWrapping="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.TextWrapping}"
                                             TextTrimming="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.TextTrimming}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Password -->
    <DataTemplate x:Key="PasswordGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, Converter={StaticResource PasswordStringConverter}}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:PasswordBoxEdit x:Name="PART_Editor"
                                             EditMode="InplaceActive"
                                             IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                             EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                             MaxLength="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).MaxLength}"
                                             behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource PasswordBoxEditGridEditStrategy}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Id -->
    <DataTemplate x:Key="IdGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:TextEdit x:Name="PART_Editor"
                                      EditMode="InplaceActive"
                                      HorizontalContentAlignment="Left"
                                      EditValue="{Binding Value, Mode=OneWay}"
                                      IsReadOnly="True" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Progress -->
    <DataTemplate x:Key="ProgressGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx AllowEditing="False">
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <dxe:ProgressBarEdit x:Name="PART_Editor"
                                             EditMode="InplaceInactive"
                                             EditValue="{Binding Value, Mode=OneWay}"
                                             Minimum="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.ActualMinimum}"
                                             Maximum="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.ActualMaximum}"
                                             ContentDisplayMode="Value"
                                             IsPercent="True"
                                             DisplayFormatString="p0" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- RichText -->
    <DataTemplate x:Key="RichTextGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, Converter={StaticResource RtfToStringConverter}}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:PopupBaseEdit x:Name="RichTextPopup"
                                           IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                           EditMode="InplaceActive"
                                           AllowDefaultButton="False"
                                           FocusPopupOnOpen="True"
                                           PopupMinWidth="400"
                                           PopupMinHeight="300"
                                           ShowSizeGrip="True">
                            <dxe:PopupBaseEdit.EditTemplate>
                                <ControlTemplate>
                                    <dxe:ButtonEdit ShowText="False"
                                                    AllowDefaultButton="False">
                                        <dxe:ButtonEdit.Buttons>
                                            <dxe:ButtonInfo GlyphKind="DropDown"
                                                            Command="{Binding OpenPopupCommand, ElementName=RichTextPopup}" />
                                        </dxe:ButtonEdit.Buttons>
                                    </dxe:ButtonEdit>
                                </ControlTemplate>
                            </dxe:PopupBaseEdit.EditTemplate>
                            <dxe:PopupBaseEdit.PopupContentContainerTemplate>
                                <ControlTemplate>
                                    <view:RichTextEdit x:Name="PART_Editor"
                                                       EditMode="Standalone"
                                                       EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       SaveCommand="{Binding Path=DefaultSaveCommand, RelativeSource={RelativeSource Self}}"
                                                       CancelCommand="{Binding Path=DefaultCancelCommand, RelativeSource={RelativeSource Self}}" />
                                </ControlTemplate>
                            </dxe:PopupBaseEdit.PopupContentContainerTemplate>
                        </dxe:PopupBaseEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- DateTime -->
    <DataTemplate x:Key="DateTimeGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx>
                            <control:TextBlockEx.Text>
                                <MultiBinding Converter="{StaticResource MultiUniversalDateTimeToLocalStringConverter}">
                                    <Binding Path="Value"
                                             Mode="OneWay" />
                                    <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor.Mask" />
                                </MultiBinding>
                            </control:TextBlockEx.Text>
                        </control:TextBlockEx>
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:DateEdit x:Name="PART_Editor"
                                      EditMode="InplaceActive"
                                      MaskUseAsDisplayFormat="True"
                                      Mask="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.Mask}"
                                      IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                      AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                      EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource UniversalToLocalDateTimeConverter}}"
                                      NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}"
                                      behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource MaskedTextEditGridEditStrategy}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand EventName="Loaded"
                                                       Command="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.LoadCommand}"
                                                       CommandParameter="{Binding ElementName=PART_Editor}" />
                            </dxmvvm:Interaction.Behaviors>

                            <dxe:DateEdit.StyleSettings>
                                <dxe:DateEditPickerStyleSettings />
                            </dxe:DateEdit.StyleSettings>
                        </dxe:DateEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- HyperLink -->
    <DataTemplate x:Key="HyperLinkGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay}"
                                             TextDecorations="Underline"
                                             Foreground="Blue" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:ButtonEdit x:Name="PART_Editor"
                                        EditMode="InplaceActive"
                                        Foreground="Black"
                                        AllowDefaultButton="False"
                                        AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                        IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                        EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}"
                                        behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource TextEditGridEditStrategy}">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EventToCommand EventName="MouseDoubleClick"
                                                       Command="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.OpenCommand}"
                                                       CommandParameter="{Binding Value}" />
                                <dxmvvm:EventToCommand EventName="LostFocus"
                                                       Command="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.OutCommand}" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ButtonEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- IncrementingTime -->
    <DataTemplate x:Key="IncrementingTimeGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx behavior:CommitOnValueChangedBehavior.Enabled="True">
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, Converter={StaticResource MinuteToHourConverter}}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <view:IncrementingTimeEdit x:Name="PART_Editor"
                                                   EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Comment -->
    <DataTemplate x:Key="CommentGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx AllowEditing="False">
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, Converter={StaticResource CommentsStringToCountConverter}}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Memo -->
    <DataTemplate x:Key="MemoGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, Converter={StaticResource StringCleanConverter}}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:MemoEdit x:Name="PART_Editor"
                                      ShowIcon="False"
                                      DisplayTextConverter="{StaticResource StringCleanConverter}"
                                      EditMode="InplaceActive"
                                      PopupMinWidth="400"
                                      PopupMinHeight="300"
                                      EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      MaxLength="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).MaxLength}"
                                      IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                      AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                      NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}">
                        </dxe:MemoEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Currency -->
    <DataTemplate x:Key="CurrencyGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx Text="{Binding Value, Mode=OneWay, StringFormat=C2}"
                                             TextAlignment="Right" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:ButtonEdit x:Name="PART_Editor"
                                        EditMode="InplaceActive"
                                        AllowDefaultButton="False"
                                        HorizontalContentAlignment="Right"
                                        DisplayFormatString="C2"
                                        MaskType="Numeric"
                                        Mask="C4"
                                        MaskUseAsDisplayFormat="False"
                                        EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                        AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                        NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}"
                                        behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource TextEditGridEditStrategy}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Option -->
    <DataTemplate x:Key="OptionGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx behavior:CommitOnValueChangedBehavior.Enabled="True">
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <dxe:ListBoxEdit x:Name="PART_Editor"
                                         StyleSettings="{dxe:RadioListBoxEditStyleSettings}"
                                         ValueMember="Key"
                                         DisplayMember="Value"
                                         Padding="4"
                                         MaxHeight="200"
                                         EditValue="{Binding Value, Mode=OneWay}"
                                         ItemsSource="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.ItemsSource}"
                                         IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:ListBoxEdit x:Name="PART_Editor"
                                         StyleSettings="{dxe:RadioListBoxEditStyleSettings}"
                                         ValueMember="Key"
                                         DisplayMember="Value"
                                         Padding="4"
                                         MaxHeight="200"
                                         EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ItemsSource="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.ItemsSource}"
                                         IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- PopupOption -->
    <DataTemplate x:Key="PopupOptionGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx>
                            <control:TextBlockEx.Text>
                                <MultiBinding Converter="{StaticResource MultiMethodToValueConverter}"
                                              ConverterParameter="GetText">
                                    <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor" />
                                    <Binding Path="Value" />
                                </MultiBinding>
                            </control:TextBlockEx.Text>
                        </control:TextBlockEx>
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:PopupBaseEdit x:Name="PART_Editor"
                                           EditMode="InplaceActive"
                                           FocusPopupOnOpen="True"
                                           IsTextEditable="False"
                                           EditValue="{Binding Value, Mode=OneWay}">
                            <dxe:PopupBaseEdit.EditNonEditableTemplate>
                                <ControlTemplate>
                                    <control:TextBlockEx>
                                        <control:TextBlockEx.Text>
                                            <MultiBinding Converter="{StaticResource MultiMethodToValueConverter}"
                                                          ConverterParameter="GetText">
                                                <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor" />
                                                <Binding Path="Value" />
                                            </MultiBinding>
                                        </control:TextBlockEx.Text>
                                    </control:TextBlockEx>
                                </ControlTemplate>
                            </dxe:PopupBaseEdit.EditNonEditableTemplate>
                            <dxe:PopupBaseEdit.PopupContentTemplate>
                                <ControlTemplate>
                                    <dxe:ListBoxEdit StyleSettings="{dxe:RadioListBoxEditStyleSettings}"
                                                     ValueMember="Key"
                                                     DisplayMember="Value"
                                                     Padding="4"
                                                     MaxHeight="200"
                                                     ItemsSource="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.ItemsSource}"
                                                     IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}" />
                                </ControlTemplate>
                            </dxe:PopupBaseEdit.PopupContentTemplate>
                        </dxe:PopupBaseEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

