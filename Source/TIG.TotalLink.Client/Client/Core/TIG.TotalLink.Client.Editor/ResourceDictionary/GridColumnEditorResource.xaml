    <!-- Decimal -->
    <DataTemplate x:Key="DecimalGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <control:TextBlockEx TextAlignment="Right">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource MultiStringFormatConverter}"
                                              Mode="OneWay">
                                    <Binding Path="Value" />
                                    <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor.Mask" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </control:TextBlockEx>
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:ButtonEdit x:Name="PART_Editor"
                                        EditMode="InplaceActive"
                                        AllowDefaultButton="False"
                                        HorizontalContentAlignment="Right"
                                        MaskType="Numeric"
                                        MaskUseAsDisplayFormat="True"
                                        Mask="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.Mask}"
                                        EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                        AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                        NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Combo -->
    <DataTemplate x:Key="ComboGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.DisplayMode, Converter={StaticResource ComboImageWidthConverter}}" />
                                <ColumnDefinition Width="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.DisplayMode, Converter={StaticResource ComboTextWidthConverter}}" />
                            </Grid.ColumnDefinitions>
                            <Grid.ToolTip>
                                <MultiBinding Converter="{StaticResource MultiMethodToValueConverter}"
                                              ConverterParameter="GetToolTip">
                                    <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor" />
                                    <Binding Path="Value" />
                                </MultiBinding>
                            </Grid.ToolTip>
                            <Image Grid.Column="0"
                                   Visibility="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.IsImageVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Margin="3,2,0,2"
                                   Width="16"
                                   Height="16">
                                <Image.Source>
                                    <MultiBinding Converter="{StaticResource MultiMethodToValueConverter}"
                                                  ConverterParameter="GetImage">
                                        <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor" />
                                        <Binding Path="Value" />
                                    </MultiBinding>
                                </Image.Source>
                            </Image>
                            <TextBlock Grid.Column="1"
                                       Margin="5,2,5,0"
                                       Visibility="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.IsTextVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource MultiMethodToValueConverter}"
                                                  ConverterParameter="GetText">
                                        <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor" />
                                        <Binding Path="Value" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:ComboBoxEdit x:Name="PART_Editor"
                                          EditMode="InplaceActive"
                                          AutoComplete="True"
                                          ItemsSource="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.ItemsSource}"
                                          ValueMember="Key"
                                          DisplayMember="Value"
                                          HorizontalContentAlignment="Stretch"
                                          EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                          AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}"
                                          NullValueButtonPlacement="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull, Converter={StaticResource BoolToEditorPlacementConverter}}"
                                          AllowDefaultButton="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.AllowPopup}"
                                          behavior:GridEditStrategyBehavior.GridEditStrategy="{StaticResource TextEditGridEditStrategy}">
                            <dxe:ComboBoxEdit.EditTemplate>
                                <ControlTemplate>
                                    <Grid>
                                        <Grid.ToolTip>
                                            <MultiBinding Converter="{StaticResource MultiMethodToValueConverter}"
                                                          ConverterParameter="GetToolTip">
                                                <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor" />
                                                <Binding Path="Value" />
                                            </MultiBinding>
                                        </Grid.ToolTip>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.DisplayMode, Converter={StaticResource ComboImageWidthConverter}}" />
                                            <ColumnDefinition Width="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.DisplayMode, Converter={StaticResource ComboTextWidthConverter}}" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0"
                                               Visibility="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.IsImageVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                               Margin="3,2,0,2"
                                               Width="16"
                                               Height="16">
                                            <Image.Source>
                                                <MultiBinding Converter="{StaticResource MultiMethodToValueConverter}"
                                                              ConverterParameter="GetImage">
                                                    <Binding Path="Column.(dxci:DependencyObjectExtensions.DataContext).Editor" />
                                                    <Binding Path="Value" />
                                                </MultiBinding>
                                            </Image.Source>
                                        </Image>
                                        <TextBox Grid.Column="1"
                                                 Name="PART_Editor"
                                                 Padding="1,0"
                                                 Style="{DynamicResource {themes:TextEditThemeKey ResourceKey=TextInplaceStyle}}"
                                                 Visibility="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).Editor.IsTextVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </ControlTemplate>
                            </dxe:ComboBoxEdit.EditTemplate>
                            <dxe:ComboBoxEdit.ItemTemplate>
                                <DataTemplate>
                                    <Grid ToolTip="{Binding Value.ToolTip}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0"
                                               Source="{Binding Value.Image}"
                                               Visibility="{Binding Path=DataContext.Column.(dxci:DependencyObjectExtensions.DataContext).Editor.IsImageVisible, RelativeSource={RelativeSource FindAncestor, AncestorType=dxe:ComboBoxEdit}, Converter={StaticResource BoolToVisibilityConverter}}"
                                               Margin="0,0,3,0"
                                               Width="16"
                                               Height="16" />
                                        <TextBlock Grid.Column="1"
                                                   Padding="1,1,1,0"
                                                   Text="{Binding Value.Text}"
                                                   Visibility="{Binding Path=DataContext.Column.(dxci:DependencyObjectExtensions.DataContext).Editor.IsTextVisible, RelativeSource={RelativeSource FindAncestor, AncestorType=dxe:ComboBoxEdit}, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </dxe:ComboBoxEdit.ItemTemplate>
                        </dxe:ComboBoxEdit>
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>

    <!-- Image -->
    <DataTemplate x:Key="ImageGridColumnTemplate">
        <ContentControl>
            <control:GridColumnEx>
                <control:GridColumnEx.DisplayTemplate>
                    <ControlTemplate>
                        <Image Source="{Binding Value, Mode=OneWay}" />
                    </ControlTemplate>
                </control:GridColumnEx.DisplayTemplate>
                <control:GridColumnEx.EditTemplate>
                    <ControlTemplate>
                        <dxe:ImageEdit x:Name="PART_Editor"
                                       EditMode="InplaceActive"
                                       MaxHeight="34"
                                       EditValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                       IsReadOnly="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).IsReadOnly}"
                                       AllowNullInput="{Binding Path=Column.(dxci:DependencyObjectExtensions.DataContext).AllowNull}" />
                    </ControlTemplate>
                </control:GridColumnEx.EditTemplate>
            </control:GridColumnEx>
        </ContentControl>
    </DataTemplate>
</ResourceDictionary>