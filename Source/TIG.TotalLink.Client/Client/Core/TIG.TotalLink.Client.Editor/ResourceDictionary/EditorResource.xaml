<ResourceDictionary x:Class="TIG.TotalLink.Client.MVVM.ResourceDictionary.EditorResource"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:definition="clr-namespace:TIG.TotalLink.Client.Editor.Definition"
                    xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control"
                    xmlns:behavior="clr-namespace:TIG.TotalLink.Client.Editor.Behavior">

    <!-- Template for items in a CheckedListBox -->
    <DataTemplate x:Key="CheckedListBoxItemTemplate"
                  DataType="ListBoxItem">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <dxmvvm:Interaction.Behaviors>
                <behavior:ListBoxSelectionBehavior MouseEnterItemCommand="{Binding Path=EditorWrapper.Editor.(definition:CheckedListBoxEditorDefinition.MouseEnterItemCommand), RelativeSource={RelativeSource FindAncestor, AncestorType=control:DataLayoutItemEx}}"
                                                   MouseEnterItemCommandParameter="{Binding}"
                                                   MouseLeaveItemCommand="{Binding Path=EditorWrapper.Editor.(definition:CheckedListBoxEditorDefinition.MouseLeaveItemCommand), RelativeSource={RelativeSource FindAncestor, AncestorType=control:DataLayoutItemEx}}"
                                                   MouseLeaveItemCommandParameter="{Binding}" />
            </dxmvvm:Interaction.Behaviors>

            <CheckBox Grid.Column="0"
                      IsChecked="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType=ListBoxItem}}" />

            <ContentPresenter Grid.Column="1"
                              Content="{TemplateBinding Content}">
                <ContentPresenter.Resources>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="TextWrapping"
                                Value="Wrap" />
                        <Setter Property="VerticalAlignment"
                                Value="Center" />
                    </Style>
                </ContentPresenter.Resources>
            </ContentPresenter>

        </Grid>
    </DataTemplate>

</ResourceDictionary>