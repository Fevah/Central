<ResourceDictionary x:Class="TIG.TotalLink.Client.MVVM.ResourceDictionary.EditorStyleResource"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control">

    <!--<converter:TabItemToEnabledConverter x:Key="TabItemToEnabledConverter" />-->

    <!-- Style for TextBlockEx -->
    <Style TargetType="{x:Type control:TextBlockEx}">
        <Setter Property="TextTrimming"
                Value="CharacterEllipsis" />
        <Setter Property="Padding"
                Value="4,2,4,0" />
        <Setter Property="ToolTip"
                Value="{Binding Text, Mode=OneWay, RelativeSource={RelativeSource Self}}" />
    </Style>

    <!-- Disabled style for DXTabItem and LayoutGroupEx headers -->
    <!-- TODO - Can't set disabled style for DXTabItem because LayoutGroup.IsEnabled returns false when tabs are not selected. -->
    <!--<Style TargetType="{x:Type control:LayoutGroupEx}">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding}" />

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TabItemToEnabledConverter}, Mode=OneWay}"
                                     Value="False">
                            <Setter Property="Opacity"
                                    Value="0.5" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>-->

    <!-- Disabled style for LayoutGroupEx headers -->
    <Style TargetType="{x:Type control:LayoutGroupEx}">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding}" />

                    <DataTemplate.Triggers>
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Opacity"
                                    Value="0.5" />
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Disabled style for DataLayoutItemEx labels -->
    <Style TargetType="{x:Type control:DataLayoutItemEx}">
        <Setter Property="LabelTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding}" />

                    <DataTemplate.Triggers>
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Opacity"
                                    Value="0.5" />
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
