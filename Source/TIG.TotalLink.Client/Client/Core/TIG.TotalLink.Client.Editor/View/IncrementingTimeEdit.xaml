<UserControl x:Class="TIG.TotalLink.Client.Editor.View.IncrementingTimeEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:mvvmService="clr-namespace:TIG.TotalLink.Client.Editor.MvvmService"
             xmlns:converter="clr-namespace:TIG.TotalLink.Client.Editor.Converter"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             x:Name="IncrementTimeView">

    <UserControl.Resources>
        <converter:MinuteToHourConverter x:Key="HourConverter" />
    </UserControl.Resources>

    <dxmvvm:Interaction.Behaviors>
        <mvvmService:IncrementingTimeDialogService x:Name="IncrementingTimeDialogService" />
    </dxmvvm:Interaction.Behaviors>

    <Button x:Name="PART_Editor"
            Click="ButtonInfo_OnClick"
            ClickMode="Press"
            HorizontalContentAlignment="Left">
        <TextBlock Text="{Binding ElementName=IncrementTimeView, 
                                  StringFormat='+ Add time to {0}', 
                                  Path=EditValue, 
                                  Mode=TwoWay,
                                  UpdateSourceTrigger=PropertyChanged,
                                  Converter={StaticResource HourConverter}}" />
    </Button>
</UserControl>