<UserControl x:Class="TIG.TotalLink.Client.Editor.View.UploadEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:io="clr-namespace:System.IO;assembly=mscorlib"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control"
             mc:Ignorable="d"
             x:Name="Root"
             d:DesignHeight="300"
             d:DesignWidth="300">
    <UserControl.Resources>
        <DataTemplate x:Key="UploadItemTemplate"
                      DataType="io:FileInfo">
            <Border BorderBrush="LightGray"
                    BorderThickness="0, 0, 0, 1"
                    Padding="2"
                    Margin="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>

                    <control:TextBlockEx Text="{Binding}"
                                         VerticalAlignment="Center"
                                         Margin="5,0,10,0" />
                    <dxe:ImageEdit Source="{dx:DXImage Image=Cancel_16x16.png}"
                                   Width="16"
                                   Height="16"
                                   Grid.Column="1"
                                   ShowBorder="False"
                                   ShowMenu="False">
                        <dxmvvm:Interaction.Behaviors>
                            <dxmvvm:EventToCommand EventName="MouseLeftButtonDown"
                                                   Command="{Binding DeleteCommand, ElementName=Root}"
                                                   CommandParameter="{Binding}" />
                        </dxmvvm:Interaction.Behaviors>
                    </dxe:ImageEdit>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid x:Name="LayoutRoot"
          AllowDrop="True">
        <dxmvvm:Interaction.Behaviors>
            <dxmvvm:EventToCommand EventName="Drop"
                                   Command="{Binding DropCommand, ElementName=Root}" />
        </dxmvvm:Interaction.Behaviors>
        <dxb:BarManager x:Name="BarManager"
                        ToolbarGlyphSize="Small"
                        MDIMergeStyle="Never"
                        AllowCustomization="False"
                        AllowHotCustomization="False"
                        AllowQuickCustomization="False"
                        dxb:MergingProperties.HideElements="False">
            <dxb:BarManager.Bars>

                <dxb:Bar x:Name="BarComment"
                         Caption="Comment"
                         ShowDragWidget="False"
                         AllowHide="False"
                         BarItemDisplayMode="ContentAndGlyph">
                    <dxb:Bar.DockInfo>
                        <dxb:BarDockInfo ContainerType="Top"
                                         Row="0"
                                         Column="0" />
                    </dxb:Bar.DockInfo>
                    <dxb:Bar.ItemLinks>
                        <dxb:BarButtonItemLink BarItemName="biNew" />
                        <dxb:BarButtonItemLink BarItemName="biDelete" />
                    </dxb:Bar.ItemLinks>
                </dxb:Bar>
            </dxb:BarManager.Bars>
            <dxb:BarManager.Items>
                <dxb:BarButtonItem x:Name="biNew"
                                   Content="Select Files"
                                   Glyph="{dx:DXImage Image=Open_32x32.png}"
                                   Alignment="Near"
                                   Command="{Binding AddCommand, ElementName=Root}" />
                <dxb:BarButtonItem x:Name="biDelete"
                                   Content="Clear List"
                                   Glyph="{dx:DXImage Image=Cancel_32x32.png}"
                                   Alignment="Near"
                                   Command="{Binding ClearCommand, ElementName=Root}" />
            </dxb:BarManager.Items>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemTemplate="{StaticResource UploadItemTemplate}"
                              ItemsSource="{Binding ItemsSource, ElementName=Root}"
                              MinHeight="25" />
            </ScrollViewer>
        </dxb:BarManager>
    </Grid>

</UserControl>
