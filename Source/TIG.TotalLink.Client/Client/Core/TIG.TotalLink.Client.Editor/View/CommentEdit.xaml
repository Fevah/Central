<UserControl x:Class="TIG.TotalLink.Client.Editor.View.CommentEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converter="clr-namespace:TIG.TotalLink.Client.Editor.Converter"
             xmlns:view="clr-namespace:TIG.TotalLink.Client.Editor.View"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             x:Name="CommentEditView">

    <UserControl.Resources>
        <converter:MultiStringConcatenationConverter x:Key="MultiStringConcatenationConverter" />
        <converter:UniversalDateTimeToLocalStringConverter x:Key="UniversalDateTimeToLocalStringConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.Resources>
            <DataTemplate x:Key="DisplayTemplate">
                <Border BorderThickness="0,0,0,1"
                        BorderBrush="Gray"
                        Margin="0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock FontWeight="Bold">
                            <TextBlock.Text>
                                <MultiBinding Mode="OneWay"
                                              Converter="{StaticResource MultiStringConcatenationConverter}"
                                              ConverterParameter=" - ">
                                    <Binding Path="UserId" />
                                    <Binding Path="UpdateTime"
                                             Converter="{StaticResource UniversalDateTimeToLocalStringConverter}" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <view:RichTextEdit EditValue="{Binding Path=Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           MinHeight="50"
                                           EditMode="InplaceInactive"
                                           Margin="0,0,0,5">
                            <view:RichTextEdit.Style>
                                <Style TargetType="{x:Type view:RichTextEdit}">
                                    <Setter Property="IsHitTestVisible"
                                            Value="False" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListBoxItem}, AncestorLevel=1}}"
                                                     Value="True">
                                            <Setter Property="IsHitTestVisible"
                                                    Value="True" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </view:RichTextEdit.Style>
                        </view:RichTextEdit>
                    </StackPanel>
                </Border>
            </DataTemplate>
            <DataTemplate x:Key="EditTemplate">
                <Border BorderThickness="0,0,0,1"
                        BorderBrush="Gray"
                        Margin="0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock FontWeight="Bold">
                            <TextBlock.Text>
                                <MultiBinding Mode="OneWay"
                                              Converter="{StaticResource MultiStringConcatenationConverter}"
                                              ConverterParameter=" - ">
                                    <Binding Path="UserId" />
                                    <Binding Path="UpdateTime"
                                             Converter="{StaticResource UniversalDateTimeToLocalStringConverter}" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <view:RichTextEdit EditValue="{Binding Path=Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           MinHeight="300"
                                           EditMode="InplaceActive"
                                           Margin="0,0,0,5"
                                           CancelCommand="{Binding ElementName=CommentEditView, Path=CancelCommentCommand}"
                                           SaveCommand="{Binding ElementName=CommentEditView, Path=SaveCommentCommand}" />
                    </StackPanel>
                </Border>
            </DataTemplate>
            <Style x:Key="CommentListStyle"
                   TargetType="ListBoxItem">
                <Style.Triggers>
                    <Trigger Property="IsSelected"
                             Value="True">
                        <Trigger.Setters>
                            <Setter Property="ContentTemplate"
                                    Value="{StaticResource EditTemplate}" />
                        </Trigger.Setters>
                    </Trigger>
                    <Trigger Property="IsSelected"
                             Value="False">
                        <Trigger.Setters>
                            <Setter Property="ContentTemplate"
                                    Value="{StaticResource DisplayTemplate}" />
                        </Trigger.Setters>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <ListBox x:Name="CommentList"
                 ItemsSource="{Binding ElementName=CommentEditView, Path=DataList, Mode=OneWay}"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemContainerStyle="{StaticResource CommentListStyle}" />
    </Grid>
</UserControl>
