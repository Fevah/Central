<UserControl x:Class="TIG.TotalLink.Client.Editor.View.Dialog.IncrementingTimeDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:viewModel="clr-namespace:TIG.TotalLink.Client.Editor.ViewModel"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance viewModel:IncrementingTimeDialogViewModel, IsDesignTimeCreatable=True}"
             >
    
    <dxlc:LayoutControl Orientation="Vertical" UseLayoutRounding="True">
        <dxlc:LayoutGroup View="Group" Orientation="Vertical">
            
            <dxlc:LayoutItem Label="Add Hours" AddColonToLabel="True">
                <dxe:SpinEdit EditValue="{Binding Hours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Mask="0.00"
                              MaskUseAsDisplayFormat="True">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:FocusBehavior/>
                    </dxmvvm:Interaction.Behaviors>
                </dxe:SpinEdit>
            </dxlc:LayoutItem>
            
        </dxlc:LayoutGroup>
    </dxlc:LayoutControl>
</UserControl>