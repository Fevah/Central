<dxe:PopupBaseEdit x:Class="TIG.TotalLink.Client.Editor.View.LookUpEdit"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                   xmlns:view="clr-namespace:TIG.TotalLink.Client.Editor.View"
                   mc:Ignorable="d"
                   d:DesignHeight="30"
                   d:DesignWidth="300"
                   x:Name="LookUpEditControl">

    <dxe:PopupBaseEdit.PopupContentTemplate>
        <ControlTemplate>
            <view:GridEdit x:Name="GridEditControl"
                           ColumnType="LookUp"
                           EditorDefinition="{Binding ElementName=LookUpEditControl, Path=EditorDefinition}" />
        </ControlTemplate>
    </dxe:PopupBaseEdit.PopupContentTemplate>

</dxe:PopupBaseEdit>