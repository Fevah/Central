<UserControl x:Class="TIG.TotalLink.Client.Module.Inventory.View.Widget.BinLocationListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Core;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Module.Admin.Control;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:widget="clr-namespace:TIG.TotalLink.Client.Module.Inventory.ViewModel.Widget"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance widget:BinLocationListViewModel, IsDesignTimeCreatable=True}">

    <control:WidgetCustomizationControl>

        <core:ListView ItemsSource="{Binding ItemsSource}"
                       SelectedItems="{Binding SelectedItems}"
                       CurrentItem="{Binding CurrentItem}" />

    </control:WidgetCustomizationControl>
</UserControl>
