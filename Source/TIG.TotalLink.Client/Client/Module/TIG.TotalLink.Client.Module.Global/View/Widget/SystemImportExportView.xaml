<UserControl x:Class="TIG.TotalLink.Client.Module.Global.View.Widget.SystemImportExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:widget="clr-namespace:TIG.TotalLink.Client.Module.Global.ViewModel.Widget"
             xmlns:core="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Core;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control;assembly=TIG.TotalLink.Client.Editor"
             xmlns:templateSelector="clr-namespace:TIG.TotalLink.Client.Editor.TemplateSelector;assembly=TIG.TotalLink.Client.Editor"
             xmlns:control1="clr-namespace:TIG.TotalLink.Client.Module.Admin.Control;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxgt="http://schemas.devexpress.com/winfx/2008/xaml/grid/themekeys"
             mc:Ignorable="d"
             x:Name="SystemImportExportControl"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance widget:SystemImportExportViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Editor;component/ResourceDictionary/DataLayoutItemEditorResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <templateSelector:DataLayoutItemTemplateSelector x:Key="DataLayoutItemTemplateSelector" />

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <dx:BoolToStringConverter x:Key="BoolToStringConverter"
                                      FalseString="Cancel"
                                      TrueString="Cancelling..." />
            <dx:BoolInverseConverter x:Key="BoolInverseConverter" />

            <!-- Style for the TreeList which aligns all checkboxes to the left -->
            <Style TargetType="{x:Type dxg:RowMarginControl}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Grid Background="{DynamicResource {dxgt:TreeListViewThemeKey ResourceKey=RowMarginBackgroundBrush}}">

                                <dxe:CheckEdit x:Name="PART_NodeCheckBox"
                                               Visibility="{Binding IsCheckBoxVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                               IsEnabled="{Binding IsCheckBoxEnabled}"
                                               IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               Focusable="False"
                                               IsThreeState="{Binding View.AllowIndeterminateCheckState}"
                                               Width="16"
                                               HorizontalAlignment="Left"
                                               Margin="6,0,0,0">
                                    <dxg:GridViewHitInfoBase.HitTestAcceptor>
                                        <dxg:TreeListNodeCheckboxHitTestAcceptor />
                                    </dxg:GridViewHitInfoBase.HitTestAcceptor>
                                </dxe:CheckEdit>

                                <Grid>
                                    <Path x:Name="PART_OffsetPath"
                                          Stroke="{TemplateBinding BorderBrush}"
                                          StrokeThickness="1" />
                                    <Path x:Name="PART_TreeLinePath"
                                          Stroke="{TemplateBinding BorderBrush}"
                                          StrokeThickness="1" />
                                    <dxg:IndentsPanel RowIndent="{Binding View.RowIndent}"
                                                      HorizontalAlignment="Right">
                                        <dxg:TreeListNodeExpandButton x:Name="PART_ExpandButton"
                                                                      Foreground="Black"
                                                                      HorizontalAlignment="Left"
                                                                      Command="{Binding View.Commands.ChangeNodeExpanded}"
                                                                      CommandParameter="{Binding RowHandle.Value}"
                                                                      IsChecked="{Binding IsExpanded}"
                                                                      IsExpandButtonVisible="{Binding Path=IsButtonVisible}" />

                                        <dx:MeasurePixelSnapper Visibility="{Binding IsImageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image x:Name="PART_NodeImage"
                                                   Focusable="False"
                                                   Source="{Binding Image, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="{Binding Path=View.NodeImageSize.Width}"
                                                   Height="{Binding Path=View.NodeImageSize.Height}">
                                                <dxg:GridViewHitInfoBase.HitTestAcceptor>
                                                    <dxg:TreeListNodeImageHitTestAcceptor />
                                                </dxg:GridViewHitInfoBase.HitTestAcceptor>
                                                <RenderOptions.BitmapScalingMode>NearestNeighbor</RenderOptions.BitmapScalingMode>
                                            </Image>
                                        </dx:MeasurePixelSnapper>
                                    </dxg:IndentsPanel>
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <control1:WidgetCustomizationControl>

        <Grid>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <control:DataLayoutControlEx x:Name="DataLayoutControl"
                                             Grid.Row="0"
                                             IsEnabled="{Binding IsImportExportActive, Converter={StaticResource BoolInverseConverter}}"
                                             EditorGeneratorTemplateSelector="{StaticResource DataLayoutItemTemplateSelector}"
                                             CurrentItem="{Binding CurrentItem}"
                                             ScrollBars="Auto"
                                             StretchContentVertically="False"
                                             UseLayoutRounding="True" />

                <dxg:TreeListControl Grid.Row="1"
                                     x:Name="TreeListControl"
                                     ItemsSource="{Binding Tables}"
                                     SelectionMode="Row"
                                     IsEnabled="{Binding IsImportExportActive, Converter={StaticResource BoolInverseConverter}}">
                    <dxg:TreeListControl.Columns>
                        <dxg:TreeListColumn FieldName="TableName"
                                            AllowEditing="False"
                                            Width="100"
                                            SortIndex="1">
                            <dxg:TreeListColumn.HeaderTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <dxe:CheckEdit Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Margin="2,0,4,0"
                                                       IsThreeState="True"
                                                       EditValue="{Binding AreAllChecked, ElementName=SystemImportExportControl}" />
                                        <ContentControl Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Content="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </dxg:TreeListColumn.HeaderTemplate>
                        </dxg:TreeListColumn>
                        <dxg:TreeListColumn FieldName="ExistingFileVersion"
                                            AllowEditing="False"
                                            FixedWidth="True"
                                            Width="130" />
                        <dxg:TreeListColumn FieldName="ModuleName"
                                            AllowEditing="False"
                                            Width="100"
                                            SortIndex="0" />
                        <dxg:TreeListColumn FieldName="TypeName"
                                            AllowEditing="False"
                                            Width="200" />
                    </dxg:TreeListControl.Columns>

                    <dxg:TreeListControl.View>
                        <dxg:TreeListView x:Name="TreeListView"
                                          TreeDerivationMode="Selfreference"
                                          KeyFieldName="Id"
                                          ParentFieldName="ParentId"
                                          AutoWidth="True"
                                          ShowCheckboxes="True"
                                          CheckBoxFieldName="IsChecked"
                                          ExpandStateFieldName="IsExpanded"
                                          NodeCheckStateChanged="TreeListView_NodeCheckStateChanged" />
                    </dxg:TreeListControl.View>
                </dxg:TreeListControl>

                <Grid Grid.Row="2"
                      Margin="2"
                      Visibility="{Binding IsImportExportActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="100"
                            Content="{Binding IsImportExportCancelling, Converter={StaticResource BoolToStringConverter}}"
                            Command="{Binding CancelImportExportCommand}" />

                    <dxe:ProgressBarEdit Grid.Column="1"
                                         Maximum="{Binding TotalTableCount}"
                                         Value="{Binding CompletedTableCount}"
                                         ContentDisplayMode="Value"
                                         IsPercent="True"
                                         DisplayFormatString="p0"
                                         Margin="4,0,4,0" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding ImportExportStatus}" />
                </Grid>
            </Grid>

            <core:WidgetLoadingPanelView />

        </Grid>

    </control1:WidgetCustomizationControl>

</UserControl>
