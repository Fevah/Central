    <!-- LayoutPanel style -->
    <Style TargetType="dxdo:LayoutPanel">
        <Setter Property="BindableName"
                Value="{Binding Oid, Mode=OneWay, Converter={StaticResource GuidToNameStringConverter}}" />
        <Setter Property="Caption"
                Value="{Binding Name}" />
        <Setter Property="CloseCommand"
                Value="{Binding PanelClosedCommand}" />
        <Setter Property="ControlBoxContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <dxdove:DockPaneControlBoxButton Style="{StaticResource DockPaneCustomizeButton}"
                                                     Visibility="{Binding DataContext.SupportsCustomization, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type dxdo:LayoutPanel}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDown">
                                <i:InvokeCommandAction Command="{Binding DataContext.ToggleCustomizationCommand, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type dxdo:LayoutPanel}}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </dxdove:DockPaneControlBoxButton>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--Panel content template-->
    <DataTemplate DataType="{x:Type documentVm:PanelViewModel}">
        <ContentPresenter Content="{Binding Content}" />
    </DataTemplate>

    <!-- Style for PageView item containers -->
    <Style TargetType="dxwui:PageViewItem">
        <Setter Property="Margin"
                Value="5,0" />
        <Setter Property="dxb:BarManager.DXContextMenu">
            <Setter.Value>
                <dxb:PopupMenu>
                    <dxb:BarButtonItem Content="Add Widget"
                                       Command="{Binding AddPanelCommand}" />
                    <dxb:BarItemSeparator />
                    <dxb:BarButtonItem Content="Add Group"
                                       Command="{Binding Document.AddPanelGroupCommand}" />
                    <dxb:BarButtonItem Content="Edit Group"
                                       Command="{Binding EditPanelGroupCommand}" />
                    <dxb:BarButtonItem Content="Delete Group"
                                       Command="{Binding DeletePanelGroupCommand}" />
                </dxb:PopupMenu>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PageView item template -->
    <DataTemplate x:Key="PageViewItemTemplate"
                  DataType="{x:Type documentVm:PanelGroupViewModel}">
        <TextBlock Text="{Binding Name}" />
    </DataTemplate>

    <!-- PageView content template -->
    <DataTemplate x:Key="PageViewContentTemplate"
                  DataType="{x:Type documentVm:PanelGroupViewModel}">
        <document:WidgetContainerView ActivateDocumentRibbonCommand="{Binding Document.ActivateDocumentRibbonCommand}"
                                      DocumentModifiedCommand="{Binding Document.DocumentModifiedCommand}" />
    </DataTemplate>

</ResourceDictionary>