<ResourceDictionary x:Class="TIG.TotalLink.Client.Module.Admin.ResourceDictionary.WidgetCustomizerResource"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:widgetCustomizer="clr-namespace:TIG.TotalLink.Client.Module.Admin.ViewModel.WidgetCustomizer"
                    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
                    xmlns:native="http://schemas.devexpress.com/winfx/2008/xaml/core/internal"
                    xmlns:control="clr-namespace:TIG.TotalLink.Client.Module.Admin.Control"
                    xmlns:core="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Core">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/TIG.TotalLink.Client.Editor;component/ResourceDictionary/DataLayoutItemEditorResource.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <dxmvvm:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"
                                         Inverse="True" />


    <!-- ******************************* -->
    <!-- * WIDGET CUSTOMIZER TEMPLATES * -->
    <!-- ******************************* -->


    <!-- Defines templates for widget customizers that appear within the WidgetCustomizationControl. -->


    <!-- Default -->
    <DataTemplate x:Key="DefaultWidgetCustomizerTemplate">
    </DataTemplate>


    <!-- Field -->
    <DataTemplate x:Key="FieldWidgetCustomizerTemplate"
                  DataType="widgetCustomizer:FieldWidgetCustomizerViewModel">

        <Grid>
            <dxlc:LayoutControlCustomizationControl x:Name="FieldCustomizationControl"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource FindAncestor, AncestorType=native:FastRenderPanel}}"
                                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource FindAncestor, AncestorType=native:FastRenderPanel}}"
                                                    Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <dxlc:LayoutControlCustomizationControl.Template>
                    <ControlTemplate TargetType="dxlc:LayoutControlCustomizationControl">
                        <dxlc:LayoutControlAvailableItemsControl x:Name="AvailableItemsElement"
                                                                 AvailableItems="{TemplateBinding AvailableItems}"
                                                                 NewItemsInfo="{TemplateBinding NewItemsInfo}"
                                                                 NewItemsUIVisibility="{TemplateBinding NewItemsUIVisibility}"
                                                                 Visibility="{TemplateBinding AvailableItemsUIVisibility}" />
                    </ControlTemplate>
                </dxlc:LayoutControlCustomizationControl.Template>

                <dxmvvm:Interaction.Behaviors>
                    <dxmvvm:EventToCommand EventName="Loaded"
                                           Command="{Binding SetCustomizationControlCommand}"
                                           CommandParameter="{Binding ElementName=FieldCustomizationControl}" />
                </dxmvvm:Interaction.Behaviors>
            </dxlc:LayoutControlCustomizationControl>

            <TextBlock Text="Fields will be available once an item is displayed in the form."
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="{Binding IsEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

        </Grid>
    </DataTemplate>


    <!-- Column -->
    <DataTemplate x:Key="ColumnWidgetCustomizerTemplate"
                  DataType="widgetCustomizer:ColumnWidgetCustomizerViewModel">

        <control:StandaloneColumnChooserControl View="{Binding View}" />

    </DataTemplate>


    <!-- Grid -->
    <DataTemplate x:Key="GridWidgetCustomizerTemplate"
                  DataType="widgetCustomizer:GridWidgetCustomizerViewModel">

        <core:LocalDetailView FormPadding="0" />

    </DataTemplate>


    <!-- Form -->
    <DataTemplate x:Key="FormWidgetCustomizerTemplate"
                  DataType="widgetCustomizer:FormWidgetCustomizerViewModel">

        <Grid>
            <core:LocalDetailView FormPadding="0"
                                  Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <TextBlock Text="Form options will be available once an item is displayed in the form."
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="{Binding IsEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        </Grid>

    </DataTemplate>


    <!-- Data -->
    <DataTemplate x:Key="DataWidgetCustomizerTemplate"
                  DataType="widgetCustomizer:DataWidgetCustomizerViewModel">

        <core:LocalDetailView FormPadding="0" />

    </DataTemplate>


    <!-- Link -->
    <DataTemplate x:Key="LinkWidgetCustomizerTemplate"
                  DataType="widgetCustomizer:LinkWidgetCustomizerViewModel">

        <core:LocalDetailView FormPadding="0" />

    </DataTemplate>


    <!-- Filter -->
    <DataTemplate x:Key="FilterWidgetCustomizerTemplate"
                  DataType="widgetCustomizer:FilterWidgetCustomizerViewModel">

        <core:LocalDetailView FormPadding="0" />

    </DataTemplate>


</ResourceDictionary>