<UserControl x:Class="TIG.TotalLink.Client.Module.Admin.View.Document.DocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
             xmlns:documentVm="clr-namespace:TIG.TotalLink.Client.Module.Admin.ViewModel.Document"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:view="clr-namespace:TIG.TotalLink.Client.Core.View;assembly=TIG.TotalLink.Client.Core"
             xmlns:document="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Document"
             xmlns:admin="clr-namespace:TIG.TotalLink.Shared.DataModel.Core.Enum.Admin;assembly=TIG.TotalLink.Shared.DataModel.Core"
             xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"
             xmlns:mvvmService="clr-namespace:TIG.TotalLink.Client.Module.Admin.MvvmService"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance documentVm:DocumentViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Module.Admin;component/ResourceDictionary/DocumentResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <dxmvvm:ObjectToObjectConverter x:Key="FlatViewVisibilityConverter"
                                            DefaultTarget="{x:Static Visibility.Collapsed}">
                <dxmvvm:MapItem Source="{x:Null}"
                                Target="{x:Static Visibility.Visible}" />
                <dxmvvm:MapItem Source="{x:Static admin:DocumentView.Flat}"
                                Target="{x:Static Visibility.Visible}" />
            </dxmvvm:ObjectToObjectConverter>

            <dxmvvm:ObjectToObjectConverter x:Key="PageViewVisibilityConverter"
                                            DefaultTarget="{x:Static Visibility.Collapsed}">
                <dxmvvm:MapItem Source="{x:Static admin:DocumentView.Pages}"
                                Target="{x:Static Visibility.Visible}" />
            </dxmvvm:ObjectToObjectConverter>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <dxr:RibbonControl x:Name="RibbonControl"
                           Grid.Row="0"
                           RibbonStyle="Office2010"
                           ToolbarShowMode="Hide"
                           ShowApplicationButton="False">
            <dxr:RibbonPageCategory Color="IndianRed"
                                    Caption=" ">
                <dxr:RibbonPage x:Name="DocumentRibbonPage"
                                Caption="{Binding Title, Mode=OneWay}"
                                GroupsSource="{Binding RibbonGroups, Mode=OneWay}"
                                GroupTemplate="{StaticResource RibbonGroupTemplate}" />
            </dxr:RibbonPageCategory>
        </dxr:RibbonControl>

        <document:WidgetContainerView x:Name="WidgetContainerView"
                                      Grid.Row="1"
                                      ActivateDocumentRibbonCommand="{Binding ActivateDocumentRibbonCommand}"
                                      DocumentModifiedCommand="{Binding DocumentModifiedCommand}"
                                      Visibility="{Binding DataObject.View, Converter={StaticResource FlatViewVisibilityConverter}}" />

        <dxwui:PageView x:Name="PageView"
                        Grid.Row="1"
                        PageHeadersLayoutType="Scroll"
                        ItemCacheMode="CacheAll"
                        ItemsSource="{Binding PanelGroups}"
                        ItemTemplate="{StaticResource PageViewItemTemplate}"
                        ContentTemplate="{StaticResource PageViewContentTemplate}"
                        Header="{Binding Title}"
                        Visibility="{Binding DataObject.View, Converter={StaticResource PageViewVisibilityConverter}}"
                        AnimationType="SlideHorizontal"
                        SelectedItem="{Binding ActiveGroup}">
            <dxmvvm:Interaction.Behaviors>
                <mvvmService:PageViewNavigationService />
            </dxmvvm:Interaction.Behaviors>
        </dxwui:PageView>

        <view:LoadingPanelView Grid.Row="0"
                               Grid.RowSpan="2"
                               Visibility="{Binding IsLoadingPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue={x:Static Visibility.Collapsed}}" />

    </Grid>
</UserControl>
