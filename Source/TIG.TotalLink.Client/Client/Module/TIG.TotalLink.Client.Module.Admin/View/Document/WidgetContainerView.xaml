<UserControl x:Class="TIG.TotalLink.Client.Module.Admin.View.Document.WidgetContainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:layout="clr-namespace:TIG.TotalLink.Client.Module.Admin.Layout"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             mc:Ignorable="d"
             x:Name="WidgetContainerViewControl"
             d:DesignHeight="300"
             d:DesignWidth="300">

    <dxdo:DockLayoutManager x:Name="DocumentViewDockLayoutManager"
                            ItemsSource="{Binding FilteredPanels, Mode=OneWay}"
                            ClosingBehavior="ImmediatelyRemove"
                            AllowDocumentSelector="False"
                            ClosedPanelsBarVisibility="Never"
                            dxdo:RestoreLayoutOptions.AddNewPanels="False"
                            dxdo:RestoreLayoutOptions.RemoveOldPanels="False"
                            ShowingMenu="DocumentViewDockLayoutManager_ShowingMenu">

        <dxmvvm:Interaction.Behaviors>
            <dxmvvm:EventToCommand EventName="PreviewMouseDown"
                                   Command="{Binding ActivateDocumentRibbonCommand, ElementName=WidgetContainerViewControl}" />
            <dxmvvm:EventToCommand EventName="DockOperationCompleted"
                                   Command="{Binding DocumentModifiedCommand, ElementName=WidgetContainerViewControl}" />
            <dxmvvm:EventToCommand EventName="LayoutItemSizeChanged"
                                   Command="{Binding DocumentModifiedCommand, ElementName=WidgetContainerViewControl}" />
        </dxmvvm:Interaction.Behaviors>

        <dxdo:MVVMHelper.LayoutAdapter>
            <layout:DocumentLayoutAdapter />
        </dxdo:MVVMHelper.LayoutAdapter>

        <dxdo:LayoutGroup x:Name="RootLayoutGroup"
                          DestroyOnClosingChildren="False" />

    </dxdo:DockLayoutManager>
</UserControl>
