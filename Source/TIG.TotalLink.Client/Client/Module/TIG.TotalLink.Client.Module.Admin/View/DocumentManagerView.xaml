<UserControl x:Class="TIG.TotalLink.Client.Module.Admin.View.DocumentManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:document="clr-namespace:TIG.TotalLink.Client.Module.Admin.ViewModel.Document"
             xmlns:converter="clr-namespace:TIG.TotalLink.Client.Module.Admin.Converter"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300">

    <UserControl.Resources>
        <dx:BoolInverseConverter x:Key="BoolInverseConverter" />
    </UserControl.Resources>

    <dxmvvm:Interaction.Behaviors>
        <dx:DXMessageBoxService />
    </dxmvvm:Interaction.Behaviors>

    <dxdo:DockLayoutManager x:Name="DocumentManagerViewDockLayoutManager"
                            FloatingMode="Desktop"
                            ClosingBehavior="ImmediatelyRemove"
                            ClosedPanelsBarVisibility="Never">

        <dxmvvm:Interaction.Behaviors>
            <dxmvvm:EventToCommand EventName="DockItemActivated"
                                   Command="{Binding ActivateDocumentRibbonCommand}">
                <dxmvvm:EventToCommand.EventArgsConverter>
                    <converter:DockItemActivatedEventArgsConverter />
                </dxmvvm:EventToCommand.EventArgsConverter>
            </dxmvvm:EventToCommand>
        </dxmvvm:Interaction.Behaviors>

        <dxdo:DockLayoutManager.ContextMenuCustomizations>
            <dxb:BarButtonItem Content="Add Widget"
                               CategoryName="Document"
                               dxb:BarItemLinkActionBase.ItemLinkIndex="0"
                               IsVisible="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.IsFixed), ElementName=DocumentManagerViewDockLayoutManager, Converter={StaticResource BoolInverseConverter}}"
                               Command="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.AddPanelCommand), ElementName=DocumentManagerViewDockLayoutManager}" />
            
            <dxb:InsertBarItemLinkAction ItemLinkIndex="1">
                <dxb:BarItemLinkSeparator BarItemName="{x:Null}" />
            </dxb:InsertBarItemLinkAction>
            
            <dxb:BarButtonItem Content="Add Group"
                               CategoryName="Document"
                               dxb:BarItemLinkActionBase.ItemLinkIndex="2"
                               IsVisible="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.IsFixed), ElementName=DocumentManagerViewDockLayoutManager, Converter={StaticResource BoolInverseConverter}}"
                               Command="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.AddPanelGroupCommand), ElementName=DocumentManagerViewDockLayoutManager}" />

            <dxb:InsertBarItemLinkAction ItemLinkIndex="3">
                <dxb:BarItemLinkSeparator BarItemName="{x:Null}" />
            </dxb:InsertBarItemLinkAction>

            <dxb:BarButtonItem Content="Edit Document"
                               CategoryName="Document"
                               dxb:BarItemLinkActionBase.ItemLinkIndex="4"
                               IsVisible="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.IsFixed), ElementName=DocumentManagerViewDockLayoutManager, Converter={StaticResource BoolInverseConverter}}"
                               Command="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.EditDocumentCommand), ElementName=DocumentManagerViewDockLayoutManager}" />

            <dxb:BarButtonItem Content="Save Document"
                               CategoryName="Document"
                               dxb:BarItemLinkActionBase.ItemLinkIndex="5"
                               IsVisible="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.IsFixed), ElementName=DocumentManagerViewDockLayoutManager, Converter={StaticResource BoolInverseConverter}}"
                               IsEnabled="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.IsModified), ElementName=DocumentManagerViewDockLayoutManager}"
                               Command="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.SaveDocumentCommand), ElementName=DocumentManagerViewDockLayoutManager}"
                               CommandParameter="False" />

            <dxb:BarButtonItem Content="Save Document As..."
                               CategoryName="Document"
                               dxb:BarItemLinkActionBase.ItemLinkIndex="6"
                               IsVisible="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.IsFixed), ElementName=DocumentManagerViewDockLayoutManager, Converter={StaticResource BoolInverseConverter}}"
                               Command="{Binding Path=ActiveDockItem.(dxmvvm:DocumentUIServiceBase.Document).Content.(document:DocumentViewModel.SaveDocumentCommand), ElementName=DocumentManagerViewDockLayoutManager}"
                               CommandParameter="True" />

            <dxb:InsertBarItemLinkAction ItemLinkIndex="7">
                <dxb:BarItemLinkSeparator BarItemName="{x:Null}" />
            </dxb:InsertBarItemLinkAction>
        </dxdo:DockLayoutManager.ContextMenuCustomizations>

        <dxdo:LayoutGroup Orientation="Vertical">
            <dxmvvm:Interaction.Behaviors>
                <dxdo:TabbedDocumentUIService DocumentGroup="{Binding ElementName=DocumentGroup}" />
            </dxmvvm:Interaction.Behaviors>
            <dxdo:DocumentGroup x:Name="DocumentGroup"
                                Caption="Documents"
                                ItemHeight="*"
                                ClosePageButtonShowMode="InAllTabPagesAndTabControlHeader" />
        </dxdo:LayoutGroup>
    </dxdo:DockLayoutManager>

</UserControl>
