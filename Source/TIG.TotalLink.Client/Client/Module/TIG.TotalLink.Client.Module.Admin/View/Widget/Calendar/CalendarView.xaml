<UserControl x:Class="TIG.TotalLink.Client.Module.Admin.View.Widget.Calendar.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:scheduler="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Core.Scheduler"
             xmlns:calendar="clr-namespace:TIG.TotalLink.Client.Module.Admin.ViewModel.Widget.Calendar"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="3000"
             d:DataContext="{d:DesignInstance calendar:CalendarViewModel, IsDesignTimeCreatable=True}">

    <!--<control:WidgetCustomizationControl>-->
    <scheduler:SchedulerView ItemsSource="{Binding ItemsSource}"
                             SelectedAppointment="{Binding SelectedItem}" />
    <!--</control:WidgetCustomizationControl>-->

</UserControl>
