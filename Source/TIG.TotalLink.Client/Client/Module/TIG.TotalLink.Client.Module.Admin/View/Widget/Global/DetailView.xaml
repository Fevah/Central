<UserControl x:Class="TIG.TotalLink.Client.Module.Admin.View.Widget.Global.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:global="clr-namespace:TIG.TotalLink.Client.Module.Admin.ViewModel.Widget.Global"
             xmlns:serialization="clr-namespace:DevExpress.Xpf.LayoutControl.Serialization;assembly=DevExpress.Xpf.LayoutControl.v15.1"
             xmlns:templateSelector="clr-namespace:TIG.TotalLink.Client.Editor.TemplateSelector;assembly=TIG.TotalLink.Client.Editor"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control;assembly=TIG.TotalLink.Client.Editor"
             xmlns:control1="clr-namespace:TIG.TotalLink.Client.Module.Admin.Control"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance global:DetailViewModel, IsDesignTimeCreatable=True}"
             x:Name="DetailViewControl"
             Loaded="DetailViewControl_Loaded"
             Unloaded="DetailViewControl_Unloaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Editor;component/ResourceDictionary/DataLayoutItemEditorResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <templateSelector:DataLayoutItemTemplateSelector x:Key="DataLayoutItemTemplateSelector" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <control1:WidgetCustomizationControl>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding CurrentItemDescription}"
                       TextAlignment="Center"
                       Visibility="{Binding ShowHeader, ElementName=DataLayoutControl, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <control:DataLayoutControlEx x:Name="DataLayoutControl"
                                         Grid.Row="1"
                                         CurrentItem="{Binding CurrentItem}"
                                         EditorGeneratorTemplateSelector="{StaticResource DataLayoutItemTemplateSelector}"
                                         ScrollBars="Auto"
                                         serialization:RestoreLayoutOptions.AddNewItems="False"
                                         serialization:RestoreLayoutOptions.RemoveOldItems="False" />
        </Grid>

    </control1:WidgetCustomizationControl>

</UserControl>
