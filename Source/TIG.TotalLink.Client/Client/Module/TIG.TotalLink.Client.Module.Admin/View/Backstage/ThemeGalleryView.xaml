<UserControl x:Class="TIG.TotalLink.Client.Module.Admin.View.Backstage.ThemeGalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:backstage="clr-namespace:TIG.TotalLink.Client.Module.Admin.ViewModel.Backstage"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance backstage:ThemeGalleryViewModel, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.MergedDictionaries>
                    <ResourceDictionary Source="/TIG.TotalLink.Client.Module.Admin;component/ResourceDictionary/GalleryResource.xaml" />
                </ResourceDictionary.MergedDictionaries>
            </ResourceDictionary>
        </Grid.Resources>

        <dxb:GalleryControl>
            <dxb:GalleryControl.Gallery>
                <dxb:Gallery x:Name="Gallery"
                             GroupTemplate="{StaticResource GalleryGroupTemplate}"
                             GroupsSource="{Binding GalleryGroups}"
                             ItemClickCommand="{Binding ItemClickCommand}"
                             ItemCheckMode="Single"
                             IsItemDescriptionVisible="False"
                             ItemGlyphLocation="Top"
                             ItemGlyphStretch="Uniform"
                             ItemGlyphMargin="2,2"
                             ItemCaptionHorizontalAlignment="Center"
                             ItemCaptionVerticalAlignment="Top"
                             AllowFilter="False"
                             AllowSmoothScrolling="True" />
            </dxb:GalleryControl.Gallery>
        </dxb:GalleryControl>
    </Grid>
</UserControl>
