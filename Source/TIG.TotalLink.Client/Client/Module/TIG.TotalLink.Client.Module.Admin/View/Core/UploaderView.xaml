<UserControl xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:templateSelector="clr-namespace:TIG.TotalLink.Client.Editor.TemplateSelector;assembly=TIG.TotalLink.Client.Editor"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control;assembly=TIG.TotalLink.Client.Editor"
             x:Class="TIG.TotalLink.Client.Module.Admin.View.Core.UploaderView"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="600"
             x:Name="UploaderViewControl"
             DataContextChanged="UploaderViewControl_DataContextChanged">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Editor;component/ResourceDictionary/GridColumnEditorResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <templateSelector:GridColumnTemplateSelector x:Key="GridColumnTemplateSelector" />

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <dx:BoolToStringConverter x:Key="BoolToStringConverter"
                                      FalseString="Cancel"
                                      TrueString="Cancelling..." />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <control:GridControlEx x:Name="GridControl"
                               Grid.Row="0"
                               ShowBorder="False"
                               SelectionMode="Row"
                               ItemsSource="{Binding ItemsSource}"
                               SelectedItems="{Binding SelectedItems}"
                               ColumnsSource="{Binding Columns}"
                               ColumnGeneratorTemplateSelector="{StaticResource GridColumnTemplateSelector}">
            <control:GridControlEx.View>
                <control:TableViewEx x:Name="TableView"
                                     AllowGrouping="False"
                                     ShowGroupPanel="False" />
            </control:GridControlEx.View>
        </control:GridControlEx>

        <Grid Grid.Row="1"
              Margin="2"
              Visibility="{Binding IsUploadActive, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="100"
                    Content="{Binding IsCancelling, Converter={StaticResource BoolToStringConverter}}"
                    Command="{Binding CancelUploadCommand}" />

            <dxe:ProgressBarEdit Grid.Column="1"
                                 Maximum="{Binding TotalRowCount}"
                                 Value="{Binding CompletedRowCount}"
                                 ContentDisplayMode="Value"
                                 IsPercent="True"
                                 DisplayFormatString="p0"
                                 Margin="4,0,4,0" />

            <TextBlock Grid.Column="2"
                       Text="{Binding UploadStatus}" />
        </Grid>
    </Grid>

</UserControl>
