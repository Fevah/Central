<UserControl x:Class="TIG.TotalLink.Client.Module.Admin.View.Core.ListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control;assembly=TIG.TotalLink.Client.Editor"
             xmlns:converter="clr-namespace:TIG.TotalLink.Client.Core.Converter;assembly=TIG.TotalLink.Client.Core"
             xmlns:templateSelector="clr-namespace:TIG.TotalLink.Client.Editor.TemplateSelector;assembly=TIG.TotalLink.Client.Editor"
             xmlns:core="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Core"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             x:Name="ListViewControl"
             DataContextChanged="ListViewControl_DataContextChanged"
             Loaded="ListViewControl_Loaded"
             Unloaded="ListViewControl_Unloaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Editor;component/ResourceDictionary/GridColumnEditorResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <templateSelector:GridColumnTemplateSelector x:Key="GridColumnTemplateSelector" />
            <converter:ThreadSafeProxyToObjectConverter x:Key="ThreadSafeProxyToObjectConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>

        <control:GridControlEx x:Name="GridControl"
                               ItemsSource="{Binding ItemsSource, ElementName=ListViewControl}"
                               CurrentItem="{Binding CurrentItem, ElementName=ListViewControl, Mode=OneWayToSource, Converter={StaticResource ThreadSafeProxyToObjectConverter}}"
                               ColumnsSource="{Binding Columns}"
                               ColumnGeneratorTemplateSelector="{StaticResource GridColumnTemplateSelector}"
                               ShowBorder="False"
                               SelectionMode="Row"
                               SelectionChanged="GridControl_SelectionChanged"
                               AsyncOperationCompleted="GridControl_AsyncOperationCompleted"
                               ItemsSourceChanged="GridControl_ItemsSourceChanged"
                               FilterCriteria="{Binding FilterCriteria, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand EventName="Loaded"
                                       Command="{Binding GridLoadedCommand}"
                                       CommandParameter="{Binding View, ElementName=GridControl}" />
                <dxmvvm:EventToCommand EventName="StartGrouping"
                                       Command="{Binding DocumentModifiedCommand}" />
                <dxmvvm:EventToCommand EventName="FilterChanged"
                                       Command="{Binding DocumentModifiedCommand}" />
            </dxmvvm:Interaction.Behaviors>

            <control:GridControlEx.View>
                <control:TableViewEx x:Name="TableView"
                                     UseAddDialog="{Binding UseAddDialog}"
                                     AutoFilter="{Binding AutoFilter}"
                                     TypeWrapper="{Binding TypeWrapper}"
                                     CheckBoxSelectorColumnWidth="30"
                                     FocusedRowChanged="TableView_FocusedRowChanged" />

            </control:GridControlEx.View>
        </control:GridControlEx>

        <core:WidgetLoadingPanelView />

    </Grid>
</UserControl>
