<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:templateSelector="clr-namespace:TIG.TotalLink.Client.Editor.TemplateSelector;assembly=TIG.TotalLink.Client.Editor"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Editor.Control;assembly=TIG.TotalLink.Client.Editor"
             xmlns:core="clr-namespace:TIG.TotalLink.Client.Module.Admin.ViewModel.Core"
             xmlns:core1="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Core"
             x:Class="TIG.TotalLink.Client.Module.Admin.View.Core.LocalDetailView"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             x:Name="LocalDetailViewControl"
             d:DataContext="{d:DesignInstance d:Type=core:LocalDetailViewModelBase, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Editor;component/ResourceDictionary/DataLayoutItemEditorResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <templateSelector:DataLayoutItemTemplateSelector x:Key="DataLayoutItemTemplateSelector" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>

        <control:DataLayoutControlEx x:Name="DataLayoutControl"
                                     EditorGeneratorTemplateSelector="{StaticResource DataLayoutItemTemplateSelector}"
                                     CurrentItem="{Binding CurrentItem}"
                                     Padding="{Binding Path=FormPadding, ElementName=LocalDetailViewControl}"
                                     ScrollBars="Auto"
                                     StretchContentVertically="False"
                                     UseLayoutRounding="True" />

        <core1:WidgetLoadingPanelView />

    </Grid>
</UserControl>
