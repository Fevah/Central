<UserControl x:Class="TIG.TotalLink.Client.Module.Sale.View.Widget.SalesOrder.SalesOrderListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:TIG.TotalLink.Client.Module.Admin.View.Core;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Module.Admin.Control;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:salesOrder="clr-namespace:TIG.TotalLink.Client.Module.Sale.ViewModel.Widget.SalesOrder"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance salesOrder:SalesOrderListViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <dx:BoolToStringConverter x:Key="BoolToStringConverter"
                                      FalseString="Cancel"
                                      TrueString="Cancelling..." />
        </ResourceDictionary>
    </UserControl.Resources>

    <control:WidgetCustomizationControl>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <core:ListView Grid.Row="0"
                           ItemsSource="{Binding ItemsSource}"
                           SelectedItems="{Binding SelectedItems}"
                           CurrentItem="{Binding CurrentItem}" />

            <Grid Grid.Row="1"
                  Margin="2"
                  Visibility="{Binding IsReleaseActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="100"
                        Content="{Binding IsReleaseCancelling, Converter={StaticResource BoolToStringConverter}}"
                        Command="{Binding CancelReleaseCommand}" />

                <dxe:ProgressBarEdit Grid.Column="1"
                                     Maximum="{Binding TotalReleaseCount}"
                                     Value="{Binding CompletedReleaseCount}"
                                     ContentDisplayMode="Value"
                                     IsPercent="True"
                                     DisplayFormatString="p0"
                                     Margin="4,0,4,0" />

                <TextBlock Grid.Column="2"
                           Text="{Binding ReleaseStatus}" />

            </Grid>
        </Grid>

    </control:WidgetCustomizationControl>

</UserControl>
