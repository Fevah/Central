<UserControl x:Class="TIG.TotalLink.Client.Module.Sale.View.Widget.Quote.QuoteTreeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:core="clr-namespace:TIG.TotalLink.Client.MVVM.View.Core;assembly=TIG.TotalLink.Client.MVVM"
             xmlns:control="clr-namespace:TIG.TotalLink.Client.Module.Admin.Control;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:quote="clr-namespace:TIG.TotalLink.Client.Module.Sale.ViewModel.Widget.Quote"
             xmlns:converter="clr-namespace:TIG.TotalLink.Client.MVVM.Converter;assembly=TIG.TotalLink.Client.MVVM"
             xmlns:service="clr-namespace:TIG.TotalLink.Shared.DataModel.Sale;assembly=TIG.TotalLink.Client.Facade.Sale"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance quote:QuoteTreeListViewModel, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <converter:MethodToValueConverter x:Key="MethodToValueConverter" />

        <HierarchicalDataTemplate DataType="{x:Type service:Quote}"
                                  ItemsSource="{Binding Converter={StaticResource MethodToValueConverter},
                                                        ConverterParameter='GetChildItemsList(QuoteVersions)'}" />

        <HierarchicalDataTemplate DataType="{x:Type service:QuoteVersion}" />

    </UserControl.Resources>

    <control:WidgetCustomizationControl>
        <core:TreeListView ItemsSource="{Binding ItemsInstantFeedbackSource}"
                           SelectedItems="{Binding SelectedItems}"
                           CurrentItem="{Binding CurrentItem}" />
    </control:WidgetCustomizationControl>

</UserControl>
