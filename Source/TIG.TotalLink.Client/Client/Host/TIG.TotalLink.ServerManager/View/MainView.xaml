<UserControl x:Class="TIG.TotalLink.ServerManager.View.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModel="clr-namespace:TIG.TotalLink.ServerManager.ViewModel"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
             xmlns:view="clr-namespace:TIG.TotalLink.Client.Module.Admin.View;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:mvvmService="clr-namespace:TIG.TotalLink.Client.Module.Admin.MvvmService;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance viewModel:MainViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Module.Admin;component/ResourceDictionary/BackstageResource.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <dxmvvm:Interaction.Behaviors>
        <mvvmService:DetailDialogService />
    </dxmvvm:Interaction.Behaviors>

    <dxb:BarManager>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <dxr:RibbonControl Grid.Row="0"
                               x:Name="RibbonControl"
                               RibbonStyle="Office2010"
                               ToolbarShowCustomizationButton="False"
                               AllowCustomization="False">
            </dxr:RibbonControl>

            <view:DocumentManagerView Grid.Row="1"
                                      RibbonControl="{Binding ElementName=RibbonControl}" />

            <dxr:RibbonStatusBarControl Grid.Row="2">
            </dxr:RibbonStatusBarControl>
        </Grid>
    </dxb:BarManager>

</UserControl>
