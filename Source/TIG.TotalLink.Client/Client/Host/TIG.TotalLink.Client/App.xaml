<Application x:Class="TIG.TotalLink.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:appContext="clr-namespace:TIG.TotalLink.Client.Core.AppContext;assembly=TIG.TotalLink.Client.Core"
             DispatcherUnhandledException="App_DispatcherUnhandledException">
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Editor;component/ResourceDictionary/EditorStyleResource.xaml" />
                <ResourceDictionary Source="/TIG.TotalLink.Client.Module.Admin;component/ResourceDictionary/WidgetCustomizerResource.xaml" />
                <ResourceDictionary Source="/TIG.TotalLink.Client.Module.Admin;component/ResourceDictionary/WidgetResource.xaml" />
                <ResourceDictionary Source="/TIG.TotalLink.Client.Module.Admin;component/ResourceDictionary/RibbonResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <appContext:AppContextProvider x:Key="AppContextProvider" />
        </ResourceDictionary>
    </Application.Resources>
    
</Application>
