<UserControl x:Class="TIG.TotalLink.Client.View.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
             xmlns:view="clr-namespace:TIG.TotalLink.Client.Module.Admin.View;assembly=TIG.TotalLink.Client.Module.Admin"
             xmlns:viewModel="clr-namespace:TIG.TotalLink.Client.ViewModel"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:converter="clr-namespace:TIG.TotalLink.Client.Converter"
             xmlns:mvvmService="clr-namespace:TIG.TotalLink.Client.Module.Admin.MvvmService;assembly=TIG.TotalLink.Client.Module.Admin"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             d:DataContext="{d:DesignInstance viewModel:MainViewModel, IsDesignTimeCreatable=True}"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/TIG.TotalLink.Client.Module.Admin;component/ResourceDictionary/BackstageResource.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <dxmvvm:Interaction.Behaviors>
        <mvvmService:DetailDialogService />

        <mvvmService:RenameDialogService />
    </dxmvvm:Interaction.Behaviors>

    <dxb:BarManager>
        <dxb:BarManager.Items>
            <dxb:BarButtonItem x:Name="biAddRibbonCategory"
                               Content="Add Category"
                               Command="{Binding AddRibbonCategoryCommand}" />
            <dxb:BarButtonItem x:Name="biEditRibbonCategory"
                               Content="Edit Category"
                               Command="{Binding EditRibbonCategoryCommand}" />
            <dxb:BarButtonItem x:Name="biDeleteRibbonCategory"
                               Content="Delete Category"
                               Command="{Binding DeleteRibbonCategoryCommand}" />
            <dxb:BarButtonItem x:Name="biAddRibbonPage"
                               Content="Add Page"
                               Command="{Binding AddRibbonPageCommand}" />
            <dxb:BarButtonItem x:Name="biEditRibbonPage"
                               Content="Edit Page"
                               Command="{Binding EditRibbonPageCommand}" />
            <dxb:BarButtonItem x:Name="biDeleteRibbonPage"
                               Content="Delete Page"
                               Command="{Binding DeleteRibbonPageCommand}" />
            <dxb:BarButtonItem x:Name="biAddRibbonGroup"
                               Content="Add Group"
                               Command="{Binding AddRibbonGroupCommand}" />
            <dxb:BarButtonItem x:Name="biEditRibbonGroup"
                               Content="Edit Group"
                               Command="{Binding EditRibbonGroupCommand}" />
            <dxb:BarButtonItem x:Name="biDeleteRibbonGroup"
                               Content="Delete Group"
                               Command="{Binding DeleteRibbonGroupCommand}" />
            <dxb:BarButtonItem x:Name="biAddRibbonItem"
                               Content="Add Item"
                               Command="{Binding AddRibbonItemCommand}" />
            <dxb:BarButtonItem x:Name="biEditRibbonItem"
                               Content="Edit Item"
                               Command="{Binding EditRibbonItemCommand}" />
            <dxb:BarButtonItem x:Name="biDeleteRibbonItem"
                               Content="Delete Item"
                               Command="{Binding DeleteRibbonItemCommand}" />
            <dxb:BarSplitButtonItem x:Name="biUndo"
                                    Content="Undo"
                                    Glyph="/TIG.TotalLink.Client;component/Image/Icon/16x16/Undo.png"
                                    KeyGesture="CTRL+Z"
                                    Command="{Binding UndoCommand}">
                <dxb:BarSplitButtonItem.PopupControl>
                    <dxb:PopupControlContainer x:Name="UndoListPopupContainer">
                        <Grid Width="Auto"
                              Height="Auto">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <dxe:ListBoxEdit x:Name="UndoList"
                                             DisplayMember="Description"
                                             SelectionMode="Extended"
                                             ItemsSource="{Binding UndoStack}"
                                             EditValue="{Binding SelectedUndos, Mode=TwoWay}"
                                             PreviewMouseRightButtonDown="UndoList_PreviewMouseRightButtonDown"
                                             BorderThickness="0"
                                             HorizontalContentAlignment="Stretch">
                                <dxe:ListBoxEdit.ItemContainerStyle>
                                    <Style TargetType="dxe:ListBoxEditItem">
                                        <Setter Property="Margin"
                                                Value="0" />
                                    </Style>
                                </dxe:ListBoxEdit.ItemContainerStyle>
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand EventName="MouseLeave"
                                                           Command="{Binding ClearUndoSelectionCommand}" />
                                    <!--<dxmvvm:EventToCommand EventName="PreviewMouseLeftButtonDown"
                                                           Command="{Binding ExecuteSelectedUndoCommand}"
                                                           CommandParameter="{Binding ElementName=UndoListPopupContainer}" />-->
                                    <dxmvvm:EventToCommand EventName="MouseMove"
                                                           Command="{Binding ChangeUndoSelectionCommand}">
                                        <dxmvvm:EventToCommand.EventArgsConverter>
                                            <converter:ListViewMouseMoveEventArgsConverter />
                                        </dxmvvm:EventToCommand.EventArgsConverter>
                                    </dxmvvm:EventToCommand>
                                </dxmvvm:Interaction.Behaviors>
                                <dxb:BarManager.DXContextMenu>
                                    <dxb:PopupMenu StaysOpen="False">
                                        <dxb:PopupMenu.Items>
                                            <dxb:BarButtonItem Content="View Change Set"
                                                               Command="{Binding ViewChangeSetCommand}" />
                                        </dxb:PopupMenu.Items>
                                    </dxb:PopupMenu>
                                </dxb:BarManager.DXContextMenu>
                            </dxe:ListBoxEdit>
                            <TextBlock Grid.Row="1"
                                       Visibility="{Binding UndoLabelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Text="{Binding UndoLabelContent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </dxb:PopupControlContainer>
                </dxb:BarSplitButtonItem.PopupControl>
            </dxb:BarSplitButtonItem>
            <dxb:BarButtonItem x:Name="biRedo"
                               Content="Redo"
                               Glyph="/TIG.TotalLink.Client;component/Image/Icon/16x16/Redo.png"
                               KeyGesture="CTRL+Y"
                               Command="{Binding RedoCommand}" />
        </dxb:BarManager.Items>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <dxr:RibbonControl Grid.Row="0"
                               x:Name="RibbonControl"
                               RibbonStyle="Office2010"
                               ToolbarShowCustomizationButton="False"
                               AllowCustomization="False"
                               PreviewMouseRightButtonDown="RibbonControl_PreviewMouseRightButtonDown"
                               SelectedPageChanged="RibbonControl_SelectedPageChanged">

                <dxr:RibbonControl.ToolbarItems>
                    <dxb:BarSplitButtonItemLink BarItemName="biUndo" />
                    <dxb:BarButtonItemLink BarItemName="biRedo" />
                </dxr:RibbonControl.ToolbarItems>

                <dxb:BarManager.DXContextMenu>
                    <dxb:PopupMenu x:Name="RibbonPopupMenu"
                                   Opening="RibbonPopupMenu_Opening">
                        <dxb:PopupMenu.ItemLinks>
                            <dxb:BarButtonItemLink BarItemName="biAddRibbonItem" />
                            <dxb:BarButtonItemLink BarItemName="biEditRibbonItem" />
                            <dxb:BarButtonItemLink BarItemName="biDeleteRibbonItem" />
                            <dxb:BarItemLinkSeparator BarItemName="{x:Null}" />
                            <dxb:BarButtonItemLink BarItemName="biAddRibbonGroup" />
                            <dxb:BarButtonItemLink BarItemName="biEditRibbonGroup" />
                            <dxb:BarButtonItemLink BarItemName="biDeleteRibbonGroup" />
                            <dxb:BarItemLinkSeparator BarItemName="{x:Null}" />
                            <dxb:BarButtonItemLink BarItemName="biAddRibbonPage" />
                            <dxb:BarButtonItemLink BarItemName="biEditRibbonPage" />
                            <dxb:BarButtonItemLink BarItemName="biDeleteRibbonPage" />
                            <dxb:BarItemLinkSeparator BarItemName="{x:Null}" />
                            <dxb:BarButtonItemLink BarItemName="biAddRibbonCategory" />
                            <dxb:BarButtonItemLink BarItemName="biEditRibbonCategory" />
                            <dxb:BarButtonItemLink BarItemName="biDeleteRibbonCategory" />
                        </dxb:PopupMenu.ItemLinks>
                    </dxb:PopupMenu>
                </dxb:BarManager.DXContextMenu>

            </dxr:RibbonControl>

            <view:DocumentManagerView Grid.Row="1"
                                      RibbonControl="{Binding ElementName=RibbonControl}" />

            <dxr:RibbonStatusBarControl Grid.Row="2">
                <dxr:RibbonStatusBarControl.RightItems>
                    <dxb:BarStaticItem Content="{Binding Source={StaticResource AppContextProvider}, Path=AppContext.UserInfo.DisplayName}"
                                       ShowBorder="False" />
                    <dxb:BarStaticItem ShowBorder="False">
                        <dxb:BarStaticItem.ContentTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Source={StaticResource AppContextProvider}, Path=AppContext.AuthStateImage}"
                                       Width="16"
                                       Height="16" />
                            </DataTemplate>
                        </dxb:BarStaticItem.ContentTemplate>
                    </dxb:BarStaticItem>
                </dxr:RibbonStatusBarControl.RightItems>
            </dxr:RibbonStatusBarControl>
        </Grid>
    </dxb:BarManager>

</UserControl>
