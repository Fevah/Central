<UserControl x:Class="TIG.TotalLink.Client.View.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:viewModel="clr-namespace:TIG.TotalLink.Client.ViewModel"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:converter="clr-namespace:TIG.TotalLink.Client.Editor.Converter;assembly=TIG.TotalLink.Client.Editor"
             xmlns:helper="clr-namespace:TIG.TotalLink.Client.Helper"
             mc:Ignorable="d"
             d:DesignHeight="550"
             d:DesignWidth="350"
             d:DataContext="{d:DesignInstance viewModel:LoginViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <dxmvvm:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <dxmvvm:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <converter:IntToDecimalConverter x:Key="IntToDecimalConverter" />
        <dxmvvm:ObjectToObjectConverter x:Key="ServerVisibilityConverter">
            <dxmvvm:MapItem Source="{x:Static viewModel:LoginViewModel+AuthMethods.Windows}"
                            Target="{x:Static Visibility.Visible}" />
            <dxmvvm:MapItem Source="{x:Static viewModel:LoginViewModel+AuthMethods.TotalLink}"
                            Target="{x:Static Visibility.Visible}" />
            <dxmvvm:MapItem Source="{x:Static viewModel:LoginViewModel+AuthMethods.Offline}"
                            Target="{x:Static Visibility.Collapsed}" />
        </dxmvvm:ObjectToObjectConverter>
        <dxmvvm:ObjectToObjectConverter x:Key="CredentialsVisibilityConverter">
            <dxmvvm:MapItem Source="{x:Static viewModel:LoginViewModel+AuthMethods.Windows}"
                            Target="{x:Static Visibility.Collapsed}" />
            <dxmvvm:MapItem Source="{x:Static viewModel:LoginViewModel+AuthMethods.TotalLink}"
                            Target="{x:Static Visibility.Visible}" />
            <dxmvvm:MapItem Source="{x:Static viewModel:LoginViewModel+AuthMethods.Offline}"
                            Target="{x:Static Visibility.Collapsed}" />
        </dxmvvm:ObjectToObjectConverter>

        <!-- PasswordBox Style -->
        <Color x:Key="DefaultForegroundColor">#FF201F35</Color>
        <SolidColorBrush x:Key="Text.Foreground"
                         Color="{StaticResource DefaultForegroundColor}" />
        <SolidColorBrush x:Key="TextBox.Background"
                         Color="#FFFFFFFF" />
        <LinearGradientBrush x:Key="TextBox.BorderBrush"
                             EndPoint="0.5,1"
                             StartPoint="0.5,0">
            <GradientStop Color="#FF9DA0AA"
                          Offset="0" />
            <GradientStop Color="#FFD9DAE0"
                          Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="Text.Selection.Background"
                         Color="#FF6699FF" />
        <SolidColorBrush x:Key="Text.CaretBrush"
                         Color="#FF201F35" />
        <Style x:Key="FocusTemplate"
               TargetType="{x:Type Border}">
            <Setter Property="CornerRadius"
                    Value="1" />
            <Setter Property="BorderBrush"
                    Value="#FF0047FF" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Opacity"
                    Value="0.25" />
        </Style>
        <Style x:Key="FocusRectTemplate"
               TargetType="{x:Type Rectangle}">
            <Setter Property="Stroke"
                    Value="#FF6699FF" />
            <Setter Property="StrokeThickness"
                    Value="2" />
            <Setter Property="Margin"
                    Value="-1" />
            <Setter Property="RadiusX"
                    Value="1" />
            <Setter Property="RadiusY"
                    Value="1" />
            <Setter Property="Opacity"
                    Value="0.25" />
            <Setter Property="IsHitTestVisible"
                    Value="False" />
        </Style>
        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}" />
            <Setter Property="Foreground"
                    Value="{StaticResource Text.Foreground}" />
            <Setter Property="Background"
                    Value="{StaticResource TextBox.Background}" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource TextBox.BorderBrush}" />
            <Setter Property="SelectionBrush"
                    Value="{StaticResource Text.Selection.Background}" />
            <Setter Property="SelectionOpacity"
                    Value="0.5" />
            <Setter Property="CaretBrush"
                    Value="{StaticResource Text.CaretBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="2,2,2,2" />
            <Setter Property="AllowDrop"
                    Value="True" />
            <Setter Property="ScrollViewer.PanningMode"
                    Value="VerticalFirst" />
            <Setter Property="Stylus.IsFlicksEnabled"
                    Value="False" />
            <Setter Property="SnapsToDevicePixels"
                    Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Grid x:Name="Root"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <Grid x:Name="DefaultState">
                                <Border CornerRadius="1"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}" />
                            </Grid>
                            <Grid x:Name="FocusedState"
                                  Opacity="0">
                                <Rectangle Style="{StaticResource FocusRectTemplate}" />
                                <Border Style="{StaticResource FocusTemplate}" />
                            </Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          Margin="1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!--<Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="PART_ContentHost" Property="Opacity" Value="0.75" />
                            </Trigger>-->
                            <Trigger Property="IsFocused"
                                     Value="True">
                                <Setter TargetName="FocusedState"
                                        Property="Opacity"
                                        Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="Root"
                                        Property="Opacity"
                                        Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styles for ErrorMessage label -->
        <Style x:Key="LoginErrorMessageStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground">
                <Setter.Value>
                    <SolidColorBrush Color="Transparent" />
                </Setter.Value>
            </Setter>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="Transparent" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasLoginError}"
                             Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                From="Red"
                                                To="LightPink"
                                                Duration="0:0:0.5" />
                                <ColorAnimation Storyboard.TargetProperty="Foreground.Color"
                                                From="Red"
                                                To="Black"
                                                Duration="0:0:0.5" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <dxlc:LayoutControl x:Name="LayoutControl"
                            Orientation="Vertical"
                            UseLayoutRounding="True"
                            dxe:ValidationService.IsValidationContainer="True">

            <dxlc:LayoutItem>
                <Image Source="{Binding Source={StaticResource AppContextProvider}, Path=AppContext.LogoImage}"
                       Width="128"
                       Height="128" />
            </dxlc:LayoutItem>

            <dxlc:LayoutItem>
                <TextBlock x:Name="Title"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           FontWeight="Bold"
                           Text="{Binding Source={StaticResource AppContextProvider}, Path=AppContext.ApplicationTitle}"
                           Margin="12,12,12,0"
                           Foreground="#FF2D2D2D" />
            </dxlc:LayoutItem>

            <dxlc:LayoutGroup>

                <dxlc:LayoutItem HorizontalAlignment="Stretch"
                                 Height="36"
                                 Margin="0,8"
                                 Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <dxe:ProgressBarEdit Name="LoginProgress"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch">
                            <dxe:ProgressBarEdit.StyleSettings>
                                <dxe:ProgressBarMarqueeStyleSettings />
                            </dxe:ProgressBarEdit.StyleSettings>
                        </dxe:ProgressBarEdit>
                        <TextBlock Text="{Binding LoginStatusMessage}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold" />
                    </Grid>
                </dxlc:LayoutItem>

                <dxlc:LayoutItem Margin="0,8"
                                 Visibility="{Binding HasLoginError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border BorderBrush="Red"
                            BorderThickness="1">
                        <TextBlock Name="ErrorMessage"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontWeight="Bold"
                                   Padding="4"
                                   Text="{Binding LoginErrorMessage}"
                                   Style="{StaticResource LoginErrorMessageStyle}" />
                    </Border>
                </dxlc:LayoutItem>

            </dxlc:LayoutGroup>


            <dxlc:LayoutGroup Orientation="Vertical"
                              IsEnabled="{Binding IsLoggingIn, Converter={StaticResource BooleanNegationConverter}}">

                <dxlc:LayoutGroup Header="Authentication Method"
                                  View="GroupBox"
                                  Orientation="Vertical">

                    <dxlc:LayoutItem>
                        <dxe:ListBoxEdit EditValue="{Binding AuthMethod, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                         StyleSettings="{dxe:RadioListBoxEditStyleSettings}">
                            <dxe:ListBoxEdit.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" />
                                </ItemsPanelTemplate>
                            </dxe:ListBoxEdit.ItemsPanel>
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:EnumItemsSourceBehavior EnumType="{x:Type viewModel:LoginViewModel+AuthMethods}"
                                                                SplitNames="False" />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:ListBoxEdit>
                    </dxlc:LayoutItem>

                </dxlc:LayoutGroup>

                <dxlc:LayoutGroup Header="Server"
                                  View="GroupBox"
                                  Orientation="Vertical"
                                  Visibility="{Binding AuthMethod, Converter={StaticResource ServerVisibilityConverter}}">

                    <dxlc:LayoutItem Label="Server"
                                     AddColonToLabel="True">
                        <dxe:TextEdit EditValue="{Binding Server, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Port"
                                     AddColonToLabel="True">
                        <dxe:SpinEdit EditValue="{Binding BasePort, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntToDecimalConverter}}"
                                      InvalidValueBehavior="AllowLeaveEditor"
                                      HorizontalContentAlignment="Left"
                                      IsFloatValue="False"
                                      Mask="D" />
                    </dxlc:LayoutItem>

                </dxlc:LayoutGroup>

                <dxlc:LayoutGroup Header="Credentials"
                                  View="GroupBox"
                                  Orientation="Vertical"
                                  Visibility="{Binding AuthMethod, Converter={StaticResource CredentialsVisibilityConverter}}">

                    <dxlc:LayoutItem Label="User"
                                     AddColonToLabel="True">
                        <dxe:TextEdit EditValue="{Binding User, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                      InvalidValueBehavior="AllowLeaveEditor">
                            <dxmvvm:Interaction.Behaviors>
                                <dxmvvm:FocusBehavior />
                            </dxmvvm:Interaction.Behaviors>
                        </dxe:TextEdit>
                    </dxlc:LayoutItem>

                    <dxlc:LayoutItem Label="Password"
                                     AddColonToLabel="True">
                        <PasswordBox Name="Password"
                                     PasswordChanged="Password_PasswordChanged" />
                    </dxlc:LayoutItem>

                </dxlc:LayoutGroup>

                <dxlc:LayoutItem VerticalAlignment="Bottom"
                                 Height="40">
                    <Button Content="Login"
                            IsDefault="True"
                            Command="{Binding Path=LoginCommand}"
                            IsEnabled="{Binding Path=(dxe:ValidationService.HasValidationError), ElementName=LayoutControl, Converter={StaticResource BooleanNegationConverter}}" />
                </dxlc:LayoutItem>

                <dxlc:LayoutItem VerticalAlignment="Bottom"
                                 HorizontalAlignment="Right">
                    <Label Content="{Binding Source={StaticResource AppContextProvider}, Path=AppContext.VersionString}"
                           FontSize="9" />
                </dxlc:LayoutItem>


            </dxlc:LayoutGroup>

        </dxlc:LayoutControl>
    </Grid>

</UserControl>
