<dxr:DXRibbonWindow x:Class="TIG.TotalLink.Client.Window.MainWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon"
                    xmlns:viewModel="clr-namespace:TIG.TotalLink.Client.ViewModel"
                    mc:Ignorable="d"
                    Title="TotalLink Client"
                    WindowState="{Binding WindowState.ActualState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Left="{Binding WindowState.ActualLeft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Top="{Binding WindowState.ActualTop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Width="{Binding WindowState.ActualWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Height="{Binding WindowState.ActualHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Icon="{Binding Source={StaticResource AppContextProvider}, Path=AppContext.LogoIcon}"
                    d:DataContext="{d:DesignInstance viewModel:MainWindowViewModel, IsDesignTimeCreatable=True}">

    <ContentControl Content="{Binding MainView}" />

</dxr:DXRibbonWindow>
