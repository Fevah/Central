    <integrationServiceSettings>
      <authenticationSettings loginName="admin" password="jGl25bVBBBW96Qi9Te4V37Fnqchz/Eu4qB9vKrRIqRg=" />
    </integrationServiceSettings>
  </integrationServiceSection>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
  <appSettings>
    <add key="Server" value="localhost" />
    <add key="BasePort" value="42000" />
  </appSettings>
