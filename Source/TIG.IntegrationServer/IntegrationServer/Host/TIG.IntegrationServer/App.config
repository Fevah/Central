  </configSections>
  <integrationServiceSection xmlns="urn:TIG.IntegrationServer.Common.Configuration">
    <concurrentSettings syncTasksLimit="1" syncInstanceTasksPerSyncInstanceBundleTaskLimit="1" syncInstanceBundleTasksPerSyncEntityBundleTaskLimit="1" />
