<?xml version="1.0" encoding="utf-8" ?>
<!-- For more information on using transformations 
     see the web.config examples at http://go.microsoft.com/fwlink/?LinkId=214134. -->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <syncAgentConfigurationSection xmlns="urn:TIG.IntegrationServer.Common.Configuration">
    <changeTrackerSettings provider="System.Data.SqlClient" connectionString="Data Source=TotalLinkLive\TotalLinkLive; Initial Catalog=TotalLink3; user=nbsapp; pwd=##qwerty123; MultipleActiveResultSets=True"
      xdt:Transform="Replace"
      xdt:Locator="Match(provider)" />
  </syncAgentConfigurationSection>
</configuration>
