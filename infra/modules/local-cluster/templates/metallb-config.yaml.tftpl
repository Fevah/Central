# Generated by Terraform — MetalLB IP pool for bare-metal LoadBalancer
apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: central-pool
  namespace: metallb-system
spec:
  addresses:
    - ${metallb_start}-${metallb_end}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: central-l2
  namespace: metallb-system
spec:
  ipAddressPools:
    - central-pool
