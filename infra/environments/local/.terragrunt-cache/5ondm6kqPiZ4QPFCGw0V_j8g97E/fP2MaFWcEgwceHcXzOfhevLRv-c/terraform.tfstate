            "content": "# Generated by Terraform — do not edit manually\nall:\n  children:\n    k8s_master:\n      hosts:\n        k8s-master:\n          ansible_host: 192.168.56.10\n    k8s_workers:\n      hosts:\n        k8s-worker-01:\n          ansible_host: 192.168.56.21\n          node_labels: \"role=database\"\n        k8s-worker-02:\n          ansible_host: 192.168.56.22\n          node_labels: \"role=database\"\n        k8s-worker-03:\n          ansible_host: 192.168.56.23\n          node_labels: \"role=general\"\n        k8s-worker-04:\n          ansible_host: 192.168.56.24\n          node_labels: \"role=general\"\n        k8s-worker-05:\n          ansible_host: 192.168.56.25\n          node_labels: \"role=general\"\n        k8s-worker-06:\n          ansible_host: 192.168.56.26\n          node_labels: \"role=general\"\n    k8s:\n      children:\n        k8s_master:\n        k8s_workers:\n  vars:\n    ansible_user: vagrant\n    ansible_ssh_private_key_file: \"../vagrant/.vagrant/machines/{{ inventory_hostname }}/vmware_desktop/private_key\"\n    k8s_master_ip: \"192.168.56.10\"\n    k8s_pod_cidr: \"10.244.0.0/16\"\n    k8s_service_cidr: \"10.96.0.0/12\"\n    metallb_range_start: \"192.168.56.200\"\n    metallb_range_end: \"192.168.56.220\"\n    k8s_version: \"1.31\"\n    containerd_version: \"1.7\"\n    central_namespace: \"central\"\n",
